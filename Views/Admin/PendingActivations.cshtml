<div class="glass-card admin-table-card" data-admin-table data-page-size="10" data-search-placeholder="Search member or UTR..." data-count-label="pending">
    <div class="admin-table-header flex-wrap gap-2">
        <h5 class="fw-bold text-dark mb-0"><i class="bi bi-shield-check text-info me-2"></i>Activation queue</h5>
        <span class="admin-record-badge" data-admin-table-count>@list.Count pending</span>
        <div class="admin-search-wrap admin-table-search-wrap ms-lg-auto" style="min-width:220px;max-width:320px;">
            <i class="bi bi-search admin-search-icon"></i>
            <input type="search" data-admin-table-search class="form-control admin-search-input"
                   placeholder="Search member or UTR..." autocomplete="off" />
        </div>
    </div>
    @if (list.Any())
    {
        <div class="admin-table-scroll">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Member</th>
                        <th>UTR / Reference</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in list)
                    {
                        var searchText = $"{req.User?.Username} {req.User?.FullName} {req.TransactionReference}".ToLowerInvariant();
                        <tr data-search="@searchText">
                            <td class="admin-subtext">@req.CreatedDate.ToString("dd MMM yyyy")</td>
                            <td>
                                <div class="fw-bold text-dark small">@(req.User?.Username ?? "-")</div>
                                <div class="admin-subtext">@(req.User?.FullName ?? "-")</div>
                            </td>
                            <td><code class="text-primary small">@req.TransactionReference</code></td>
                            <td class="text-end">
                                <form asp-action="ApproveActivation" asp-route-id="@req.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-success rounded-pill px-3 me-1">
                                        <i class="bi bi-check-lg me-1"></i>Approve
                                    </button>
                                </form>
                                <form asp-action="RejectActivation" asp-route-id="@req.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        @await Html.PartialAsync("_AdminNoResults")
    }
</div>
