@model IEnumerable<MLM_Level.Models.ActivationRequest>
@{
    ViewData["Title"] = "Activation Requests";
    var list = Model.ToList();
}

<div class="admin-page-header admin-theme-amber mb-4">
    <div class="admin-page-header-glow"></div>
    <div class="row align-items-center position-relative z-1 g-3">
        <div class="col-lg-8">
            <div class="d-flex align-items-center gap-3">
                <div class="admin-page-icon"><i class="bi bi-shield-lock"></i></div>
                <div>
                    <h2 class="fw-bold text-white mb-0">Activation Requests</h2>
                    <p class="mb-0 text-white-50 small mt-1">Approve new member activations and distribute commissions</p>
                </div>
            </div>
        </div>
        <div class="col-lg-4 text-lg-end">
            <a asp-action="PendingRequests" class="admin-header-btn">
                <i class="bi bi-wallet2 me-1"></i>Withdrawals queue
            </a>
        </div>
    </div>
</div>

