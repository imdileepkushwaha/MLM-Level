@model List<MLM_Level.Models.CommissionTran>
@{
    ViewData["Title"] = "Global Transaction Ledger & Wallet Adjustments";
}

<div class="row g-4 mb-4">
    <!-- Page Header -->
    <div class="col-lg-8">
        <div class="glass-card p-4 h-100">
            <h4 class="text-white fw-bold mb-2">Global Ledger Audit & History</h4>
            <p class="text-secondary mb-0">System-wide transaction trail of all member commissions, manual wallet additions/deductions, and transfer audits.</p>
        </div>
    </div>
    
    <!-- Quick wallet adjustment form -->
    <div class="col-lg-4">
        <div class="glass-card p-4">
            <h5 class="text-white fw-bold mb-3"><i class="bi bi-wallet-fill text-pink me-2"></i>Adjust Member Wallet</h5>
            <form asp-controller="Admin" asp-action="AdjustWallet" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-2 form-group">
                    <input type="text" name="username" class="form-control form-control-sm auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" placeholder="Username" required />
                </div>
                <div class="mb-2 form-group">
                    <input type="number" step="0.01" name="amount" class="form-control form-control-sm auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" placeholder="Amount (positive to add, negative to subtract)" required />
                </div>
                <div class="mb-2 form-group">
                    <input type="text" name="description" class="form-control form-control-sm auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" placeholder="Description/Reason" required />
                </div>
                <button type="submit" class="btn btn-cyber-pink btn-sm w-100 py-2">
                    <i class="bi bi-patch-plus me-1"></i>Execute Adjustment
                </button>
            </form>
        </div>
    </div>
</div>

<!-- Ledger filter panel -->
<div class="glass-card p-3 mb-4">
    <form method="get" class="row g-3 align-items-center">
        <div class="col-md-4">
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary"><i class="bi bi-search"></i></span>
                <input type="text" name="searchUsername" value="@ViewBag.SearchUsername" class="form-control auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" placeholder="Filter by username..." />
            </div>
        </div>
        <div class="col-md-4">
            <select name="filterType" class="form-select auth-glow-input bg-transparent border-secondary border-opacity-25 text-white">
                <option value="" class="bg-dark text-white">All Transactions</option>
                <option value="Commission" selected="@(ViewBag.FilterType == "Commission")" class="bg-dark text-white">Commissions Payout Only</option>
                <option value="P2P" selected="@(ViewBag.FilterType == "P2P")" class="bg-dark text-white">P2P Transfers Only</option>
                <option value="Manual" selected="@(ViewBag.FilterType == "Manual")" class="bg-dark text-white">Manual Adjustments Only</option>
            </select>
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn btn-cyber-cyan w-100">
                <i class="bi bi-funnel me-1"></i>Filter Ledger
            </button>
            <a asp-action="Ledger" class="btn btn-cyber-outline w-100 text-center">
                Clear
            </a>
        </div>
    </form>
</div>

<!-- Ledger Audit Table -->
<div class="glass-card p-4">
    <h5 class="text-white fw-bold mb-4"><i class="bi bi-receipt text-cyan me-2"></i>Audit Trail Log</h5>
    <div class="glass-table-container">
        @if (Model.Any())
        {
            <table class="table glass-table align-middle">
                <thead>
                    <tr>
                        <th>Date & Time</th>
                        <th>User Wallet</th>
                        <th>From User / Admin</th>
                        <th>Type / Level</th>
                        <th>Amount</th>
                        <th>Transaction Info</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tx in Model)
                    {
                        <tr>
                            <td>@tx.Timestamp.ToString("dd MMM yyyy hh:mm:ss tt")</td>
                            <td>
                                <strong class="text-white">@@@tx.User.Username</strong><br/>
                                <span class="small text-muted" style="font-size: 0.75rem;">@tx.User.FullName</span>
                            </td>
                            <td>
                                @if (tx.FromUser != null)
                                {
                                    <strong class="text-secondary">@@@tx.FromUser.Username</strong><br/>
                                    <span class="small text-muted" style="font-size: 0.75rem;">@tx.FromUser.FullName</span>
                                }
                                else
                                {
                                    <span class="text-muted small">System / Root</span>
                                }
                            </td>
                            <td>
                                @if (tx.Level == 99)
                                {
                                    <span class="badge bg-opacity-10 bg-danger text-danger border border-danger border-opacity-25 px-2 py-1">Manual Adjust</span>
                                }
                                else if (tx.Level > 0 && tx.Level <= 5)
                                {
                                    <span class="badge bg-opacity-10 bg-info text-info border border-info border-opacity-25 px-2 py-1">Level @tx.Level</span>
                                }
                                else
                                {
                                    <span class="badge bg-opacity-10 bg-warning text-warning border border-warning border-opacity-25 px-2 py-1">P2P Transfer</span>
                                }
                            </td>
                            <td>
                                @if (tx.Amount >= 0)
                                {
                                    <strong class="text-success">+₹@tx.Amount.ToString("N2")</strong>
                                }
                                else
                                {
                                    <strong class="text-danger">-₹@Math.Abs(tx.Amount).ToString("N2")</strong>
                                }
                            </td>
                            <td class="text-secondary small">@tx.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center py-5 text-secondary">
                <i class="bi bi-file-earmark-spreadsheet fs-2 mb-2 d-block text-muted"></i>
                No matching transactions found in database ledger.
            </div>
        }
    </div>
</div>
