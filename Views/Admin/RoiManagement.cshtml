@model List<MLM_Level.Models.UserPackage>
@{
    ViewData["Title"] = "ROI Management";
    var packages = Model ?? new List<MLM_Level.Models.UserPackage>();
    var totalAmount = packages.Sum(p => p.Amount);
    var avgProgress = packages.Any() ? (int)packages.Average(p => p.RoiDurationDays > 0 ? (p.DaysPaid * 100.0 / p.RoiDurationDays) : 0) : 0;
}

<div class="admin-page-header admin-theme-teal mb-4">
    <div class="admin-page-header-glow"></div>
    <div class="row align-items-center position-relative z-1 g-3">
        <div class="col-lg-8">
            <div class="d-flex align-items-center gap-3">
                <div class="admin-page-icon"><i class="bi bi-graph-up-arrow"></i></div>
                <div>
                    <h2 class="fw-bold text-white mb-0">ROI Management</h2>
                    <p class="mb-0 text-white-50 small mt-1">Active packages awaiting daily return on investment</p>
                </div>
            </div>
        </div>
        <div class="col-lg-4 text-lg-end">
            <form asp-controller="Admin" asp-action="DistributeRoi" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn admin-btn-primary px-4 py-2">
                    <i class="bi bi-play-circle me-2"></i>Distribute Daily ROI
                </button>
            </form>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="glass-card admin-stat-card h-100">
            <div class="d-flex justify-content-between">
                <div>
                    <p class="admin-stat-label">Active packages</p>
                    <p class="admin-stat-value text-success mb-0">@packages.Count</p>
                </div>
                <div class="admin-stat-icon admin-stat-icon-teal"><i class="bi bi-box-seam"></i></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="glass-card admin-stat-card h-100">
            <div class="d-flex justify-content-between">
                <div>
                    <p class="admin-stat-label">Total invested</p>
                    <p class="admin-stat-value text-primary mb-0" style="font-size:1.1rem;">&#8377;@totalAmount.ToString("N0")</p>
                </div>
                <div class="admin-stat-icon admin-stat-icon-blue"><i class="bi bi-cash-stack"></i></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="glass-card admin-stat-card h-100">
            <div class="d-flex justify-content-between">
                <div>
                    <p class="admin-stat-label">Avg progress</p>
                    <p class="admin-stat-value text-info mb-0">@avgProgress%</p>
                </div>
                <div class="admin-stat-icon admin-stat-icon-violet"><i class="bi bi-percent"></i></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="glass-card admin-stat-card h-100">
            <div class="d-flex justify-content-between">
                <div>
                    <p class="admin-stat-label">Due today</p>
                    <p class="admin-stat-value text-warning mb-0">@packages.Count</p>
                </div>
                <div class="admin-stat-icon admin-stat-icon-amber"><i class="bi bi-calendar-check"></i></div>
            </div>
        </div>
    </div>
</div>

<div class="glass-card admin-table-card" data-admin-table data-page-size="10" data-search-placeholder="Search member or package..." data-count-label="packages">
    <div class="admin-table-header flex-wrap gap-2">
        <h5 class="fw-bold text-dark mb-0"><i class="bi bi-graph-up text-success me-2"></i>Active ROI packages</h5>
        <span class="admin-record-badge" data-admin-table-count>@packages.Count packages</span>
        <div class="admin-search-wrap admin-table-search-wrap" style="min-width:220px;max-width:320px;">
            <i class="bi bi-search admin-search-icon"></i>
            <input type="search" data-admin-table-search class="form-control admin-search-input"
                   placeholder="Search member or package..." autocomplete="off" />
        </div>
    </div>
    @if (packages.Any())
    {
        <div class="admin-table-scroll">
            <table class="table admin-table" id="roiTable">
                <thead>
                    <tr>
                        <th>Member</th>
                        <th>Package</th>
                        <th>Amount</th>
                        <th>ROI %</th>
                        <th>Progress</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var up in packages)
                    {
                        var pct = up.RoiDurationDays > 0 ? (up.DaysPaid * 100) / up.RoiDurationDays : 0;
                        var initial = up.User?.Username?.Length > 0 ? up.User.Username[0].ToString().ToUpper() : "?";
                        var searchText = $"{up.User?.Username} {up.User?.FullName} {up.Package?.Name} {up.Amount} {up.RoiPercentage}".ToLowerInvariant();
                        <tr data-search="@searchText">
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="admin-avatar">@initial</div>
                                    <div>
                                        <div class="fw-bold text-dark small">@(up.User?.Username ?? "-")</div>
                                        <div class="admin-subtext">@(up.User?.FullName ?? "-")</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="fw-semibold text-dark small">@(up.Package?.Name ?? "-")</div>
                                <div class="admin-subtext">@up.ActivationDate.ToString("dd MMM yyyy")</div>
                            </td>
                            <td class="fw-bold text-dark">&#8377;@up.Amount.ToString("N2")</td>
                            <td><span class="admin-badge-type admin-type-commission">@up.RoiPercentage%</span></td>
                            <td style="min-width:140px;">
                                <div class="d-flex justify-content-between admin-subtext mb-1">
                                    <span>Day @up.DaysPaid</span>
                                    <span>/ @up.RoiDurationDays</span>
                                </div>
                                <div class="progress admin-progress">
                                    <div class="progress-bar admin-progress-bar" style="width:@pct%"></div>
                                </div>
                            </td>
                            <td><span class="admin-badge-success"><i class="bi bi-circle-fill me-1" style="font-size:0.4rem;"></i>Active</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        @await Html.PartialAsync("_AdminNoResults")
    }
</div>
