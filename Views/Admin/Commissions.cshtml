@model List<MLM_Level.Models.CommissionTran>
@{
    ViewData["Title"] = "System Commissions Distribution Ledger";
}

<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card p-4">
            <h4 class="text-white fw-bold mb-2">Commissions Payout Audit Ledger</h4>
            <p class="text-secondary mb-0">System-wide audit trail of all level commissions generated and distributed from activation packages.</p>
        </div>
    </div>
</div>

<div class="glass-card p-4">
    <h5 class="text-white fw-bold mb-4"><i class="bi bi-receipt text-info me-2"></i>Global Payout Records</h5>
    <div class="glass-table-container">
        @if (Model.Any())
        {
            <table class="table glass-table align-middle">
                <thead>
                    <tr>
                        <th>Date & Time</th>
                        <th>Payout Recipient</th>
                        <th>Triggered By User</th>
                        <th>Sponsor Level</th>
                        <th>Distributed Amount</th>
                        <th>Audit Details</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tx in Model)
                    {
                        <tr>
                            <td>@tx.Timestamp.ToString("dd MMM yyyy hh:mm:ss tt")</td>
                            <td>
                                <strong class="text-white">@tx.User.Username</strong><br/>
                                <span class="small text-muted" style="font-size: 0.75rem;">@tx.User.FullName</span>
                            </td>
                            <td>
                                <strong class="text-white">@tx.FromUser.Username</strong><br/>
                                <span class="small text-muted" style="font-size: 0.75rem;">@tx.FromUser.FullName</span>
                            </td>
                            <td>
                                <span class="badge bg-opacity-10 bg-info text-info border border-info border-opacity-25 px-2 py-1">Level @tx.Level</span>
                            </td>
                            <td><strong class="text-success">+₹@tx.Amount.ToString("N2")</strong></td>
                            <td class="text-secondary small">@tx.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center py-5 text-secondary">
                <i class="bi bi-file-earmark-spreadsheet fs-2 mb-2 d-block text-muted"></i>
                No commissions have been generated or distributed yet.
            </div>
        }
    </div>
</div>
