@model MLM_Level.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "System Administration Dashboard";
}

<!-- Stat Metrics -->
<div class="row g-4 mb-4">
    <!-- Total Registered -->
    <div class="col-md-3 col-sm-6">
        <div class="glass-card p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <p class="text-secondary small fw-medium mb-1">Total Members</p>
                    <h3 class="text-white fw-extrabold mb-0">@Model.TotalUsers</h3>
                </div>
                <div class="stat-icon-box icon-box-cyan">
                    <i class="bi bi-people-fill"></i>
                </div>
            </div>
            <a asp-action="Members" class="small text-info text-decoration-none fw-bold">Manage Members <i class="bi bi-arrow-right-short"></i></a>
        </div>
    </div>

    <!-- Total Active -->
    <div class="col-md-3 col-sm-6">
        <div class="glass-card p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <p class="text-secondary small fw-medium mb-1">Active Accounts</p>
                    <h3 class="text-white fw-extrabold mb-0">@Model.ActiveUsers</h3>
                </div>
                <div class="stat-icon-box icon-box-green">
                    <i class="bi bi-patch-check-fill"></i>
                </div>
            </div>
            <span class="small text-secondary">Ratio: <strong>@(((double)Model.ActiveUsers / (Model.TotalUsers > 0 ? Model.TotalUsers : 1) * 100).ToString("N1"))%</strong> active</span>
        </div>
    </div>

    <!-- Total Sales -->
    <div class="col-md-3 col-sm-6">
        <div class="glass-card p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <p class="text-secondary small fw-medium mb-1">Gross Sales (₹)</p>
                    <h3 class="text-white fw-extrabold mb-0">₹@Model.TotalSales.ToString("N2")</h3>
                </div>
                <div class="stat-icon-box icon-box-blue">
                    <i class="bi bi-currency-rupee"></i>
                </div>
            </div>
            <span class="small text-secondary">Based on ₹1,000 package</span>
        </div>
    </div>

    <!-- Total Commissions -->
    <div class="col-md-3 col-sm-6">
        <div class="glass-card p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <p class="text-secondary small fw-medium mb-1">Commissions Distributed</p>
                    <h3 class="text-white fw-extrabold mb-0">₹@Model.TotalCommissionsDistributed.ToString("N2")</h3>
                </div>
                <div class="stat-icon-box icon-box-pink">
                    <i class="bi bi-graph-up"></i>
                </div>
            </div>
            <a asp-action="Commissions" class="small text-info text-decoration-none fw-bold">Commission Logs <i class="bi bi-arrow-right-short"></i></a>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Left Column: Pending Activations -->
    <div class="col-lg-6">
        <div class="glass-card p-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="text-white fw-bold mb-0">
                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-20 px-2 py-1 small me-2">@Model.PendingActivationsCount</span>
                    Pending Account Activations
                </h5>
                <a asp-action="PendingRequests" class="small text-secondary text-decoration-none">Manage Approvals</a>
            </div>

            <div class="glass-table-container">
                @if (Model.PendingActivations.Any())
                {
                    <table class="table glass-table align-middle">
                        <thead>
                            <tr>
                                <th>Member Details</th>
                                <th>UTR/Ref</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in Model.PendingActivations)
                            {
                                <tr>
                                    <td>
                                        <strong class="text-white">@req.User.Username</strong><br/>
                                        <span class="small text-muted" style="font-size: 0.75rem;">Joined: @req.User.JoinedDate.ToString("dd MMM yyyy")</span>
                                    </td>
                                    <td><code class="text-info">@req.TransactionReference</code></td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <form asp-action="ApproveActivation" asp-route-id="@req.Id" method="post">
                                                <button type="submit" class="btn btn-success btn-sm px-2 py-1" style="font-size: 0.75rem;"><i class="bi bi-check-circle"></i></button>
                                            </form>
                                            <form asp-action="RejectActivation" asp-route-id="@req.Id" method="post">
                                                <button type="submit" class="btn btn-danger btn-sm px-2 py-1" style="font-size: 0.75rem;"><i class="bi bi-slash-circle"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center py-5 text-secondary small">
                        <i class="bi bi-emoji-smile fs-2 mb-2 d-block text-muted"></i>
                        No pending activations in queue!
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Right Column: Pending Withdrawals -->
    <div class="col-lg-6">
        <div class="glass-card p-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="text-white fw-bold mb-0">
                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-20 px-2 py-1 small me-2">@Model.PendingWithdrawalsCount</span>
                    Pending Withdrawal Approvals
                </h5>
                <a asp-action="PendingRequests" class="small text-secondary text-decoration-none">Manage Approvals</a>
            </div>

            <div class="glass-table-container">
                @if (Model.PendingWithdrawals.Any())
                {
                    <table class="table glass-table align-middle">
                        <thead>
                            <tr>
                                <th>Member</th>
                                <th>Amount</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var w in Model.PendingWithdrawals)
                            {
                                <tr>
                                    <td>
                                        <strong class="text-white">@w.User.Username</strong><br/>
                                        <span class="small text-muted" style="font-size: 0.75rem;">Balance: ₹@w.User.WalletBalance.ToString("N2")</span>
                                    </td>
                                    <td><strong class="text-warning">₹@w.Amount.ToString("N2")</strong></td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <form asp-action="ApproveWithdrawal" asp-route-id="@w.Id" method="post">
                                                <button type="submit" class="btn btn-success btn-sm px-2 py-1" style="font-size: 0.75rem;"><i class="bi bi-check-circle"></i></button>
                                            </form>
                                            <form asp-action="RejectWithdrawal" asp-route-id="@w.Id" method="post">
                                                <button type="submit" class="btn btn-danger btn-sm px-2 py-1" style="font-size: 0.75rem;"><i class="bi bi-arrow-counterclockwise"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center py-5 text-secondary small">
                        <i class="bi bi-emoji-smile fs-2 mb-2 d-block text-muted"></i>
                        No pending withdrawal requests in queue!
                    </div>
                }
            </div>
        </div>
    </div>
</div>
