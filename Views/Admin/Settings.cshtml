                @Html.AntiForgeryToken()
                <div class="modal-body p-4 pt-3">
                    <p class="text-muted small mb-3">Save SMTP settings before sending a test email.</p>
                    <label class="settings-label">Recipient Email</label>
                    <input type="email" name="testEmail" class="form-control settings-input" required placeholder="admin@example.com" />
                </div>
                <div class="modal-footer border-0 pt-0 pb-4 px-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-semibold">Send Email</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var fileInput = document.getElementById('popupImageInput');
    var fileNameEl = document.getElementById('popupFileName');
    var previewImg = document.getElementById('adminPopupPreviewImg');
    var previewEmpty = document.getElementById('adminPopupPreviewEmpty');
    var previewOverlay = document.getElementById('adminPopupPreviewOverlay');
    var previewBadge = document.getElementById('adminPopupPreviewBadge');
    var currentWrap = document.getElementById('adminPopupCurrentWrap');
    var currentImg = document.getElementById('adminPopupCurrentImg');
    var enableSwitch = document.getElementById('homePopupEnabled');

    if (!fileInput) return;

    function refreshPreviewState(hasImage) {
        if (previewOverlay) {
            previewOverlay.classList.toggle('is-empty', !hasImage);
        }
        if (previewBadge) {
            previewBadge.textContent = hasImage ? (enableSwitch && enableSwitch.checked ? 'Live' : 'Preview') : 'Empty';
        }
    }

    fileInput.addEventListener('change', function () {
        var file = fileInput.files && fileInput.files[0];
        if (!file) return;

        fileNameEl.textContent = file.name;
        if (enableSwitch) enableSwitch.checked = true;

        var reader = new FileReader();
        reader.onload = function (e) {
            if (previewImg) {
                previewImg.src = e.target.result;
                previewImg.hidden = false;
            }
            if (previewEmpty) previewEmpty.hidden = true;
            if (currentImg) {
                currentImg.src = e.target.result;
            }
            if (currentWrap) currentWrap.classList.remove('d-none');
            refreshPreviewState(true);
        };
        reader.readAsDataURL(file);
    });

    if (enableSwitch) {
        enableSwitch.addEventListener('change', function () {
            refreshPreviewState(!!(previewImg && previewImg.src));
        });
    }

    refreshPreviewState(!!(previewImg && previewImg.src && !previewImg.hidden));
})();
</script>
}
