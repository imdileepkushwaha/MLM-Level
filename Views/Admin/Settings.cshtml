@model MLM_Level.Models.MlmSetting
@{
    ViewData["Title"] = "MLM Configuration & General Settings";
}

<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card p-4">
            <h4 class="text-white fw-bold mb-2">MLM Configuration Portal</h4>
            <p class="text-secondary mb-0">Manage level commission rates, withdrawal constraints, fee structures, and company collection accounts.</p>
        </div>
    </div>
</div>

<form asp-controller="Admin" asp-action="Settings" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>

    <div class="row g-4">
        <!-- Commission Setup -->
        <div class="col-md-6">
            <div class="glass-card p-4 h-100">
                <h5 class="text-white fw-bold mb-4">
                    <i class="bi bi-percent text-info me-2"></i>Multi-Level Commission Structure
                </h5>
                <p class="text-secondary small mb-4">Set the percentage of package price paid to upline sponsors at each level of recruitment hierarchy.</p>
                
                <div class="mb-3 form-group">
                    <label for="Level1Commission" class="text-secondary small fw-bold">Level 1 Commission (%)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary">Level 1</span>
                        <input asp-for="Level1Commission" type="number" step="0.01" class="form-control auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" required />
                        <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary">%</span>
                    </div>
                </div>

                <div class="mb-3 form-group">
                    <label for="Level2Commission" class="text-secondary small fw-bold">Level 2 Commission (%)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary">Level 2</span>
                        <input asp-for="Level2Commission" type="number" step="0.01" class="form-control auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" required />
                        <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary">%</span>
                    </div>
                </div>

                <div class="mb-3 form-group">
                    <label for="Level3Commission" class="text-secondary small fw-bold">Level 3 Commission (%)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary">Level 3</span>
                        <input asp-for="Level3Commission" type="number" step="0.01" class="form-control auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" required />
                        <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary">%</span>
                    </div>
                </div>

                <div class="mb-3 form-group">
                    <label for="Level4Commission" class="text-secondary small fw-bold">Level 4 Commission (%)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary">Level 4</span>
                        <input asp-for="Level4Commission" type="number" step="0.01" class="form-control auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" required />
                        <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary">%</span>
                    </div>
                </div>

                <div class="mb-3 form-group">
                    <label for="Level5Commission" class="text-secondary small fw-bold">Level 5 Commission (%)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary">Level 5</span>
                        <input asp-for="Level5Commission" type="number" step="0.01" class="form-control auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" required />
                        <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary">%</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Withdrawals & Limits -->
        <div class="col-md-6">
            <div class="glass-card p-4 mb-4">
                <h5 class="text-white fw-bold mb-4">
                    <i class="bi bi-wallet2 text-pink me-2"></i>Withdrawal Rules & Limits
                </h5>
                
                <div class="mb-3 form-group">
                    <label for="MinWithdrawalLimit" class="text-secondary small fw-bold">Minimum Withdrawal Limit (₹)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary">₹</span>
                        <input asp-for="MinWithdrawalLimit" type="number" step="0.01" class="form-control auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" required />
                        <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary">INR</span>
                    </div>
                </div>

                <div class="mb-3 form-group">
                    <label for="WithdrawalFeePercent" class="text-secondary small fw-bold">Withdrawal Fee (%)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary">Fee</span>
                        <input asp-for="WithdrawalFeePercent" type="number" step="0.01" class="form-control auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" required />
                        <span class="input-group-text bg-dark border-secondary border-opacity-25 text-secondary">%</span>
                    </div>
                    <small class="text-muted d-block mt-1">Deducted from the user wallet upon withdrawal request approval.</small>
                </div>
            </div>

            <!-- Payment Accounts settings -->
            <div class="glass-card p-4">
                <h5 class="text-white fw-bold mb-4">
                    <i class="bi bi-bank text-cyan me-2"></i>Company Gateway details
                </h5>
                
                <div class="mb-3 form-group">
                    <label for="CompanyQrCodeUrl" class="text-secondary small fw-bold">UPI ID / Address</label>
                    <input asp-for="CompanyQrCodeUrl" type="text" class="form-control auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" placeholder="e.g. elitemlm@paytm" />
                    <small class="text-muted d-block mt-1">Direct UPI ID shown to members on activation view.</small>
                </div>

                <div class="mb-3 form-group">
                    <label for="BankDetails" class="text-secondary small fw-bold">Bank Deposit Information</label>
                    <textarea asp-for="BankDetails" rows="4" class="form-control auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" placeholder="Enter bank transfer instructions..."></textarea>
                    <small class="text-muted d-block mt-1">Bank Name, IFSC, Account Number, etc. to copy-paste.</small>
                </div>
            </div>
        </div>

        <div class="col-12 mt-4 text-end">
            <button type="submit" class="btn btn-cyber-cyan px-5 py-3">
                <i class="bi bi-save me-2"></i>Save Settings & Rules
            </button>
        </div>
    </div>
</form>
