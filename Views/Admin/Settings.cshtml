<form asp-controller="Admin" asp-action="Settings" method="post" id="settingsForm">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small mb-4" role="alert"></div>
    <input type="hidden" asp-for="ActiveTab" id="ActiveTabInput" />

    <div class="row align-items-start g-4">
        <!-- Sidebar -->
        <div class="col-md-4 col-lg-3">
            <div class="glass-card p-3 settings-sidebar h-100">
                <nav class="nav flex-column nav-pills settings-nav" id="v-pills-tab" role="tablist" aria-orientation="vertical">

                    <span class="settings-nav-group">Platform</span>
                    <button class="nav-link settings-nav-link @(Model.ActiveTab == "general" ? "active" : "")" id="tab-general" data-bs-toggle="pill" data-bs-target="#content-general" type="button" role="tab" onclick="document.getElementById('ActiveTabInput').value = 'general'">
                        <span class="settings-nav-icon settings-nav-icon-red"><i class="bi bi-sliders"></i></span>General
                    </button>
                    <button class="nav-link settings-nav-link @(Model.ActiveTab == "commission" ? "active" : "")" id="tab-commission" data-bs-toggle="pill" data-bs-target="#content-commission" type="button" role="tab" onclick="document.getElementById('ActiveTabInput').value = 'commission'">
                        <span class="settings-nav-icon settings-nav-icon-blue"><i class="bi bi-diagram-3"></i></span>Commission Setup
                    </button>
                    <button class="nav-link settings-nav-link @(Model.ActiveTab == "withdrawals" ? "active" : "")" id="tab-withdrawals" data-bs-toggle="pill" data-bs-target="#content-withdrawals" type="button" role="tab" onclick="document.getElementById('ActiveTabInput').value = 'withdrawals'">
                        <span class="settings-nav-icon settings-nav-icon-purple"><i class="bi bi-receipt"></i></span>Withdrawal Rules
                    </button>
                    <button class="nav-link settings-nav-link @(Model.ActiveTab == "paymentSetup" ? "active" : "")" id="tab-paymentSetup" data-bs-toggle="pill" data-bs-target="#content-paymentSetup" type="button" role="tab" onclick="document.getElementById('ActiveTabInput').value = 'paymentSetup'">
                        <span class="settings-nav-icon settings-nav-icon-red"><i class="bi bi-bank"></i></span>Payment Setup
                    </button>
                    <button class="nav-link settings-nav-link @(Model.ActiveTab == "homePopup" ? "active" : "")" id="tab-homePopup" data-bs-toggle="pill" data-bs-target="#content-homePopup" type="button" role="tab" onclick="document.getElementById('ActiveTabInput').value = 'homePopup'">
                        <span class="settings-nav-icon settings-nav-icon-amber"><i class="bi bi-image"></i></span>Website Popup
                    </button>

                    <span class="settings-nav-group">Integrations</span>
                    <button class="nav-link settings-nav-link @(Model.ActiveTab == "smtp" ? "active" : "")" id="tab-smtp" data-bs-toggle="pill" data-bs-target="#content-smtp" type="button" role="tab" onclick="document.getElementById('ActiveTabInput').value = 'smtp'">
                        <span class="settings-nav-icon settings-nav-icon-cyan"><i class="bi bi-envelope"></i></span>SMTP Email
                    </button>
                    <button class="nav-link settings-nav-link @(Model.ActiveTab == "sms" ? "active" : "")" id="tab-sms" data-bs-toggle="pill" data-bs-target="#content-sms" type="button" role="tab" onclick="document.getElementById('ActiveTabInput').value = 'sms'">
                        <span class="settings-nav-icon settings-nav-icon-pink"><i class="bi bi-chat-text"></i></span>SMS Gateway
                    </button>
                    <button class="nav-link settings-nav-link @(Model.ActiveTab == "whatsapp" ? "active" : "")" id="tab-whatsapp" data-bs-toggle="pill" data-bs-target="#content-whatsapp" type="button" role="tab" onclick="document.getElementById('ActiveTabInput').value = 'whatsapp'">
                        <span class="settings-nav-icon settings-nav-icon-green"><i class="bi bi-whatsapp"></i></span>WhatsApp API
                    </button>

                    <span class="settings-nav-group">Account</span>
                    <button class="nav-link settings-nav-link @(Model.ActiveTab == "adminProfile" ? "active" : "")" id="tab-adminProfile" data-bs-toggle="pill" data-bs-target="#content-adminProfile" type="button" role="tab" onclick="document.getElementById('ActiveTabInput').value = 'adminProfile'">
                        <span class="settings-nav-icon settings-nav-icon-indigo"><i class="bi bi-person-badge"></i></span>Admin Profile
                    </button>
                    <button class="nav-link settings-nav-link @(Model.ActiveTab == "password" ? "active" : "")" id="tab-password" data-bs-toggle="pill" data-bs-target="#content-password" type="button" role="tab" onclick="document.getElementById('ActiveTabInput').value = 'password'">
                        <span class="settings-nav-icon settings-nav-icon-green"><i class="bi bi-shield-lock"></i></span>Password
                    </button>
                </nav>
            </div>
        </div>

        <!-- Tab Content -->
        <div class="col-md-8 col-lg-9">
            <div class="tab-content" id="v-pills-tabContent">

                <div class="tab-pane fade @(Model.ActiveTab == "general" ? "show active" : "")" id="content-general" role="tabpanel">
                    <div class="glass-card settings-panel settings-panel--general">
                        <div class="settings-panel-top">
                            <div class="settings-panel-icon settings-panel-icon-red"><i class="bi bi-sliders"></i></div>
                            <div class="settings-panel-heading">
                                <h5 class="fw-bold text-dark mb-1">General settings</h5>
                                <p class="text-muted small mb-0">Site identity, support contact, and maintenance mode.</p>
                            </div>
                            <span class="settings-panel-badge @(isOnline ? "is-success" : "is-warning")">
                                <i class="bi @(isOnline ? "bi-check-circle" : "bi-tools") me-1"></i>@(isOnline ? "Online" : "Maintenance")
                            </span>
                        </div>
                        <div class="settings-panel-body">
                            <div class="settings-section">
                                <p class="settings-section-title">
                                    <span class="settings-section-title-icon is-indigo"><i class="bi bi-building"></i></span>
                                    Site identity
                                </p>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="settings-label">Site Name</label>
                                        <input asp-for="Settings.SiteName" type="text" class="form-control settings-input" placeholder="Elite MLM Level Network" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="settings-label">Support Email</label>
                                        <input asp-for="Settings.SupportEmail" type="email" class="form-control settings-input" placeholder="support@example.com" />
                                    </div>
                                </div>
                            </div>
                            <div class="settings-section">
                                <p class="settings-section-title">
                                    <span class="settings-section-title-icon is-green"><i class="bi bi-shield-check"></i></span>
                                    Portal availability
                                </p>
                                <label class="settings-label">Maintenance Mode</label>
                                <select asp-for="Settings.MaintenanceMode" class="form-select settings-input">
                                    <option value="Online">Website Online — members can access the portal</option>
                                    <option value="Offline">Maintenance Mode — member access paused</option>
                                </select>
                                <div class="settings-note mt-3">
                                    <i class="bi bi-info-circle"></i>
                                    <span>When maintenance mode is on, members see a maintenance message and cannot sign in. Admin portal stays available.</span>
                                </div>
                            </div>
                        </div>
                        <div class="settings-panel-footer">
                            <button type="submit" class="btn settings-save-btn"><i class="bi bi-check2-circle me-1"></i>Save general settings</button>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade @(Model.ActiveTab == "commission" ? "show active" : "")" id="content-commission" role="tabpanel">
                    @{
                        var totalCommission = Model.Settings.Level1Commission + Model.Settings.Level2Commission + Model.Settings.Level3Commission + Model.Settings.Level4Commission + Model.Settings.Level5Commission;
                    }
                    <div class="glass-card settings-panel settings-panel--commission">
                        <div class="settings-panel-top">
                            <div class="settings-panel-icon settings-panel-icon-blue"><i class="bi bi-diagram-3"></i></div>
                            <div class="settings-panel-heading">
                                <h5 class="fw-bold text-dark mb-1">Commission setup</h5>
                                <p class="text-muted small mb-0">Set referral payout percentages across five levels.</p>
                            </div>
                            <span class="settings-panel-badge is-info">
                                <i class="bi bi-percent me-1"></i>@totalCommission.ToString("0.##")% total
                            </span>
                        </div>
                        <div class="settings-panel-body">
                            <div class="settings-level-grid">
                                <div class="settings-level-card">
                                    <span class="settings-level-badge">L1</span>
                                    <label class="settings-label">Level 1</label>
                                    <div class="settings-input-suffix-wrap">
                                        <input asp-for="Settings.Level1Commission" type="number" step="0.01" class="form-control settings-input" required />
                                        <span class="settings-input-suffix">%</span>
                                    </div>
                                </div>
                                <div class="settings-level-card">
                                    <span class="settings-level-badge">L2</span>
                                    <label class="settings-label">Level 2</label>
                                    <div class="settings-input-suffix-wrap">
                                        <input asp-for="Settings.Level2Commission" type="number" step="0.01" class="form-control settings-input" required />
                                        <span class="settings-input-suffix">%</span>
                                    </div>
                                </div>
                                <div class="settings-level-card">
                                    <span class="settings-level-badge">L3</span>
                                    <label class="settings-label">Level 3</label>
                                    <div class="settings-input-suffix-wrap">
                                        <input asp-for="Settings.Level3Commission" type="number" step="0.01" class="form-control settings-input" required />
                                        <span class="settings-input-suffix">%</span>
                                    </div>
                                </div>
                                <div class="settings-level-card">
                                    <span class="settings-level-badge">L4</span>
                                    <label class="settings-label">Level 4</label>
                                    <div class="settings-input-suffix-wrap">
                                        <input asp-for="Settings.Level4Commission" type="number" step="0.01" class="form-control settings-input" required />
                                        <span class="settings-input-suffix">%</span>
                                    </div>
                                </div>
                                <div class="settings-level-card">
                                    <span class="settings-level-badge">L5</span>
                                    <label class="settings-label">Level 5</label>
                                    <div class="settings-input-suffix-wrap">
                                        <input asp-for="Settings.Level5Commission" type="number" step="0.01" class="form-control settings-input" required />
                                        <span class="settings-input-suffix">%</span>
                                    </div>
                                </div>
                            </div>
                            <div class="settings-note mt-2">
                                <i class="bi bi-lightbulb"></i>
                                <span>Commissions are calculated on package activation amount and paid to active sponsors up the chain.</span>
                            </div>
                        </div>
                        <div class="settings-panel-footer">
                            <button type="submit" class="btn settings-save-btn"><i class="bi bi-check2-circle me-1"></i>Save commission setup</button>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade @(Model.ActiveTab == "withdrawals" ? "show active" : "")" id="content-withdrawals" role="tabpanel">
                    <div class="glass-card settings-panel settings-panel--withdrawals">
                        <div class="settings-panel-top">
                            <div class="settings-panel-icon settings-panel-icon-purple"><i class="bi bi-receipt"></i></div>
                            <div class="settings-panel-heading">
                                <h5 class="fw-bold text-dark mb-1">Withdrawal rules</h5>
                                <p class="text-muted small mb-0">Minimum thresholds, fees, and tax deductions for payouts.</p>
                            </div>
                        </div>
                        <div class="settings-panel-body">
                            <div class="settings-field-grid">
                                <div class="settings-field-card">
                                    <div class="settings-field-card-icon is-green"><i class="bi bi-cash-stack"></i></div>
                                    <label class="settings-label">Minimum payout (&#8377;)</label>
                                    <input asp-for="Settings.MinWithdrawalLimit" type="number" step="0.01" class="form-control settings-input" required />
                                </div>
                                <div class="settings-field-card">
                                    <div class="settings-field-card-icon is-blue"><i class="bi bi-percent"></i></div>
                                    <label class="settings-label">Processing fee (%)</label>
                                    <input asp-for="Settings.WithdrawalFeePercent" type="number" step="0.01" class="form-control settings-input" required />
                                </div>
                                <div class="settings-field-card">
                                    <div class="settings-field-card-icon is-amber"><i class="bi bi-receipt-cutoff"></i></div>
                                    <label class="settings-label">TDS deduction (%)</label>
                                    <input asp-for="Settings.TdsPercent" type="number" step="0.01" class="form-control settings-input" required />
                                </div>
                                <div class="settings-field-card">
                                    <div class="settings-field-card-icon is-purple"><i class="bi bi-moon-stars"></i></div>
                                    <label class="settings-label">Daily closing admin charge (%)</label>
                                    <input asp-for="Settings.AdminChargePercent" type="number" step="0.01" class="form-control settings-input" required />
                                </div>
                            </div>
                        </div>
                        <div class="settings-panel-footer">
                            <button type="submit" class="btn settings-save-btn"><i class="bi bi-check2-circle me-1"></i>Save withdrawal rules</button>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade @(Model.ActiveTab == "paymentSetup" ? "show active" : "")" id="content-paymentSetup" role="tabpanel">
                    <div class="glass-card settings-panel settings-panel--payment">
                        <div class="settings-panel-top">
                            <div class="settings-panel-icon settings-panel-icon-red"><i class="bi bi-bank"></i></div>
                            <div class="settings-panel-heading">
                                <h5 class="fw-bold text-dark mb-1">Payment setup</h5>
                                <p class="text-muted small mb-0">Manual payment instructions shown to members during activation.</p>
                            </div>
                        </div>
                        <div class="settings-panel-body">
                            <div class="settings-section">
                                <p class="settings-section-title">
                                    <span class="settings-section-title-icon is-violet"><i class="bi bi-qr-code"></i></span>
                                    UPI payment
                                </p>
                                <label class="settings-label">UPI ID / Address</label>
                                <input asp-for="Settings.CompanyQrCodeUrl" type="text" class="form-control settings-input" placeholder="e.g. elitemlm@paytm" />
                                <small class="text-muted d-block mt-2">Shown on the member activation screen for quick UPI transfers.</small>
                            </div>
                            <div class="settings-section settings-section--bank">
                                <p class="settings-section-title">
                                    <span class="settings-section-title-icon is-red"><i class="bi bi-bank2"></i></span>
                                    Bank deposit
                                </p>
                                <div class="settings-bank-card">
                                    <div class="settings-bank-card-head">
                                        <div class="settings-bank-card-icon"><i class="bi bi-bank2"></i></div>
                                        <div>
                                            <p class="settings-bank-card-title mb-0">Offline bank transfer</p>
                                            <p class="settings-bank-card-sub mb-0">Members copy these details on the activation page.</p>
                                        </div>
                                    </div>
                                    <label class="settings-label">Transfer instructions</label>
                                    <textarea asp-for="Settings.BankDetails" rows="6" class="form-control settings-input settings-bank-textarea" placeholder="Bank Name&#10;Account Holder Name&#10;Account Number&#10;IFSC Code&#10;Branch (optional)"></textarea>
                                    <div class="settings-bank-checklist">
                                        <span><i class="bi bi-check-circle-fill"></i> Bank name</span>
                                        <span><i class="bi bi-check-circle-fill"></i> Account holder</span>
                                        <span><i class="bi bi-check-circle-fill"></i> Account number</span>
                                        <span><i class="bi bi-check-circle-fill"></i> IFSC code</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="settings-panel-footer">
                            <button type="submit" class="btn settings-save-btn"><i class="bi bi-check2-circle me-1"></i>Save payment setup</button>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade @(Model.ActiveTab == "homePopup" ? "show active" : "")" id="content-homePopup" role="tabpanel">
                    @{
                        var hasPopupImage = !string.IsNullOrWhiteSpace(Model.Settings.HomePopupImageUrl);
                        var popupIsLive = Model.Settings.HomePopupEnabled && hasPopupImage;
                    }

                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="glass-card admin-popup-stat h-100">
                                <div class="admin-popup-stat-icon @(popupIsLive ? "is-live" : (hasPopupImage ? "is-ready" : "is-off"))">
                                    <i class="bi @(popupIsLive ? "bi-broadcast" : (hasPopupImage ? "bi-pause-circle" : "bi-eye-slash"))"></i>
                                </div>
                                <div>
                                    <p class="admin-popup-stat-label">Homepage status</p>
                                    <p class="admin-popup-stat-value mb-0">
                                        @(popupIsLive ? "Live" : (hasPopupImage ? "Saved, hidden" : "Not configured"))
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="glass-card admin-popup-stat h-100">
                                <div class="admin-popup-stat-icon is-image">
                                    <i class="bi bi-image"></i>
                                </div>
                                <div>
                                    <p class="admin-popup-stat-label">Popup image</p>
                                    <p class="admin-popup-stat-value mb-0">@(hasPopupImage ? "Uploaded" : "Missing")</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="glass-card admin-popup-stat h-100">
                                <div class="admin-popup-stat-icon is-visit">
                                    <i class="bi bi-people"></i>
                                </div>
                                <div>
                                    <p class="admin-popup-stat-label">Visitor experience</p>
                                    <p class="admin-popup-stat-value mb-0">@(popupIsLive ? "Auto popup" : "No popup")</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4 align-items-stretch">
                        <div class="col-xl-7">
                            <div class="glass-card p-4 settings-panel admin-popup-config h-100">
                                <div class="admin-popup-config-head mb-4">
                                    <div>
                                        <h5 class="fw-bold text-dark mb-1">Configure popup</h5>
                                        <p class="text-muted small mb-0">Upload a banner and choose when visitors see it on the homepage.</p>
                                    </div>
                                    @if (popupIsLive)
                                    {
                                        <span class="admin-popup-status admin-popup-status-live"><i class="bi bi-broadcast me-1"></i>Live</span>
                                    }
                                    else if (hasPopupImage)
                                    {
                                        <span class="admin-popup-status admin-popup-status-ready"><i class="bi bi-pause-circle me-1"></i>Ready</span>
                                    }
                                    else
                                    {
                                        <span class="admin-popup-status admin-popup-status-off"><i class="bi bi-eye-slash me-1"></i>Setup needed</span>
                                    }
                                </div>

                                <div class="admin-popup-progress mb-4">
                                    <div class="admin-popup-progress-step @(hasPopupImage ? "is-done" : "is-active")">
                                        <span class="admin-popup-progress-dot">1</span>
                                        <span class="admin-popup-progress-text">Upload</span>
                                    </div>
                                    <div class="admin-popup-progress-line @(hasPopupImage ? "is-done" : "")"></div>
                                    <div class="admin-popup-progress-step @(popupIsLive ? "is-done" : (hasPopupImage ? "is-active" : ""))">
                                        <span class="admin-popup-progress-dot">2</span>
                                        <span class="admin-popup-progress-text">Enable</span>
                                    </div>
                                    <div class="admin-popup-progress-line @(popupIsLive ? "is-done" : "")"></div>
                                    <div class="admin-popup-progress-step @(popupIsLive ? "is-active is-done" : "")">
                                        <span class="admin-popup-progress-dot">3</span>
                                        <span class="admin-popup-progress-text">Go live</span>
                                    </div>
                                </div>

                                <div id="homePopupFields">
                                    <div class="admin-popup-toggle-card mb-4">
                                        <div class="admin-popup-toggle-main">
                                            <div class="admin-popup-toggle-icon">
                                                <i class="bi bi-megaphone"></i>
                                            </div>
                                            <div class="flex-grow-1">
                                                <div class="form-check form-switch m-0">
                                                    <input type="hidden" name="homePopupEnabled" value="false" form="homePopupSaveForm" />
                                                    <input class="form-check-input" type="checkbox" name="homePopupEnabled" id="homePopupEnabled" value="true"
                                                           form="homePopupSaveForm" @(Model.Settings.HomePopupEnabled ? "checked" : null) />
                                                    <label class="form-check-label settings-label mb-0" for="homePopupEnabled">
                                                        Show popup on homepage
                                                    </label>
                                                </div>
                                                <p class="small text-muted mb-0 mt-1">Turn off to keep the image saved without showing it to visitors.</p>
                                            </div>
                                        </div>
                                    </div>

                                    <label class="settings-label d-block mb-2">Popup image</label>
                                    <div class="admin-popup-current mb-3 @(hasPopupImage ? "" : "d-none")" id="adminPopupCurrentWrap">
                                        <img src="@(hasPopupImage ? Model.Settings.HomePopupImageUrl : "")" alt="Current popup" class="admin-popup-current-img" id="adminPopupCurrentImg" />
                                        <div class="admin-popup-current-meta">
                                            <strong>Current image</strong>
                                            <span class="small text-muted d-block">Upload a new file below to replace it.</span>
                                        </div>
                                    </div>

                                    <label class="admin-popup-upload" for="popupImageInput">
                                        <input type="file" name="popupImage" id="popupImageInput" class="admin-popup-upload-input"
                                               form="homePopupSaveForm" accept="image/jpeg,image/png,image/webp,image/gif" />
                                        <span class="admin-popup-upload-icon"><i class="bi bi-cloud-arrow-up"></i></span>
                                        <span class="admin-popup-upload-title">@(hasPopupImage ? "Replace popup image" : "Upload popup image")</span>
                                        <span class="admin-popup-upload-hint">JPG, PNG, WEBP, GIF — max 3MB · Recommended 900×1200px</span>
                                        <span class="admin-popup-upload-name" id="popupFileName">@(hasPopupImage ? "Current image is saved" : "No file selected yet")</span>
                                    </label>

