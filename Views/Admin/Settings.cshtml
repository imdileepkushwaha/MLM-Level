@model MLM_Level.Models.AdminSettingsViewModel
@{
    ViewData["Title"] = "General Settings";
    var isOnline = Model.Settings.MaintenanceMode == "Online";
}

<!-- Page Header -->
<div class="admin-page-header admin-theme-violet mb-4" style="--admin-btn:linear-gradient(45deg,#6366f1,#4f46e5);">
    <div class="admin-page-header-glow"></div>
    <div class="row align-items-center position-relative z-1 g-3">
        <div class="col-lg-8">
            <div class="d-flex align-items-center gap-3">
                <div class="admin-page-icon"><i class="bi bi-sliders"></i></div>
                <div>
                    <h2 class="fw-bold text-white mb-0">System Settings</h2>
                    <p class="mb-0 text-white-50 small mt-1">Platform config, payouts, integrations, and admin account</p>
                </div>
            </div>
        </div>
        <div class="col-lg-4 text-lg-end">
            <span class="admin-header-badge">
                <i class="bi @(isOnline ? "bi-check-circle" : "bi-tools") me-1"></i>
                @(isOnline ? "Website Online" : "Maintenance mode")
            </span>
        </div>
    </div>
</div>

