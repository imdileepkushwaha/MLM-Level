@model List<MLM_Level.Models.Package>
@{
    ViewData["Title"] = "MLM Packages Management";
}

<div class="row g-4 mb-4">
    <!-- Page Info -->
    <div class="col-lg-7">
        <div class="glass-card p-4 h-100">
            <h4 class="text-white fw-bold mb-2">Package Administration</h4>
            <p class="text-secondary mb-0">Define, edit, and toggle active packages that members can choose during account activation. System supports multiple tiers with customized benefits.</p>
        </div>
    </div>

    <!-- Create Package Form -->
    <div class="col-lg-5">
        <div class="glass-card p-4">
            <h5 class="text-white fw-bold mb-3"><i class="bi bi-patch-plus text-cyan me-2"></i>Create New Package</h5>
            <form asp-controller="Admin" asp-action="CreatePackage" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-2 form-group">
                    <input type="text" name="name" class="form-control form-control-sm auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" placeholder="Package Name (e.g. Platinum Plan)" required />
                </div>
                <div class="mb-2 form-group row g-2">
                    <div class="col-6">
                        <input type="number" step="0.01" name="price" class="form-control form-control-sm auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" placeholder="Price (₹)" required />
                    </div>
                    <div class="col-6">
                        <input type="number" step="0.01" name="roiPercentage" class="form-control form-control-sm auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" placeholder="Daily ROI %" required />
                    </div>
                </div>
                <div class="mb-2 form-group">
                    <input type="number" name="roiDurationDays" class="form-control form-control-sm auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" placeholder="ROI Duration (Days)" required />
                </div>
                <div class="mb-2 form-group">
                    <textarea name="description" rows="2" class="form-control form-control-sm auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" placeholder="Brief Description..." required></textarea>
                </div>
                <button type="submit" class="btn btn-cyber-cyan btn-sm w-100 py-2">
                    <i class="bi bi-plus-circle me-1"></i>Publish Package
                </button>
            </form>
        </div>
    </div>
</div>

<!-- Packages List -->
<div class="row g-4">
    @if (Model.Any())
    {
        @foreach (var pkg in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="glass-card p-4 border border-opacity-10 @(pkg.IsActive ? "border-info" : "border-secondary") d-flex flex-column justify-content-between h-100 position-relative overflow-hidden">
                    <!-- Status Glow Top Corner -->
                    <div class="position-absolute top-0 end-0 px-3 py-1 text-uppercase fw-bold small rounded-bottom-start @(pkg.IsActive ? "bg-info text-dark" : "bg-secondary text-white")" style="font-size: 0.7rem;">
                        @(pkg.IsActive ? "Active" : "Inactive")
                    </div>

                    <div>
                        <span class="text-muted small">Package ID: #@pkg.Id</span>
                        <h4 class="text-white fw-bold mt-1 mb-2">@pkg.Name</h4>
                        <div class="fs-3 text-cyan fw-bold mb-2">₹@pkg.Price.ToString("N2") <span class="small text-muted text-uppercase" style="font-size: 0.8rem;">INR</span></div>
                        
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <span class="badge bg-primary bg-opacity-25 text-primary border border-primary border-opacity-25"><i class="bi bi-graph-up me-1"></i>@pkg.RoiPercentage% Daily ROI</span>
                            <span class="badge bg-warning bg-opacity-25 text-warning border border-warning border-opacity-25"><i class="bi bi-calendar3 me-1"></i>@pkg.RoiDurationDays Days</span>
                        </div>

                        <p class="text-secondary small mb-4">@pkg.Description</p>
                    </div>

                    <div class="d-flex align-items-center justify-content-between pt-3 border-top border-white border-opacity-10 mt-auto">
                        <span class="text-muted small">Created: @pkg.CreatedDate.ToString("dd MMM yyyy")</span>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-outline-info btn-sm px-2" data-bs-toggle="modal" data-bs-target="#editPackageModal-@pkg.Id">
                                <i class="bi bi-pencil-square"></i>
                            </button>
                            <form asp-controller="Admin" asp-action="TogglePackage" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@pkg.Id" />
                                @if (pkg.IsActive)
                                {
                                    <button type="submit" class="btn btn-danger btn-sm px-3">
                                        <i class="bi bi-x-circle me-1"></i>Disable
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-success btn-sm px-3">
                                        <i class="bi bi-check-circle me-1"></i>Enable
                                    </button>
                                }
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Edit Package Modal -->
            <div class="modal fade" id="editPackageModal-@pkg.Id" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content glass-card border border-secondary border-opacity-25">
                        <div class="modal-header border-bottom border-secondary border-opacity-25">
                            <h5 class="modal-title text-white"><i class="bi bi-pencil-square text-info me-2"></i>Edit Package</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <form asp-controller="Admin" asp-action="EditPackage" method="post">
                            <div class="modal-body p-4">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@pkg.Id" />
                                
                                <div class="mb-3">
                                    <label class="form-label text-secondary small mb-1">Package Name</label>
                                    <input type="text" name="name" class="form-control form-control-sm auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" value="@pkg.Name" required />
                                </div>
                                
                                <div class="row mb-3 g-3">
                                    <div class="col-6">
                                        <label class="form-label text-secondary small mb-1">Price (₹)</label>
                                        <input type="number" step="0.01" name="price" class="form-control form-control-sm auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" value="@pkg.Price" required />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label text-secondary small mb-1">Daily ROI %</label>
                                        <input type="number" step="0.01" name="roiPercentage" class="form-control form-control-sm auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" value="@pkg.RoiPercentage" required />
                                    </div>
                                </div>
                                
                                <div class="mb-3">
                                    <label class="form-label text-secondary small mb-1">ROI Duration (Days)</label>
                                    <input type="number" name="roiDurationDays" class="form-control form-control-sm auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" value="@pkg.RoiDurationDays" required />
                                </div>
                                
                                <div class="mb-3">
                                    <label class="form-label text-secondary small mb-1">Description</label>
                                    <textarea name="description" rows="2" class="form-control form-control-sm auth-glow-input bg-transparent border-secondary border-opacity-25 text-white" required>@pkg.Description</textarea>
                                </div>
                            </div>
                            <div class="modal-footer border-top border-secondary border-opacity-25 p-3">
                                <button type="button" class="btn btn-sm btn-outline-secondary px-3" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-sm btn-cyber-cyan px-4"><i class="bi bi-save me-1"></i> Save Changes</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="glass-card p-5 text-center text-secondary">
                <i class="bi bi-box fs-2 mb-2 d-block text-muted"></i>
                No membership packages exist. Seed system defaults or create one above.
            </div>
        </div>
    }
</div>
