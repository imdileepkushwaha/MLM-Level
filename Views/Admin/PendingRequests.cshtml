@model MLM_Level.Models.AdminApprovalsViewModel
@{
    ViewData["Title"] = "Pending Activations & Withdrawals Approvals";
}

<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card p-4">
            <h4 class="text-white fw-bold mb-2">Audit & Approvals Queue</h4>
            <p class="text-secondary mb-0">Approve new network activations to distribute payouts, or verify withdrawal requests to authorize cash outs.</p>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Activations Table -->
    <div class="col-lg-6">
        <div class="glass-card p-4">
            <h5 class="text-white fw-bold mb-4">
                <i class="bi bi-shield-check text-info me-2"></i>Account Activations Queue
            </h5>

            <div class="glass-table-container">
                @if (Model.ActivationRequests.Any())
                {
                    <table class="table glass-table align-middle">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Member Details</th>
                                <th>UTR/Reference</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in Model.ActivationRequests)
                            {
                                <tr>
                                    <td>@req.CreatedDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <strong class="text-white">@req.User.Username</strong><br/>
                                        <span class="small text-muted" style="font-size: 0.75rem;">@req.User.FullName</span>
                                    </td>
                                    <td><code class="text-cyan font-monospace">@req.TransactionReference</code></td>
                                    <td class="text-end">
                                        <div class="d-flex gap-2 justify-content-end">
                                            <form asp-action="ApproveActivation" asp-route-id="@req.Id" method="post">
                                                <button type="submit" class="btn btn-success btn-sm px-3" style="font-size: 0.75rem;"><i class="bi bi-check-lg me-1"></i>Approve</button>
                                            </form>
                                            <form asp-action="RejectActivation" asp-route-id="@req.Id" method="post">
                                                <button type="submit" class="btn btn-outline-danger btn-sm px-2" style="font-size: 0.75rem;"><i class="bi bi-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center py-5 text-secondary small">
                        <i class="bi bi-check-circle fs-2 mb-2 d-block text-muted"></i>
                        No pending activations are in the system queue.
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Withdrawals Table -->
    <div class="col-lg-6">
        <div class="glass-card p-4">
            <h5 class="text-white fw-bold mb-4">
                <i class="bi bi-wallet2 text-pink me-2"></i>Withdrawal Requests Queue
            </h5>

            <div class="glass-table-container">
                @if (Model.WithdrawalRequests.Any())
                {
                    <table class="table glass-table align-middle">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Member Details</th>
                                <th>Cashout Amount</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var w in Model.WithdrawalRequests)
                            {
                                <tr>
                                    <td>@w.CreatedDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <strong class="text-white">@w.User.Username</strong><br/>
                                        <span class="small text-muted" style="font-size: 0.75rem;">Wallet Bal: ₹@w.User.WalletBalance.ToString("N2")</span>
                                    </td>
                                    <td><strong class="text-warning">₹@w.Amount.ToString("N2")</strong></td>
                                    <td class="text-end">
                                        <div class="d-flex gap-2 justify-content-end">
                                            <form asp-action="ApproveWithdrawal" asp-route-id="@w.Id" method="post">
                                                <button type="submit" class="btn btn-success btn-sm px-3" style="font-size: 0.75rem;"><i class="bi bi-check-lg me-1"></i>Approve</button>
                                            </form>
                                            <form asp-action="RejectWithdrawal" asp-route-id="@w.Id" method="post">
                                                <button type="submit" class="btn btn-outline-danger btn-sm px-3" style="font-size: 0.75rem;"><i class="bi bi-arrow-counterclockwise me-1"></i>Reject</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center py-5 text-secondary small">
                        <i class="bi bi-check-circle fs-2 mb-2 d-block text-muted"></i>
                        No pending withdrawal requests in system queue.
                    </div>
                }
            </div>
        </div>
    </div>
</div>
