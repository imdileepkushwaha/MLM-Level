<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Portal - Elite MLM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>
    @{
        var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Admin";
        var initials = "";
        if (!string.IsNullOrEmpty(fullName))
        {
            var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length > 0)
            {
                initials += parts[0][0];
                if (parts.Length > 1) initials += parts[1][0];
            }
        }
        if (string.IsNullOrEmpty(initials)) initials = "A";
        var colorIndex = Math.Abs(fullName.GetHashCode()) % 6;
    }

    <!-- Panelix Admin Layout -->
    <div class="dashboard-layout">
        <!-- Sidebar -->
        <aside class="dashboard-sidebar">
            <div class="dashboard-brand d-flex justify-content-between align-items-center pe-3">
                <div class="d-flex align-items-center">
                    <div class="dashboard-brand-logo">
                        <i class="bi bi-diagram-3-fill"></i>
                    </div>
                    <a class="dashboard-brand-text" asp-controller="Home" asp-action="Index">Elite Admin</a>
                </div>
                <button class="btn btn-sm btn-light d-lg-none" type="button" onclick="document.querySelector('.dashboard-sidebar').classList.remove('sidebar-open')">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="sidebar-scrollable">
                <h5>Main</h5>
                <nav class="nav flex-column">
                    <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Index" ? "active" : "")" asp-controller="Admin" asp-action="Index">
                        <i class="bi bi-grid"></i> Dashboard
                    </a>
                </nav>

                <h5>Network</h5>
                <nav class="nav flex-column">
                    <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Members" ? "active" : "")" asp-controller="Admin" asp-action="Members">
                        <i class="bi bi-people"></i> All Members
                    </a>
                    <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Withdrawals" ? "active" : "")" asp-controller="Admin" asp-action="Withdrawals">
                        <i class="bi bi-wallet2"></i> Withdrawals
                    </a>
                    <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "PendingActivations" ? "active" : "")" asp-controller="Admin" asp-action="PendingActivations">
                        <i class="bi bi-shield-lock"></i> Activation Requests
                    </a>
                    <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "KycApprovals" ? "active" : "")" asp-controller="Admin" asp-action="KycApprovals">
                        <i class="bi bi-shield-check"></i> KYC Approvals
                    </a>
                    <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "TreeExplorer" ? "active" : "")" asp-controller="Admin" asp-action="TreeExplorer">
                        <i class="bi bi-diagram-3"></i> Network Explorer
                    </a>
                </nav>

                <h5>Financials & Notices</h5>
                <nav class="nav flex-column">
                    <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Commissions" ? "active" : "")" asp-controller="Admin" asp-action="Commissions">
                        <i class="bi bi-currency-exchange"></i> Commissions Log
                    </a>
                    <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "RoiManagement" ? "active" : "")" asp-controller="Admin" asp-action="RoiManagement">
                        <i class="bi bi-graph-up-arrow"></i> ROI Management
                    </a>
                    <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Ledger" ? "active" : "")" asp-controller="Admin" asp-action="Ledger">
                        <i class="bi bi-receipt-cutoff"></i> Audit Ledger
                    </a>
                    <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Packages" ? "active" : "")" asp-controller="Admin" asp-action="Packages">
                        <i class="bi bi-box-seam"></i> Packages
                    </a>
                    <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Announcements" ? "active" : "")" asp-controller="Admin" asp-action="Announcements">
                        <i class="bi bi-megaphone"></i> Notice Board
                    </a>
                    <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Rewards" ? "active" : "")" asp-controller="Admin" asp-action="Rewards">
                        <i class="bi bi-trophy"></i> Member Rewards
                    </a>
                </nav>

                <h5>System</h5>
                <nav class="nav flex-column">
                    <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Tickets" ? "active" : "")" asp-controller="Admin" asp-action="Tickets">
                        <i class="bi bi-chat-dots"></i> Support Tickets
                    </a>
                    <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Settings" ? "active" : "")" asp-controller="Admin" asp-action="Settings">
                        <i class="bi bi-sliders"></i> General Settings
                    </a>

                    <a class="sidebar-link text-danger" asp-controller="Account" asp-action="Logout">
                        <i class="bi bi-box-arrow-right text-danger"></i> Sign Out
                    </a>
                </nav>
            </div>
        </aside>

        <!-- Main Content Area -->
        <div class="dashboard-main-area">
            <!-- Topbar Header -->
            <header class="dashboard-topbar d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                    <!-- Mobile Hamburger -->
                    <button class="btn btn-light d-block d-lg-none me-3" type="button" onclick="document.querySelector('.dashboard-sidebar').classList.toggle('sidebar-open')">
                        <i class="bi bi-list fs-4"></i>
                    </button>

                    <div class="topbar-search-container d-none d-md-flex">
                        <i class="bi bi-search topbar-search-icon"></i>
                        <input type="text" class="topbar-search-input" placeholder="Search anything... (Ctrl+K)" />
                    </div>
                </div>

                <div class="topbar-actions">
                    @await Html.PartialAsync("_AdminNotifications")
                    <a class="topbar-icon-btn" href="#">
                        <i class="bi bi-envelope"></i>
                    </a>

                    <div class="dropdown">
                        <button class="topbar-profile dropdown-toggle" type="button" id="adminMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="avatar-circle avatar-color-@colorIndex">
                                @initials
                            </div>
                            <div class="user-profile-info">
                                <span class="user-profile-name">@fullName</span>
                                <span class="user-profile-role">Administrator</span>
                            </div>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end border shadow-sm py-2" aria-labelledby="adminMenuButton" style="border-radius: 12px; font-size: 0.9rem;">
                            <li><a class="dropdown-item py-2" asp-controller="Admin" asp-action="Settings"><i class="bi bi-sliders me-2 text-secondary"></i>Settings</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item py-2 text-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2 text-danger"></i>Sign Out</a></li>
                        </ul>
                    </div>
                </div>
            </header>

            <main role="main" class="dashboard-content">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm py-3 mb-4" role="alert" style="border-radius: 12px; background-color: rgba(16, 185, 129, 0.1); color: #047857; border: 1px solid rgba(16, 185, 129, 0.15);">
                        <i class="bi bi-check-circle-fill me-2"></i> @Html.Raw(TempData["SuccessMessage"])
                        <button type="button" class="btn-close text-success" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm py-3 mb-4" role="alert" style="border-radius: 12px; background-color: rgba(239, 68, 68, 0.1); color: #b91c1c; border: 1px solid rgba(239, 68, 68, 0.15);">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @Html.Raw(TempData["ErrorMessage"])
                        <button type="button" class="btn-close text-danger" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["InfoMessage"] != null)
                {
                    <div class="alert alert-info alert-dismissible fade show border-0 shadow-sm py-3 mb-4" role="alert" style="border-radius: 12px; background-color: rgba(59, 130, 246, 0.1); color: #1d4ed8; border: 1px solid rgba(59, 130, 246, 0.15);">
                        <i class="bi bi-info-circle-fill me-2"></i> @Html.Raw(TempData["InfoMessage"])
                        <button type="button" class="btn-close text-info" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/admin-tables.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
