@model MLM_Level.Models.LoginViewModel
@{
    ViewData["Title"] = "Admin Gateway";
}

<div class="auth-page" style="background: radial-gradient(circle at 50% 50%, #0d0e12 0%, #050608 100%);">
    <div class="glass-card auth-card shadow-lg" style="border-top: 4px solid var(--accent-gold); max-width: 440px; background: rgba(18, 20, 26, 0.75);">
        <div class="text-center mb-4">
            <div class="stat-icon-box mx-auto mb-3" style="width: 64px; height: 64px; font-size: 1.8rem; background: rgba(245, 158, 11, 0.12); color: #fbbf24; border: 1px solid rgba(245, 158, 11, 0.3);">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h2 class="text-slate-800 fw-bold">Admin Portal</h2>
            <p class="text-secondary small mt-1">Authorized Personnel Only</p>
        </div>

        <form asp-controller="Admin" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3 form-group">
                <label class="form-label text-secondary small fw-semibold">Admin Username or Email</label>
                <div class="position-relative">
                    <input asp-for="UsernameOrEmail" class="form-control rounded-3" placeholder="e.g. admin" required />
                    <span asp-validation-for="UsernameOrEmail" class="text-danger small mt-1 d-block"></span>
                </div>
            </div>

            <div class="mb-4 form-group">
                <label class="form-label text-secondary small fw-semibold">Security Password</label>
                <div class="position-relative">
                    <input asp-for="Password" type="password" class="form-control rounded-3" placeholder="••••••••" required />
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                </div>
            </div>

            <div class="mb-4 d-flex justify-content-between align-items-center">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label text-secondary small">Maintain Session</label>
                </div>
            </div>

            <button type="submit" class="btn btn-warning w-100 py-3 mb-3 fw-bold text-dark rounded-pill shadow-sm" style="background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%); border: none;">
                <i class="bi bi-unlock-fill me-1"></i>Secure Authenticate
            </button>
        </form>

        <div class="text-center mt-3 pt-3 border-top border-light">
            <a asp-controller="Home" asp-action="Index" class="text-secondary text-decoration-none small"><i class="bi bi-arrow-left me-1"></i>Back to Homepage</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
