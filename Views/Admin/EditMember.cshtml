@model MLM_Level.Models.AdminUserEditViewModel
@{
    ViewData["Title"] = "Edit Network Member details";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="glass-card p-5">
            <h3 class="text-white fw-bold mb-2">Edit Member Account</h3>
            <p class="text-secondary mb-4">Modify personal details, active membership status, and adjust wallet funds manually.</p>

            <form asp-action="EditMember" method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3 form-group">
                    <label asp-for="FullName"></label>
                    <input asp-for="FullName" class="form-control auth-glow-input" required />
                    <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="row">
                    <div class="col-sm-6 mb-3 form-group">
                        <label asp-for="Email"></label>
                        <input asp-for="Email" class="form-control auth-glow-input" required />
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                    </div>
                    <div class="col-sm-6 mb-3 form-group">
                        <label asp-for="Phone"></label>
                        <input asp-for="Phone" class="form-control auth-glow-input" />
                        <span asp-validation-for="Phone" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="mb-3 form-group">
                    <label asp-for="WalletBalance">Wallet Balance (₹)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-end-0 border-opacity-10 border-white text-secondary" style="border-radius: 10px 0 0 10px;">₹</span>
                        <input asp-for="WalletBalance" class="form-control auth-glow-input" type="number" step="0.01" min="0" required style="border-radius: 0 10px 10px 0; border-left: none;" />
                    </div>
                    <span asp-validation-for="WalletBalance" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-4 d-flex gap-4">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" style="background-color: rgba(15,23,42,0.6); border-color: var(--glass-border);" />
                        <label asp-for="IsActive" class="form-check-label text-secondary small">Active MLM Member</label>
                    </div>
                </div>

                <div class="d-flex gap-3">
                    <a asp-action="Members" class="btn btn-cyber-outline w-50 py-3">Cancel</a>
                    <button type="submit" class="btn btn-cyber-cyan w-50 py-3">
                        <i class="bi bi-save me-1"></i>Save Member
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
