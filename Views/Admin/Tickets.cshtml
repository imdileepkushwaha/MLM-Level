@model IEnumerable<MLM_Level.Models.SupportTicket>
@{
    ViewData["Title"] = "Customer Tickets Inbox";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <!-- Page Title and Stats Header -->
    <div class="row align-items-center mb-4">
        <div class="col-md-6 col-12 text-md-start text-center mb-3 mb-md-0">
            <h1 class="h2 text-slate-800 fw-bold mb-1"><i class="bi bi-chat-dots-fill text-primary me-2"></i>Helpdesk Tickets Inbox</h1>
            <p class="text-secondary small mb-0">Manage customer queries, resolve disputes, and submit responses to members.</p>
        </div>
        <div class="col-md-6 col-12 text-md-end text-center d-flex justify-content-md-end justify-content-center gap-2">
            <div class="glass-card px-3 py-2 text-center" style="min-width: 140px;">
                <div class="h4 text-warning fw-bold mb-0">@Model.Count(t => t.Status == "Pending")</div>
                <div class="small text-secondary text-uppercase" style="font-size: 0.65rem;">Pending Tickets</div>
            </div>
            <div class="glass-card px-3 py-2 text-center" style="min-width: 140px;">
                <div class="h4 text-success fw-bold mb-0">@Model.Count(t => t.Status == "Resolved")</div>
                <div class="small text-secondary text-uppercase" style="font-size: 0.65rem;">Resolved Tickets</div>
            </div>
        </div>
    </div>

    <!-- Alert Notifications -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Tickets List Table -->
    <div class="glass-card p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="text-slate-800 fw-bold mb-0"><i class="bi bi-envelope-paper text-primary me-2"></i>Inbox Logs</h5>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="display-1 text-muted mb-3"><i class="bi bi-check-circle text-success opacity-50"></i></div>
                <h5 class="text-slate-700 fw-semibold">Inbox is clear!</h5>
                <p class="text-secondary small">No customer service tickets exist in the system yet.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr class="text-secondary small border-bottom border-light">
                            <th>ID</th>
                            <th>MEMBER DETAILS</th>
                            <th>SUBJECT</th>
                            <th>SUBMITTED DATE</th>
                            <th>STATUS</th>
                            <th class="text-end">ACTION</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ticket in Model)
                        {
                            <tr class="border-bottom border-light">
                                <td class="fw-bold text-slate-800">#@ticket.Id</td>
                                <td>
                                    <div class="fw-bold text-slate-800">@ticket.User.FullName</div>
                                    <div class="small text-secondary"><i class="bi bi-person me-1"></i>@@@ticket.User.Username</div>
                                </td>
                                <td>
                                    <div class="fw-semibold text-slate-800 text-truncate" style="max-width: 250px;">@ticket.Subject</div>
                                    <div class="small text-muted text-truncate" style="max-width: 300px;">@ticket.Message</div>
                                </td>
                                <td class="small text-secondary">@ticket.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</td>
                                <td>
                                    @if (ticket.Status == "Pending")
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning px-3 py-1 rounded-pill small"><i class="bi bi-clock-history me-1"></i>Pending</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success px-3 py-1 rounded-pill small"><i class="bi bi-check-all me-1"></i>Resolved</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (ticket.Status == "Pending")
                                    {
                                        <button class="btn btn-sm btn-primary rounded-pill px-3 me-1" data-bs-toggle="modal" data-bs-target="#replyModal-@ticket.Id">
                                            <i class="bi bi-reply me-1"></i>Reply & Resolve
                                        </button>
                                    }
                                    <button class="btn btn-sm btn-light border rounded-pill px-3" data-bs-toggle="collapse" data-bs-target="#ticketDetails-@ticket.Id">
                                        <i class="bi bi-eye me-1"></i>View Thread
                                    </button>
                                </td>
                            </tr>
                            <!-- Details Thread Collapse -->
                            <tr class="collapse" id="ticketDetails-@ticket.Id">
                                <td colspan="6" class="bg-light bg-opacity-30 p-4 border-bottom border-light">
                                    <div class="row">
                                        <div class="col-md-6 mb-3 mb-md-0">
                                            <div class="p-3 bg-white rounded shadow-sm border h-100">
                                                <div class="d-flex justify-content-between mb-2">
                                                    <span class="fw-bold text-slate-800"><i class="bi bi-person text-secondary me-1"></i>Member's Original Query:</span>
                                                    <span class="small text-muted">@ticket.CreatedAt.ToString("g")</span>
                                                </div>
                                                <p class="text-secondary mb-0 text-break" style="white-space: pre-wrap;">@ticket.Message</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="p-3 bg-white rounded shadow-sm border h-100">
                                                @if (!string.IsNullOrEmpty(ticket.AdminResponse))
                                                {
                                                    <div class="d-flex justify-content-between mb-2">
                                                        <span class="fw-bold text-success"><i class="bi bi-shield-check me-1"></i>Resolved Response:</span>
                                                    </div>
                                                    <p class="text-slate-700 mb-0 text-break" style="white-space: pre-wrap;">@ticket.AdminResponse</p>
                                                }
                                                else
                                                {
                                                    <div class="text-center py-4 text-warning small">
                                                        <i class="bi bi-clock-history display-6 mb-2 d-block"></i>
                                                        No response submitted yet. Use the "Reply & Resolve" button to resolve.
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>

                            <!-- Reply Modal -->
                            @if (ticket.Status == "Pending")
                            {
                                <div class="modal fade" id="replyModal-@ticket.Id" tabindex="-1" aria-labelledby="replyModalLabel-@ticket.Id" aria-hidden="true">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                                            <div class="modal-header border-0 pb-0">
                                                <h5 class="modal-title fw-bold text-slate-800" id="replyModalLabel-@ticket.Id"><i class="bi bi-reply-fill text-primary me-2"></i>Reply to Customer</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <form asp-action="ReplyTicket" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@ticket.Id" />
                                                <div class="modal-body py-4">
                                                    <div class="mb-3 p-3 bg-light rounded-3">
                                                        <div class="fw-bold text-slate-700 small mb-1">Original Query Details:</div>
                                                        <div class="text-secondary small text-break" style="max-height: 100px; overflow-y: auto;">
                                                            <strong>Subject:</strong> @ticket.Subject <br/>
                                                            <strong>Query:</strong> @ticket.Message
                                                        </div>
                                                    </div>
                                                    <div class="mb-0">
                                                        <label class="form-label text-secondary small fw-semibold">Write Resolution / Response</label>
                                                        <textarea name="adminResponse" class="form-control rounded-3" rows="5" placeholder="Provide resolution updates or instructions. Submitting this will mark the ticket as resolved." required></textarea>
                                                    </div>
                                                </div>
                                                <div class="modal-footer border-0 pt-0 justify-content-end">
                                                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-primary rounded-pill px-4">Submit & Resolve</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
