@model IEnumerable<MLM_Level.Models.SupportTicket>
@{
    ViewData["Title"] = "Support Tickets";
    var tickets = Model.ToList();
    var pendingCount = tickets.Count(t => t.Status == "Pending");
    var resolvedCount = tickets.Count(t => t.Status == "Resolved");
    var todayUtc = DateTime.UtcNow.Date;
    var todayCount = tickets.Count(t => t.CreatedAt.Date == todayUtc);
}

<!-- Page Header -->
<div class="tickets-page-header rounded-4 mb-4">
    <div class="tickets-page-header-glow"></div>
    <div class="row align-items-center position-relative z-1 g-3">
        <div class="col-lg-8">
            <div class="d-flex align-items-center gap-3">
                <div class="tickets-page-icon">
                    <i class="bi bi-chat-dots-fill"></i>
                </div>
                <div>
                    <h2 class="fw-bold text-white mb-0">Support Tickets</h2>
                    <p class="mb-0 text-white-50 small mt-1">Manage member queries, reply, and resolve helpdesk requests</p>
                </div>
            </div>
        </div>
        <div class="col-lg-4 text-lg-end">
            @if (pendingCount > 0)
            {
                <span class="tickets-header-badge">
                    <i class="bi bi-exclamation-circle me-1"></i>@pendingCount need attention
                </span>
            }
            else
            {
                <span class="tickets-header-badge tickets-header-badge-clear">
                    <i class="bi bi-check-circle me-1"></i>All caught up
                </span>
            }
        </div>
    </div>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="glass-card tickets-stat-card h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="tickets-stat-label mb-1">Total</p>
                    <h3 class="tickets-stat-value text-primary mb-0">@tickets.Count</h3>
                </div>
                <div class="tickets-stat-icon tickets-stat-icon-blue"><i class="bi bi-inbox"></i></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="glass-card tickets-stat-card h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="tickets-stat-label mb-1">Pending</p>
                    <h3 class="tickets-stat-value text-warning mb-0">@pendingCount</h3>
                </div>
                <div class="tickets-stat-icon tickets-stat-icon-amber"><i class="bi bi-clock-history"></i></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="glass-card tickets-stat-card h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="tickets-stat-label mb-1">Resolved</p>
                    <h3 class="tickets-stat-value text-success mb-0">@resolvedCount</h3>
                </div>
                <div class="tickets-stat-icon tickets-stat-icon-green"><i class="bi bi-check-all"></i></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="glass-card tickets-stat-card h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="tickets-stat-label mb-1">Today</p>
                    <h3 class="tickets-stat-value text-info mb-0">@todayCount</h3>
                    <span class="text-muted" style="font-size:0.7rem;">new tickets</span>
                </div>
                <div class="tickets-stat-icon tickets-stat-icon-cyan"><i class="bi bi-calendar-day"></i></div>
            </div>
        </div>
    </div>
</div>

@if (tickets.Any())
{
<div data-admin-table data-page-size="10" data-search-placeholder="Search member, subject, or message..." data-count-label="tickets">
    <div class="glass-card p-3 mb-4 tickets-toolbar">
        <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between">
            <span class="text-muted small fw-semibold mb-0"><i class="bi bi-funnel me-1"></i>Filter by status</span>
            <div class="d-flex flex-wrap gap-2" role="group">
                <button type="button" class="tickets-filter-btn active" data-status="all">All (@tickets.Count)</button>
                <button type="button" class="tickets-filter-btn" data-status="pending">Pending (@pendingCount)</button>
                <button type="button" class="tickets-filter-btn" data-status="resolved">Resolved (@resolvedCount)</button>
            </div>
        </div>
        <div class="admin-table-empty-banner d-none mb-0 mt-2" data-admin-table-empty role="status">
            <span class="admin-table-empty-banner-icon" aria-hidden="true"><i class="bi bi-search"></i></span>
            <span>No tickets match your search or filter. Try another keyword or clear filters.</span>
        </div>
    </div>

    <div class="glass-card admin-table-card">
        <div class="admin-table-header flex-wrap gap-2">
            <h5 class="fw-bold text-dark mb-0">
                <i class="bi bi-envelope-paper text-primary me-2"></i>Inbox
            </h5>
            <span class="admin-record-badge" data-admin-table-count>@tickets.Count tickets</span>
            <div class="admin-search-wrap admin-table-search-wrap tickets-search-wrap" style="min-width:220px;max-width:320px;">
                <i class="bi bi-search admin-search-icon tickets-search-icon"></i>
                <input type="search" data-admin-table-search class="form-control admin-search-input tickets-search-input"
                       placeholder="Search member, subject, message..." autocomplete="off" />
            </div>
        </div>
        <div class="admin-table-scroll">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Member</th>
                        <th>Subject</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody id="ticketTableBody">
                    @foreach (var ticket in tickets)
                    {
                        var user = ticket.User;
                        var userName = user?.Username ?? "unknown";
                        var fullName = user?.FullName ?? "Unknown";
                        var initial = string.IsNullOrWhiteSpace(userName) ? "?" : userName.Trim()[0].ToString().ToUpper();
                        var statusKey = ticket.Status == "Pending" ? "pending" : "resolved";
                        var timeSpan = DateTime.UtcNow - ticket.CreatedAt;
                        string timeAgo;
                        if (timeSpan.TotalMinutes < 1) { timeAgo = "Just now"; }
                        else if (timeSpan.TotalHours < 1) { timeAgo = $"{(int)timeSpan.TotalMinutes} min ago"; }
                        else if (timeSpan.TotalDays < 1) { timeAgo = $"{(int)timeSpan.TotalHours} hr ago"; }
                        else if (timeSpan.TotalDays < 30) { timeAgo = $"{(int)timeSpan.TotalDays} days ago"; }
                        else { timeAgo = ticket.CreatedAt.ToString("dd MMM yyyy"); }
                        var searchText = $"{userName} {fullName} {ticket.Subject} {ticket.Message}".ToLowerInvariant();

                        <tr class="tickets-row" data-status="@statusKey" data-search="@searchText" data-ticket-id="@ticket.Id">
                            <td>
                                <span class="tickets-id-badge">#@ticket.Id</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="tickets-avatar">@initial</div>
                                    <div>
                                        <div class="fw-bold text-dark small">@fullName</div>
                                        <div class="text-muted tickets-subtext">@("@" + userName)</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="fw-semibold text-dark small tickets-subject">@ticket.Subject</div>
                                <div class="text-muted tickets-preview">@(ticket.Message.Length > 80 ? ticket.Message.Substring(0, 80).TrimEnd() + "..." : ticket.Message)</div>
                            </td>
                            <td>
                                <div class="fw-semibold text-dark small">@ticket.CreatedAt.ToString("dd MMM yyyy")</div>
                                <div class="text-muted tickets-subtext" title="@ticket.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")">@timeAgo</div>
                            </td>
                            <td>
                                @if (ticket.Status == "Pending")
                                {
                                    <span class="tickets-status-badge tickets-status-pending">
                                        <i class="bi bi-clock me-1"></i>Pending
                                    </span>
                                }
                                else
                                {
                                    <span class="tickets-status-badge tickets-status-resolved">
                                        <i class="bi bi-check-all me-1"></i>Resolved
                                    </span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex flex-wrap gap-2 justify-content-end">
                                    @if (ticket.Status == "Pending")
                                    {
                                        <button class="btn tickets-btn-reply" type="button" data-bs-toggle="modal" data-bs-target="#replyModal-@ticket.Id">
                                            <i class="bi bi-reply me-1"></i>Reply
                                        </button>
                                    }
                                    <button class="btn tickets-btn-view" type="button" data-bs-toggle="collapse" data-bs-target="#ticketDetails-@ticket.Id">
                                        <i class="bi bi-eye me-1"></i>View
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <tr class="collapse tickets-detail-row admin-table-detail-row" id="ticketDetails-@ticket.Id" data-detail-for="@ticket.Id">
                            <td colspan="6" class="p-0 border-0">
                                <div class="tickets-thread-panel">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <div class="tickets-thread-box">
                                                <div class="tickets-thread-label">
                                                    <i class="bi bi-person text-secondary me-1"></i>Member query
                                                    <span class="text-muted fw-normal ms-auto">@ticket.CreatedAt.ToString("g")</span>
                                                </div>
                                                <p class="mb-0 text-secondary small" style="white-space:pre-wrap;">@ticket.Message</p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="tickets-thread-box tickets-thread-box-reply">
                                                @if (!string.IsNullOrEmpty(ticket.AdminResponse))
                                                {
                                                    <div class="tickets-thread-label text-success">
                                                        <i class="bi bi-shield-check me-1"></i>Admin response
                                                    </div>
                                                    <p class="mb-0 text-dark small" style="white-space:pre-wrap;">@ticket.AdminResponse</p>
                                                }
                                                else
                                                {
                                                    <div class="text-center py-3 text-muted small">
                                                        <i class="bi bi-hourglass-split fs-4 d-block mb-2 text-warning"></i>
                                                        Awaiting your response. Use Reply to resolve this ticket.
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>

                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

    @foreach (var ticket in tickets.Where(t => t.Status == "Pending"))
    {
        <div class="modal fade" id="replyModal-@ticket.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg" style="border-radius:16px;">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold text-dark">
                            <i class="bi bi-reply-fill text-primary me-2"></i>Reply to #@ticket.Id
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-action="ReplyTicket" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@ticket.Id" />
                        <div class="modal-body p-4 pt-3">
                            <div class="tickets-modal-query mb-3">
                                <div class="fw-semibold text-dark small mb-1">@ticket.Subject</div>
                                <div class="text-muted small" style="max-height:100px;overflow-y:auto;">@ticket.Message</div>
                            </div>
                            <label class="settings-label">Your response</label>
                            <textarea name="adminResponse" class="form-control settings-input" rows="5"
                                      placeholder="Write resolution or instructions. Ticket will be marked resolved." required></textarea>
                        </div>
                        <div class="modal-footer border-0 pt-0 pb-4 px-4">
                            <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn settings-save-btn">Submit &amp; Resolve</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="glass-card text-center py-5 tickets-empty-state">
        <div class="tickets-empty-icon mx-auto mb-4">
            <i class="bi bi-check-circle"></i>
        </div>
        <h4 class="fw-bold text-dark mb-2">Inbox is clear</h4>
        <p class="text-muted mb-0 mx-auto" style="max-width:360px;">
            No support tickets yet. Member queries will appear here when submitted.
        </p>
    </div>
}

