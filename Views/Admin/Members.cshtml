@model List<MLM_Level.Models.User>
@{
    ViewData["Title"] = "Network Members";
    var members = Model ?? new List<MLM_Level.Models.User>();
    var activeCount = members.Count(u => u.IsActive);
    var inactiveCount = members.Count - activeCount;
    var totalWallet = members.Sum(u => u.WalletBalance);
}

<div class="admin-page-header admin-theme-violet mb-4">
    <div class="admin-page-header-glow"></div>
    <div class="row align-items-center position-relative z-1 g-3">
        <div class="col-lg-8">
            <div class="d-flex align-items-center gap-3">
                <div class="admin-page-icon"><i class="bi bi-people-fill"></i></div>
                <div>
                    <h2 class="fw-bold text-white mb-0">Network Members</h2>
                    <p class="mb-0 text-white-50 small mt-1">Audit registrations, status, wallets and sponsor lines</p>
                </div>
            </div>
        </div>
        <div class="col-lg-4 text-lg-end">
            <span class="admin-header-badge"><i class="bi bi-person-check me-1"></i>@activeCount active</span>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="glass-card admin-stat-card h-100">
            <p class="admin-stat-label">Total members</p>
            <p class="admin-stat-value text-primary mb-0">@members.Count</p>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="glass-card admin-stat-card h-100">
            <p class="admin-stat-label">Active</p>
            <p class="admin-stat-value text-success mb-0">@activeCount</p>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="glass-card admin-stat-card h-100">
            <p class="admin-stat-label">Inactive</p>
            <p class="admin-stat-value text-secondary mb-0">@inactiveCount</p>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="glass-card admin-stat-card h-100">
            <p class="admin-stat-label">Total wallets</p>
            <p class="admin-stat-value text-info mb-0" style="font-size:1rem;">&#8377;@totalWallet.ToString("N0")</p>
        </div>
    </div>
</div>

<div class="glass-card admin-table-card" data-admin-table data-page-size="15" data-search-placeholder="Search members..." data-count-label="members">
    <div class="admin-table-header flex-wrap">
        <h5 class="fw-bold text-dark mb-0"><i class="bi bi-people text-primary me-2"></i>All members</h5>
        <span class="admin-record-badge" data-admin-table-count>@members.Count members</span>
        <div class="admin-search-wrap admin-table-search-wrap" style="min-width:220px;max-width:280px;">
            <i class="bi bi-search admin-search-icon"></i>
            <input type="search" data-admin-table-search class="form-control admin-search-input" placeholder="Search members..." autocomplete="off" />
        </div>
    </div>
    @if (members.Any())
    {
        <div class="admin-table-scroll">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>Joined</th>
                        <th>Member</th>
                        <th>Contact</th>
                        <th>Sponsor / Parent</th>
                        <th>Status</th>
                        <th>Wallet</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in members)
                    {
                        var initial = user.Username?.Length > 0 ? user.Username[0].ToString().ToUpper() : "?";
                        var search = $"{user.Username} {user.FullName} {user.Email} {user.Phone}".ToLowerInvariant();
                        <tr class="member-row" data-search="@search">
                            <td class="admin-subtext">@user.JoinedDate.ToString("dd MMM yyyy")</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="admin-avatar">@initial</div>
                                    <div>
                                        <div class="fw-bold text-dark small">@user.Username</div>
                                        <div class="admin-subtext">@user.FullName</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="small text-dark">@user.Email</div>
                                <div class="admin-subtext">@user.Phone</div>
                            </td>
                            <td class="admin-subtext">
                                <div>Sponsor: <strong class="text-dark">@(user.Sponsor?.Username ?? "—")</strong></div>
                                <div>Parent: <strong class="text-dark">@(user.Parent?.Username ?? "—")</strong></div>
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="admin-badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="admin-badge-inactive">Inactive</span>
                                }
                            </td>
                            <td class="fw-bold text-success">&#8377;@user.WalletBalance.ToString("N2")</td>
                            <td class="text-end">
                                <a asp-action="EditMember" asp-route-id="@user.Id" class="btn admin-btn-primary btn-sm">
                                    <i class="bi bi-pencil me-1"></i>Edit
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="admin-empty-icon mb-4" style="background:rgba(139,92,246,0.1);color:#7c3aed;"><i class="bi bi-people"></i></div>
            <h5 class="fw-bold text-dark">No members found</h5>
        </div>
    }
</div>

