<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Elite MLM Level Network</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @if (ViewData["LandingPage"] as bool? == true)
    {
        <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
    }
    @if (ViewData["AuthPage"] as bool? == true)
    {
        <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    }
    @if (User.Identity != null && User.Identity.IsAuthenticated && Context.Request.RouteValues["controller"]?.ToString() == "User")
    {
        <link rel="stylesheet" href="~/css/user.css" asp-append-version="true" />
    }
</head>
<body>
    @if (User.Identity != null && User.Identity.IsAuthenticated && Context.Request.RouteValues["controller"]?.ToString() == "User")
    {
        var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "User";
        var initials = "";
        if (!string.IsNullOrEmpty(fullName))
        {
            var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length > 0)
            {
                initials += parts[0][0];
                if (parts.Length > 1) initials += parts[1][0];
            }
        }
        if (string.IsNullOrEmpty(initials)) initials = "U";
        var colorIndex = Math.Abs(fullName.GetHashCode()) % 6;

        <!-- Authenticated Dashboard Mode (Panelix Layout for User) -->
        <div class="dashboard-layout">
            <!-- Sidebar -->
            <aside class="dashboard-sidebar">
                <!-- Brand logo in sidebar -->
                <div class="dashboard-brand d-flex justify-content-between align-items-center pe-3">
                    <div class="d-flex align-items-center">
                        <div class="dashboard-brand-logo">
                            <i class="bi bi-diagram-3-fill"></i>
                        </div>
                        <a class="dashboard-brand-text" asp-controller="Home" asp-action="Index"> Elite MLM</a>
                    </div>
                    <button class="btn btn-sm btn-light d-lg-none" type="button" onclick="document.querySelector('.dashboard-sidebar').classList.remove('sidebar-open')">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="sidebar-scrollable">
                    <h5>Member Portal</h5>
                    <nav class="nav flex-column">
                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Index" ? "active" : "")" asp-controller="User" asp-action="Index">
                            <i class="bi bi-grid"></i> Dashboard
                        </a>
                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Wallet" ? "active" : "")" asp-controller="User" asp-action="Wallet">
                            <i class="bi bi-wallet2"></i> E-Wallet
                        </a>
                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "IncomeTransactions" ? "active" : "")" asp-controller="User" asp-action="IncomeTransactions">
                            <i class="bi bi-receipt-cutoff"></i> Income Transactions
                        </a>
                        
                        <a class="sidebar-link" data-bs-toggle="collapse" href="#myTeamCollapse" role="button" aria-expanded="false" aria-controls="myTeamCollapse">
                            <i class="bi bi-people"></i> My Team <i class="bi bi-chevron-down ms-auto" style="font-size: 0.75rem;"></i>
                        </a>
                        <div class="collapse @(new[]{"MyDirect","MyDownline","Tree"}.Contains(Context.Request.RouteValues["action"]?.ToString()) ? "show" : "")" id="myTeamCollapse">
                            <nav class="nav flex-column ms-3 mt-1 mb-2" style="border-left: 2px solid rgba(255,255,255,0.1); padding-left: 0.5rem;">
                                <a class="sidebar-link py-1 @(Context.Request.RouteValues["action"]?.ToString() == "MyDirect" ? "active" : "")" asp-controller="User" asp-action="MyDirect" style="font-size: 0.9rem;">
                                    <i class="bi bi-person-check" style="font-size: 1rem;"></i> My Direct
                                </a>
                                <a class="sidebar-link py-1 @(Context.Request.RouteValues["action"]?.ToString() == "MyDownline" ? "active" : "")" asp-controller="User" asp-action="MyDownline" style="font-size: 0.9rem;">
                                    <i class="bi bi-diagram-3" style="font-size: 1rem;"></i> My Downline
                                </a>
                                <a class="sidebar-link py-1 @(Context.Request.RouteValues["action"]?.ToString() == "Tree" ? "active" : "")" asp-controller="User" asp-action="Tree" style="font-size: 0.9rem;">
                                    <i class="bi bi-tree" style="font-size: 1rem;"></i> Tree View
                                </a>
                            </nav>
                        </div>

                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Packages" ? "active" : "")" asp-controller="User" asp-action="Packages">
                            <i class="bi bi-box-seam"></i> Packages
                        </a>

                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Kyc" ? "active" : "")" asp-controller="User" asp-action="Kyc">
                            <i class="bi bi-shield-check"></i> KYC Verification
                        </a>

                        <a class="sidebar-link" data-bs-toggle="collapse" href="#myIncomeCollapse" role="button" aria-expanded="false" aria-controls="myIncomeCollapse">
                            <i class="bi bi-cash-stack"></i> My Income <i class="bi bi-chevron-down ms-auto" style="font-size: 0.75rem;"></i>
                        </a>
                        <div class="collapse @(new[]{"DailyIncome","DirectIncome","LevelIncome","Rewards"}.Contains(Context.Request.RouteValues["action"]?.ToString()) ? "show" : "")" id="myIncomeCollapse">
                            <nav class="nav flex-column ms-3 mt-1 mb-2" style="border-left: 2px solid rgba(255,255,255,0.1); padding-left: 0.5rem;">
                                <a class="sidebar-link py-1 @(Context.Request.RouteValues["action"]?.ToString() == "DailyIncome" ? "active" : "")" asp-controller="User" asp-action="DailyIncome" style="font-size: 0.9rem;">
                                    <i class="bi bi-calendar-check" style="font-size: 1rem;"></i> Daily Income
                                </a>
                                <a class="sidebar-link py-1 @(Context.Request.RouteValues["action"]?.ToString() == "DirectIncome" ? "active" : "")" asp-controller="User" asp-action="DirectIncome" style="font-size: 0.9rem;">
                                    <i class="bi bi-arrow-right-circle" style="font-size: 1rem;"></i> Direct Income
                                </a>
                                <a class="sidebar-link py-1 @(Context.Request.RouteValues["action"]?.ToString() == "LevelIncome" ? "active" : "")" asp-controller="User" asp-action="LevelIncome" style="font-size: 0.9rem;">
                                    <i class="bi bi-layers" style="font-size: 1rem;"></i> Level Income
                                </a>
                                <a class="sidebar-link py-1 @(Context.Request.RouteValues["action"]?.ToString() == "Rewards" ? "active" : "")" asp-controller="User" asp-action="Rewards" style="font-size: 0.9rem;">
                                    <i class="bi bi-trophy" style="font-size: 1rem;"></i> Rewards
                                </a>
                            </nav>
                        </div>

                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "ActivationReport" ? "active" : "")" asp-controller="User" asp-action="ActivationReport">
                            <i class="bi bi-shield-check"></i> Activation Report
                        </a>

                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Profile" ? "active" : "")" asp-controller="User" asp-action="Profile">
                            <i class="bi bi-person-gear"></i> Manage Profile
                        </a>
                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Support" ? "active" : "")" asp-controller="User" asp-action="Support">
                            <i class="bi bi-headset"></i> Support Helpdesk
                        </a>
                        
                        <a class="sidebar-link text-danger" asp-controller="Account" asp-action="Logout">
                            <i class="bi bi-box-arrow-right text-danger"></i> Sign Out
                        </a>
                    </nav>
                </div>
            </aside>

            <!-- Main Content Area -->
            <div class="dashboard-main-area">
                <!-- Topbar Header -->
                <header class="dashboard-topbar d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center">
                        <!-- Mobile Hamburger -->
                        <button class="btn btn-light d-block d-lg-none me-3" type="button" onclick="document.querySelector('.dashboard-sidebar').classList.toggle('sidebar-open')">
                            <i class="bi bi-list fs-4"></i>
                        </button>

                        <!-- Search Box -->
                        <div class="topbar-search-container d-none d-md-flex">
                            <i class="bi bi-search topbar-search-icon"></i>
                            <input type="text" class="topbar-search-input" placeholder="Search anything... (Ctrl+K)" />
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="topbar-actions">
                        @await Html.PartialAsync("_MemberNotifications")
                        <a class="topbar-icon-btn" asp-controller="User" asp-action="Support" title="Support">
                            <i class="bi bi-headset"></i>
                        </a>

                        <div class="dropdown">
                            <button class="topbar-profile dropdown-toggle" type="button" id="userMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="avatar-circle avatar-color-@colorIndex">
                                    @initials
                                </div>
                                <div class="user-profile-info">
                                    <span class="user-profile-name">@fullName</span>
                                    <span class="user-profile-role">Member</span>
                                </div>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end border shadow-sm py-2" aria-labelledby="userMenuButton" style="border-radius: 12px; font-size: 0.9rem;">
                                <li><a class="dropdown-item py-2" asp-controller="User" asp-action="Profile"><i class="bi bi-person me-2 text-secondary"></i>Profile</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2 text-danger"></i>Sign Out</a></li>
                            </ul>
                        </div>
                    </div>
                </header>

                <main role="main" class="dashboard-content">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm py-3 mb-4" role="alert" style="border-radius: 12px; background-color: rgba(16, 185, 129, 0.1); color: #047857; border: 1px solid rgba(16, 185, 129, 0.15);">
                            <i class="bi bi-check-circle-fill me-2"></i> @Html.Raw(TempData["SuccessMessage"])
                            <button type="button" class="btn-close text-success" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm py-3 mb-4" role="alert" style="border-radius: 12px; background-color: rgba(239, 68, 68, 0.1); color: #b91c1c; border: 1px solid rgba(239, 68, 68, 0.15);">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @Html.Raw(TempData["ErrorMessage"])
                            <button type="button" class="btn-close text-danger" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["InfoMessage"] != null)
                    {
                        <div class="alert alert-info alert-dismissible fade show border-0 shadow-sm py-3 mb-4" role="alert" style="border-radius: 12px; background-color: rgba(59, 130, 246, 0.1); color: #1d4ed8; border: 1px solid rgba(59, 130, 246, 0.15);">
                            <i class="bi bi-info-circle-fill me-2"></i> @Html.Raw(TempData["InfoMessage"])
                            <button type="button" class="btn-close text-info" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        var isLanding = ViewData["LandingPage"] as bool? == true;
        var isFullWidth = ViewData["FullWidth"] as bool? == true;
        var isAuthPage = ViewData["AuthPage"] as bool? == true;
        @if (!isAuthPage)
        {
        <!-- Public Landing Page / Access Mode -->
        <header class="main-nav @(isLanding ? "landing-nav" : "")">
            <nav class="navbar navbar-expand-lg @(isLanding ? "navbar-dark" : "") py-3">
                <div class="container">
                    <a class="navbar-brand nav-brand d-flex align-items-center gap-2 @(isLanding ? "landing-brand" : "")" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-diagram-3-fill @(isLanding ? "text-warning" : "text-info")"></i>
                        <span>ELITE MLM</span>
                    </a>
                    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarNav">
                        <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-3">
                            @if (isLanding)
                            {
                                <li class="nav-item">
                                    <a class="nav-link landing-nav-link" href="#how-it-works">How It Works</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link landing-nav-link" href="#commission-plan">Income Plan</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link landing-nav-link" href="#features">Features</a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-secondary" asp-controller="Home" asp-action="Index">Home</a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="btn @(isLanding ? "btn-landing-outline" : "btn-cyber-outline") btn-sm px-4" asp-controller="Account" asp-action="Login">Sign In</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn @(isLanding ? "btn-landing-gold" : "btn-cyber-cyan") btn-sm px-4" asp-controller="Account" asp-action="Register">Join Now</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <main role="main" class="@(isFullWidth ? "" : "py-5")">
            @if (!isAuthPage && (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null))
            {
                <div class="container @(isFullWidth ? "pt-4" : "")">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm py-3 mb-4" role="alert" style="border-radius: 12px; background-color: rgba(16, 185, 129, 0.1); color: #047857;">
                            <i class="bi bi-check-circle-fill me-2"></i> @Html.Raw(TempData["SuccessMessage"])
                            <button type="button" class="btn-close text-success" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm py-3 mb-4" role="alert" style="border-radius: 12px; background-color: rgba(239, 68, 68, 0.1); color: #b91c1c;">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @Html.Raw(TempData["ErrorMessage"])
                            <button type="button" class="btn-close text-danger" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                </div>
            }
            @if (isFullWidth)
            {
                @RenderBody()
            }
            else
            {
                <div class="container">
                    @RenderBody()
                </div>
            }
        </main>
        }
        else
        {
            @RenderBody()
        }
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true && Context.Request.RouteValues["controller"]?.ToString() == "User")
    {
        <script src="~/js/admin-tables.js" asp-append-version="true"></script>
    }
    @await RenderSectionAsync("Scripts", required: false)

    @if (ViewBag.MaintenanceMode == true)
    {
        @await Html.PartialAsync("_MaintenanceOverlay")
    }
</body>
</html>
