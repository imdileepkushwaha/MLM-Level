<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Elite MLM Level Network</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="main-nav">
        <nav class="navbar navbar-expand-lg navbar-dark py-3">
            <div class="container">
                <a class="navbar-brand nav-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-diagram-3-fill text-info"></i>
                    <span>ELITE MLM</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center gap-3">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-secondary">
                                    <i class="bi bi-person-circle me-1 text-info"></i> Welcome, <strong>@User.FindFirst("FullName")?.Value</strong>
                                </span>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="btn btn-cyber-cyan btn-sm px-3" asp-controller="Admin" asp-action="Index">Admin Portal</a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="btn btn-cyber-cyan btn-sm px-3" asp-controller="User" asp-action="Index">User Portal</a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="btn btn-cyber-outline btn-sm px-3 border-danger text-danger" asp-controller="Account" asp-action="Logout">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-secondary" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-cyber-outline btn-sm px-4" asp-controller="Account" asp-action="Login">Sign In</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-cyber-cyan btn-sm px-4" asp-controller="Account" asp-action="Register">Join Now</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @if (User.Identity != null && User.Identity.IsAuthenticated && (Context.Request.RouteValues["controller"]?.ToString() == "User" || Context.Request.RouteValues["controller"]?.ToString() == "Admin"))
    {
        <!-- Authenticated Dashboard Mode -->
        <div class="dashboard-wrapper">
            <aside class="dashboard-sidebar">
                @if (User.IsInRole("Admin"))
                {
                    <h5 class="text-secondary px-3 mb-3 small text-uppercase fw-bold tracking-wider">Admin Panel</h5>
                    <nav class="nav flex-column">
                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Index" ? "active" : "")" asp-controller="Admin" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Members" || Context.Request.RouteValues["action"]?.ToString() == "EditMember" ? "active" : "")" asp-controller="Admin" asp-action="Members">
                            <i class="bi bi-people"></i> Manage Members
                        </a>
                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "PendingRequests" ? "active" : "")" asp-controller="Admin" asp-action="PendingRequests">
                            <i class="bi bi-patch-check"></i> Pending Approvals
                        </a>
                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "TreeExplorer" ? "active" : "")" asp-controller="Admin" asp-action="TreeExplorer">
                            <i class="bi bi-diagram-3"></i> Network Explorer
                        </a>
                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Commissions" ? "active" : "")" asp-controller="Admin" asp-action="Commissions">
                            <i class="bi bi-receipt"></i> System Commissions
                        </a>
                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Tickets" ? "active" : "")" asp-controller="Admin" asp-action="Tickets">
                            <i class="bi bi-chat-dots"></i> Support Tickets
                        </a>
                    </nav>
                }
                else
                {
                    <h5 class="text-secondary px-3 mb-3 small text-uppercase fw-bold tracking-wider">Member Portal</h5>
                    <nav class="nav flex-column">
                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Index" ? "active" : "")" asp-controller="User" asp-action="Index">
                            <i class="bi bi-grid-1x2"></i> Dashboard
                        </a>
                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Activate" ? "active" : "")" asp-controller="User" asp-action="Activate">
                            <i class="bi bi-shield-check"></i> Package Activation
                        </a>
                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Tree" ? "active" : "")" asp-controller="User" asp-action="Tree">
                            <i class="bi bi-diagram-2"></i> My Downline Tree
                        </a>
                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Wallet" ? "active" : "")" asp-controller="User" asp-action="Wallet">
                            <i class="bi bi-wallet2"></i> E-Wallet Ledger
                        </a>
                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Profile" ? "active" : "")" asp-controller="User" asp-action="Profile">
                            <i class="bi bi-person-gear"></i> Manage Profile
                        </a>
                        <a class="sidebar-link @(Context.Request.RouteValues["action"]?.ToString() == "Support" ? "active" : "")" asp-controller="User" asp-action="Support">
                            <i class="bi bi-headset"></i> Helpdesk / Support
                        </a>
                    </nav>
                }
            </aside>
            <main role="main" class="dashboard-content">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show glass-card border-success text-dark py-3 mb-4" role="alert">
                        <i class="bi bi-check-circle-fill me-2 text-success"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show glass-card border-danger text-dark py-3 mb-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2 text-danger"></i> @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["InfoMessage"] != null)
                {
                    <div class="alert alert-info alert-dismissible fade show glass-card border-info text-dark py-3 mb-4" role="alert">
                        <i class="bi bi-info-circle-fill me-2 text-info"></i> @TempData["InfoMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <!-- Public Landing Page / Access Mode -->
        <main role="main" class="py-4">
            <div class="container">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show glass-card border-success text-dark py-3 mb-4" role="alert">
                        <i class="bi bi-check-circle-fill me-2 text-success"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show glass-card border-danger text-dark py-3 mb-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2 text-danger"></i> @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
            </div>
            @RenderBody()
        </main>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
