@model MLM_Level.Models.AdminRejectModalViewModel
<div class="modal fade" id="@Model.ModalId" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius:16px;">
            <form asp-controller="Admin" asp-action="@Model.FormAction" asp-route-id="@Model.RequestId" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <h5 class="fw-bold text-danger mb-2">@Model.Title</h5>
                    @if (!string.IsNullOrWhiteSpace(Model.Subtitle))
                    {
                        <p class="text-muted small mb-3">@Model.Subtitle</p>
                    }
                    <label class="settings-label">Rejection reason <span class="text-danger">*</span></label>
                    <textarea name="rejectionReason" class="form-control settings-input" rows="3"
                              placeholder="Explain why this request was rejected so the member can fix and resubmit." required maxlength="500"></textarea>
                    <p class="text-muted small mt-2 mb-0">The member will see this reason in their portal and receive an email alert.</p>
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4">Confirm reject</button>
                </div>
            </form>
        </div>
    </div>
</div>
