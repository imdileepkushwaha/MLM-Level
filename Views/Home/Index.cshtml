@model MLM_Level.Models.LandingViewModel
@{
    ViewData["Title"] = "Elite Level Plan Network";
    var s = Model.Settings;
    var siteName = string.IsNullOrWhiteSpace(s.SiteName) ? "Elite MLM" : s.SiteName;
    var price = Model.StarterPackagePrice;
    decimal Commission(decimal pct) => Math.Round(price * pct / 100m, 0);
    var totalPct = s.Level1Commission + s.Level2Commission + s.Level3Commission + s.Level4Commission + s.Level5Commission;
    var totalEarn = Commission(totalPct);
    var levels = new[]
    {
        new { Level = 1, Label = "Direct Sponsor", Pct = s.Level1Commission, Icon = "bi-person-check-fill", Accent = "cyan" },
        new { Level = 2, Label = "Level 2 Upline", Pct = s.Level2Commission, Icon = "bi-people-fill", Accent = "blue" },
        new { Level = 3, Label = "Level 3 Upline", Pct = s.Level3Commission, Icon = "bi-diagram-2-fill", Accent = "green" },
        new { Level = 4, Label = "Level 4 Upline", Pct = s.Level4Commission, Icon = "bi-share-fill", Accent = "gold" },
        new { Level = 5, Label = "Level 5 Upline", Pct = s.Level5Commission, Icon = "bi-stars", Accent = "pink" }
    };
}

<div class="landing-page">
    <!-- Hero -->
    <section class="landing-hero">
        <div class="landing-hero-bg"></div>
        <div class="landing-hero-orb landing-hero-orb-1"></div>
        <div class="landing-hero-orb landing-hero-orb-2"></div>
        <div class="landing-hero-grid"></div>
        <div class="container position-relative">
            <div class="row align-items-center g-5 py-5">
                <div class="col-lg-6 landing-reveal">
                    <span class="landing-badge">
                        <span class="landing-badge-dot"></span>
                        India's Trusted Level-Income Platform
                    </span>
                    <h1 class="landing-hero-title">
                        Build Your Network.<br />
                        <span class="landing-hero-highlight">Unlock 5-Level Income.</span>
                    </h1>
                    <p class="landing-hero-lead">
                        Join <strong>@siteName</strong> — instant commission on every activation, verified KYC payouts,
                        ROI membership plans, and a powerful member dashboard to grow your team.
                    </p>
                    <div class="landing-hero-earn">
                        <div class="landing-hero-earn-icon"><i class="bi bi-cash-coin"></i></div>
                        <div>
                            <span class="landing-hero-earn-label">Earn up to</span>
                            <strong>₹@totalEarn.ToString("N0")</strong>
                            <span class="landing-hero-earn-sub">per ₹@price.ToString("N0") activation (@totalPct.ToString("0.##")% total)</span>
                        </div>
                    </div>
                    <div class="landing-hero-actions">
                        <a asp-controller="Account" asp-action="Register" class="btn btn-landing-gold btn-lg">
                            <i class="bi bi-person-plus-fill me-2"></i>Start Free Registration
                        </a>
                        <a asp-controller="Account" asp-action="Login" class="btn btn-landing-outline btn-lg">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Member Login
                        </a>
                    </div>
                    <div class="landing-hero-social">
                        <div class="landing-hero-avatars">
                            <span>A</span><span>R</span><span>P</span><span>K</span><span>+</span>
                        </div>
                        <p>Join thousands of members building their network every day</p>
                    </div>
                </div>
                <div class="col-lg-6 landing-reveal landing-reveal-delay">
                    <div class="landing-hero-visual">
                        <div class="landing-dashboard-mock">
                            <div class="landing-mock-header">
                                <span class="landing-mock-dot"></span>
                                <span class="landing-mock-dot"></span>
                                <span class="landing-mock-dot"></span>
                                <span class="landing-mock-title">@siteName Dashboard</span>
                            </div>
                            <div class="landing-mock-body">
                                <div class="landing-mock-row">
                                    <div class="landing-mock-stat landing-mock-stat-income">
                                        <span class="landing-mock-stat-label">Income Wallet</span>
                                        <strong>₹12,450</strong>
                                        <small>+₹@Commission(s.Level1Commission) today</small>
                                    </div>
                                    <div class="landing-mock-stat landing-mock-stat-team">
                                        <span class="landing-mock-stat-label">Active Team</span>
                                        <strong>48</strong>
                                        <small>5 levels</small>
                                    </div>
                                </div>
                                <div class="landing-mock-chart">
                                    <div class="landing-mock-bar" style="--h:65%"><span>L1</span></div>
                                    <div class="landing-mock-bar" style="--h:45%"><span>L2</span></div>
                                    <div class="landing-mock-bar" style="--h:35%"><span>L3</span></div>
                                    <div class="landing-mock-bar" style="--h:25%"><span>L4</span></div>
                                    <div class="landing-mock-bar" style="--h:18%"><span>L5</span></div>
                                </div>
                                <div class="landing-mock-tree">
                                    <div class="landing-tree-node landing-tree-root"><i class="bi bi-person-fill"></i></div>
                                    <div class="landing-tree-connector"></div>
                                    <div class="landing-tree-row">
                                        <div class="landing-tree-node"><i class="bi bi-person-fill"></i></div>
                                        <div class="landing-tree-node"><i class="bi bi-person-fill"></i></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="landing-hero-float landing-hero-float-1">
                            <i class="bi bi-lightning-charge-fill"></i>
                            <span>Instant Credit</span>
                        </div>
                        <div class="landing-hero-float landing-hero-float-2">
                            <i class="bi bi-shield-check"></i>
                            <span>KYC Payouts</span>
                        </div>
                        <div class="landing-hero-float landing-hero-float-3">
                            <i class="bi bi-graph-up"></i>
                            <span>ROI Plans</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats -->
    <section class="landing-stats">
        <div class="container">
            <div class="row g-3 g-md-4">
                <div class="col-6 col-lg-3 landing-reveal">
                    <div class="landing-stat-card">
                        <div class="landing-stat-icon"><i class="bi bi-layers-fill"></i></div>
                        <strong>5 Levels</strong>
                        <span>Deep commission plan</span>
                    </div>
                </div>
                <div class="col-6 col-lg-3 landing-reveal">
                    <div class="landing-stat-card">
                        <div class="landing-stat-icon landing-stat-icon-gold"><i class="bi bi-currency-rupee"></i></div>
                        <strong>₹@price.ToString("N0")+</strong>
                        <span>Starter activation</span>
                    </div>
                </div>
                <div class="col-6 col-lg-3 landing-reveal">
                    <div class="landing-stat-card">
                        <div class="landing-stat-icon landing-stat-icon-green"><i class="bi bi-graph-up-arrow"></i></div>
                        <strong>@totalPct.ToString("0.##")%</strong>
                        <span>Total level payout</span>
                    </div>
                </div>
                <div class="col-6 col-lg-3 landing-reveal">
                    <div class="landing-stat-card">
                        <div class="landing-stat-icon landing-stat-icon-blue"><i class="bi bi-headset"></i></div>
                        <strong>24/7</strong>
                        <span>Support & tickets</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Trust strip -->
    <section class="landing-trust">
        <div class="container">
            <div class="landing-trust-inner">
                <div class="landing-trust-item"><i class="bi bi-shield-lock-fill"></i> Secure Platform</div>
                <div class="landing-trust-item"><i class="bi bi-patch-check-fill"></i> KYC Verified</div>
                <div class="landing-trust-item"><i class="bi bi-lightning-fill"></i> Instant Commission</div>
                <div class="landing-trust-item"><i class="bi bi-bank2"></i> Bank Payouts</div>
                <div class="landing-trust-item"><i class="bi bi-phone-fill"></i> Mobile Ready</div>
            </div>
        </div>
    </section>

    <!-- How it works -->
    <section class="landing-section" id="how-it-works">
        <div class="container">
            <div class="landing-section-head text-center landing-reveal">
                <span class="landing-section-tag">Simple Process</span>
                <h2 class="landing-section-title">How @siteName Works</h2>
                <p class="landing-section-sub">Four easy steps to start building your network and earning level income.</p>
            </div>
            <div class="landing-steps-track landing-reveal">
                @{
                    var steps = new[]
                    {
                        new { Num = "01", Title = "Register Free", Desc = "Create your account with sponsor ID.", Icon = "bi-person-plus" },
                        new { Num = "02", Title = "Activate Package", Desc = "Choose a plan & submit payment proof.", Icon = "bi-box-seam" },
                        new { Num = "03", Title = "Build Your Team", Desc = "Refer members across 5 levels.", Icon = "bi-diagram-3" },
                        new { Num = "04", Title = "Withdraw Earnings", Desc = "KYC verify & payout to bank.", Icon = "bi-bank" }
                    };
                }
                <div class="row g-4">
                    @foreach (var step in steps)
                    {
                        <div class="col-md-6 col-lg-3">
                            <div class="landing-step-card">
                                <span class="landing-step-num">@step.Num</span>
                                <div class="landing-step-icon"><i class="bi @step.Icon"></i></div>
                                <h3>@step.Title</h3>
                                <p>@step.Desc</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Commission plan -->
    <section class="landing-section landing-section-dark" id="commission-plan">
        <div class="container">
            <div class="landing-section-head text-center landing-reveal">
                <span class="landing-section-tag landing-section-tag-light">Income Plan</span>
                <h2 class="landing-section-title text-white">5-Level Commission Structure</h2>
                <p class="landing-section-sub landing-section-sub-light">
                    Every <strong>₹@price.ToString("N0")</strong> activation distributes <strong>₹@totalEarn.ToString("N0")</strong> across your upline network.
                </p>
            </div>

            <div class="landing-plan-summary landing-reveal">
                <span class="landing-plan-summary-label">Total per activation</span>
                <strong>@totalPct.ToString("0.##")%</strong>
                <span class="landing-plan-summary-divider">·</span>
                <strong class="landing-plan-summary-amt">₹@totalEarn.ToString("N0")</strong>
                <span class="landing-plan-summary-note">distributed across 5 upline levels</span>
            </div>

            <div class="row g-3 g-lg-4 justify-content-center landing-reveal">
                @foreach (var lv in levels)
                {
                    <div class="col-sm-6 col-lg-4 col-xl">
                        <div class="landing-level-card landing-level-@lv.Accent">
                            <div class="landing-level-top">
                                <span class="landing-level-badge">Level @lv.Level</span>
                                <i class="bi @lv.Icon"></i>
                            </div>
                            <h4>@lv.Label</h4>
                            <div class="landing-level-pct">@lv.Pct.ToString("0.##")%</div>
                            <div class="landing-level-amt">₹@Commission(lv.Pct).ToString("N0") <small>per activation</small></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Packages -->
    @if (Model.ActivePackages.Any())
    {
        <section class="landing-section" id="packages">
            <div class="container">
                <div class="landing-section-head text-center landing-reveal">
                    <span class="landing-section-tag">Membership Plans</span>
                    <h2 class="landing-section-title">Choose Your Package</h2>
                    <p class="landing-section-sub">Activate a plan to unlock network earnings and ROI benefits.</p>
                </div>
                <div class="row g-4 justify-content-center">
                    @{ var pkgIndex = 0; }
                    @foreach (var pkg in Model.ActivePackages)
                    {
                        var featured = pkgIndex == 1;
                        <div class="col-md-4 landing-reveal">
                            <div class="landing-package-card @(featured ? "is-featured" : "")">
                                @if (featured)
                                {
                                    <span class="landing-package-popular"><i class="bi bi-star-fill me-1"></i>Most Popular</span>
                                }
                                <div class="landing-package-icon"><i class="bi bi-gem"></i></div>
                                <h3>@pkg.Name</h3>
                                <div class="landing-package-price"><span>₹</span>@pkg.Price.ToString("N0")</div>
                                <p>@pkg.Description</p>
                                @if (pkg.RoiPercentage > 0 && pkg.RoiDurationDays > 0)
                                {
                                    <div class="landing-package-roi">
                                        <i class="bi bi-graph-up me-1"></i>@pkg.RoiPercentage% ROI · @pkg.RoiDurationDays days
                                    </div>
                                }
                                <ul class="landing-package-list">
                                    <li><i class="bi bi-check-circle-fill"></i>5-level commission</li>
                                    <li><i class="bi bi-check-circle-fill"></i>Team tree placement</li>
                                    <li><i class="bi bi-check-circle-fill"></i>Full dashboard access</li>
                                </ul>
                                <a asp-controller="Account" asp-action="Register" class="btn @(featured ? "btn-landing-gold" : "btn-landing-outline-dark") w-100">
                                    Get Started <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                        pkgIndex++;
                    }
                </div>
            </div>
        </section>
    }

    <!-- Features -->
    <section class="landing-section landing-section-alt" id="features">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-5 landing-reveal">
                    <span class="landing-section-tag">Platform Features</span>
                    <h2 class="landing-section-title mb-3">Built for Network Leaders</h2>
                    <p class="landing-section-sub text-start mb-4">
                        Everything you need — team management, transparent earnings, and secure payouts — in one professional platform.
                    </p>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-landing-outline-dark">
                        Explore Member Portal <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
                <div class="col-lg-7">
                    <div class="row g-3">
                        @{
                            var features = new[]
                            {
                                new { Icon = "bi-diagram-3-fill", Title = "Genealogy Tree", Desc = "Visual downline with direct & level-wise views." },
                                new { Icon = "bi-wallet2", Title = "Dual Wallet", Desc = "Income Wallet + main wallet for withdrawals." },
                                new { Icon = "bi-shield-check", Title = "KYC Verification", Desc = "Identity & bank verification before payout." },
                                new { Icon = "bi-receipt-cutoff", Title = "Income Ledger", Desc = "Level-wise commission history & reports." },
                                new { Icon = "bi-gift-fill", Title = "Member Rewards", Desc = "Bonuses and exclusive announcements." },
                                new { Icon = "bi-headset", Title = "Support Tickets", Desc = "Track queries with dedicated support." }
                            };
                        }
                        @foreach (var f in features)
                        {
                            <div class="col-sm-6 landing-reveal">
                                <div class="landing-feature-card">
                                    <div class="landing-feature-icon"><i class="bi @f.Icon"></i></div>
                                    <div>
                                        <h5>@f.Title</h5>
                                        <p>@f.Desc</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonials -->
    <section class="landing-section landing-testimonials">
        <div class="container">
            <div class="landing-section-head text-center landing-reveal">
                <span class="landing-section-tag">Success Stories</span>
                <h2 class="landing-section-title">What Members Say</h2>
            </div>
            <div class="row g-4">
                @{
                    var testimonials = new[]
                    {
                        new { Name = "Rajesh K.", Role = "Team Leader", Quote = "Level income credit is instant. My team grew 3x in two months with the transparent dashboard.", Initials = "RK", Color = "indigo" },
                        new { Name = "Priya S.", Role = "Gold Member", Quote = "KYC was smooth and my first withdrawal reached my bank within days. Very professional platform.", Initials = "PS", Color = "gold" },
                        new { Name = "Amit M.", Role = "Direct Sponsor", Quote = "The 5-level plan is clear — I can see exactly how much I earn from each activation in my ledger.", Initials = "AM", Color = "green" }
                    };
                }
                @foreach (var t in testimonials)
                {
                    <div class="col-md-4 landing-reveal">
                        <div class="landing-testimonial-card">
                            <div class="landing-testimonial-stars">
                                @for (var i = 0; i < 5; i++) { <i class="bi bi-star-fill"></i> }
                            </div>
                            <p>"@t.Quote"</p>
                            <div class="landing-testimonial-author">
                                <span class="landing-testimonial-avatar landing-avatar-@t.Color">@t.Initials</span>
                                <div>
                                    <strong>@t.Name</strong>
                                    <small>@t.Role</small>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="landing-section landing-section-alt" id="faq">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-4 landing-reveal">
                    <span class="landing-section-tag">FAQ</span>
                    <h2 class="landing-section-title">Common Questions</h2>
                    <p class="landing-section-sub text-start">Quick answers about joining, earning, and withdrawals.</p>
                </div>
                <div class="col-lg-8 landing-reveal">
                    <div class="accordion landing-faq" id="landingFaq">
                        @{
                            var faqs = new[]
                            {
                                new { Q = "How do I start earning?", A = "Register free, activate a membership package, and refer members. You earn commission when your team activates packages — up to 5 levels deep." },
                                new { Q = "When is commission credited?", A = "Commission is credited instantly to your Income Wallet when admin approves a member's package activation." },
                                new { Q = "How do withdrawals work?", A = "Complete KYC verification with your bank details. Once approved, request withdrawal from your E-Wallet. Admin processes payouts to your verified bank account." },
                                new { Q = "What is the minimum withdrawal?", A = $"Minimum withdrawal is ₹{s.MinWithdrawalLimit:N0}. Standard fees and charges apply as configured in platform settings." }
                            };
                            var faqIdx = 0;
                        }
                        @foreach (var faq in faqs)
                        {
                            faqIdx++;
                            <div class="accordion-item landing-faq-item">
                                <h3 class="accordion-header">
                                    <button class="accordion-button @(faqIdx > 1 ? "collapsed" : "")" type="button" data-bs-toggle="collapse" data-bs-target="#faq-@faqIdx">
                                        @faq.Q
                                    </button>
                                </h3>
                                <div id="faq-@faqIdx" class="accordion-collapse collapse @(faqIdx == 1 ? "show" : "")" data-bs-parent="#landingFaq">
                                    <div class="accordion-body">@faq.A</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="landing-cta">
        <div class="container landing-reveal">
            <div class="landing-cta-inner">
                <div class="landing-cta-glow"></div>
                <div class="landing-cta-content">
                    <h2>Ready to Build Your Network?</h2>
                    <p>Join @siteName today — free registration, professional tools, and a proven 5-level income plan.</p>
                </div>
                <div class="landing-cta-actions">
                    <a asp-controller="Account" asp-action="Register" class="btn btn-landing-gold btn-lg">
                        <i class="bi bi-rocket-takeoff me-2"></i>Join Now — It's Free
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-landing-outline btn-lg">Sign In</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="landing-footer">
        <div class="container">
            <div class="row g-4 mb-4">
                <div class="col-lg-4">
                    <div class="landing-footer-brand">
                        <i class="bi bi-diagram-3-fill"></i>
                        <span>@siteName.ToUpper()</span>
                    </div>
                    <p class="landing-footer-copy">Professional multi-level marketing platform. Earn smart, grow together, withdraw securely.</p>
                </div>
                <div class="col-6 col-lg-2">
                    <h6 class="landing-footer-heading">Platform</h6>
                    <a href="#how-it-works" class="landing-footer-link d-block mb-2">How It Works</a>
                    <a href="#commission-plan" class="landing-footer-link d-block mb-2">Income Plan</a>
                    <a href="#packages" class="landing-footer-link d-block mb-2">Packages</a>
                    <a href="#faq" class="landing-footer-link d-block">FAQ</a>
                </div>
                <div class="col-6 col-lg-2">
                    <h6 class="landing-footer-heading">Account</h6>
                    <a asp-controller="Account" asp-action="Register" class="landing-footer-link d-block mb-2">Register</a>
                    <a asp-controller="Account" asp-action="Login" class="landing-footer-link d-block mb-2">Login</a>
                    <a asp-controller="Home" asp-action="Privacy" class="landing-footer-link d-block">Privacy</a>
                </div>
                <div class="col-lg-4">
                    <h6 class="landing-footer-heading">Support</h6>
                    <p class="landing-footer-copy mb-2">
                        <i class="bi bi-envelope me-2"></i>@(string.IsNullOrWhiteSpace(s.SupportEmail) ? "support@mlm.com" : s.SupportEmail)
                    </p>
                    <p class="landing-footer-copy mb-0"><i class="bi bi-clock me-2"></i>24/7 ticket support available</p>
                </div>
            </div>
            <div class="landing-footer-bottom">
                <span>&copy; @DateTime.UtcNow.Year @siteName. All rights reserved.</span>
            </div>
        </div>
    </footer>
</div>

@if (s.HomePopupEnabled && !string.IsNullOrWhiteSpace(s.HomePopupImageUrl))
{
    <div id="homePromoPopup" class="landing-popup" aria-hidden="true">
        <div class="landing-popup-backdrop" data-home-popup-close></div>
        <div class="landing-popup-dialog" role="dialog" aria-modal="true" aria-label="Announcement">
            <div class="landing-popup-header">
                <div class="landing-popup-title">
                    <div class="landing-popup-icon"><i class="bi bi-bell-fill"></i></div>
                    Important Update
                </div>
                <button type="button" class="landing-popup-close" data-home-popup-close aria-label="Close popup">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="landing-popup-body">
                <img src="@s.HomePopupImageUrl" alt="Announcement" class="landing-popup-image" />
            </div>
            <div class="landing-popup-footer">
                <button type="button" class="btn btn-landing-gold w-100" data-home-popup-close>Continue to Website <i class="bi bi-arrow-right ms-2"></i></button>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
(function () {
    var popup = document.getElementById('homePromoPopup');
    if (popup) {
        var popupVersion = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(s.HomePopupImageUrl));
        var storageKey = 'mlm-home-popup-dismissed';
        var showPopup = function () {
            popup.classList.add('is-visible');
            popup.setAttribute('aria-hidden', 'false');
            document.body.classList.add('landing-popup-open');
        };
        var hidePopup = function () {
            popup.classList.remove('is-visible');
            popup.setAttribute('aria-hidden', 'true');
            document.body.classList.remove('landing-popup-open');
            try { sessionStorage.setItem(storageKey, popupVersion); } catch (e) { }
        };
        var dismissed = '';
        try { dismissed = sessionStorage.getItem(storageKey) || ''; } catch (e) { }
        if (dismissed !== popupVersion) {
            window.setTimeout(showPopup, 350);
        }
        popup.querySelectorAll('[data-home-popup-close]').forEach(function (el) {
            el.addEventListener('click', hidePopup);
        });
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && popup.classList.contains('is-visible')) hidePopup();
        });
    }
})();
</script>
<script>
(function () {
    var nav = document.querySelector('.landing-nav');
    if (nav) {
        window.addEventListener('scroll', function () {
            nav.classList.toggle('is-scrolled', window.scrollY > 40);
        }, { passive: true });
    }

    document.querySelectorAll('a[href^="#"]').forEach(function (a) {
        a.addEventListener('click', function (e) {
            var id = a.getAttribute('href');
            if (!id || id === '#') return;
            var el = document.querySelector(id);
            if (!el) return;
            e.preventDefault();
            el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
    });

    if ('IntersectionObserver' in window) {
        var obs = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    obs.unobserve(entry.target);
                }
            });
        }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('.landing-reveal').forEach(function (el) { obs.observe(el); });
    } else {
        document.querySelectorAll('.landing-reveal').forEach(function (el) { el.classList.add('is-visible'); });
    }
})();
</script>
}
