@{
    ViewData["Title"] = "Elite Level Plan Network";
}

<div class="container py-5">
    <!-- Hero Section -->
    <div class="row align-items-center justify-content-between py-5 my-3">
        <div class="col-lg-6 mb-4 mb-lg-0 text-center text-lg-start">
            <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-3 py-2 mb-3 rounded-pill fw-bold">
                <i class="bi bi-rocket-takeoff-fill me-1"></i> The Future of Networking is Here
            </span>
            <h1 class="display-3 fw-extrabold text-dark mb-3" style="line-height: 1.1;">
                Supercharge Your Network <br/>
                <span class="bg-gradient text-transparent" style="background: linear-gradient(135deg, #06b6d4 0%, #ec4899 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">With Stored Procedure Payouts</span>
            </h1>
            <p class="lead text-secondary mb-4 fs-5">
                Join our premium Multi-Level Marketing platform powered by a robust 5-Level Commission structure and blazing-fast MS SQL Server workflows. Start earning today.
            </p>
            <div class="d-flex flex-wrap justify-content-center justify-content-lg-start gap-3">
                <a asp-controller="Account" asp-action="Register" class="btn btn-cyber-cyan btn-lg px-4 fs-6">
                    <i class="bi bi-diagram-3-fill me-2"></i>Join Network
                </a>
                <a asp-controller="Account" asp-action="Login" class="btn btn-cyber-outline btn-lg px-4 fs-6">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Member Login
                </a>
            </div>
        </div>
        <div class="col-lg-5 d-none d-lg-block">
            <!-- Stunning Abstract Glowing Graphic -->
            <div class="glass-container p-5 text-center position-relative overflow-hidden" style="min-height: 380px; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-soft);">
                <div class="position-absolute rounded-circle" style="width: 150px; height: 150px; background: radial-gradient(circle, var(--accent-cyan) 0%, transparent 70%); opacity: 0.15; filter: blur(20px);"></div>
                <div class="z-3">
                    <i class="bi bi-diagram-3" style="font-size: 7rem; background: linear-gradient(135deg, #4f46e5 0%, #0891b2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>
                    <h3 class="text-dark mt-4 fw-bold">5-Level Matrix</h3>
                    <p class="text-secondary small px-3">Unbounded relative level progression with automated commission rolling.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Payout Scheme Cards -->
    <div class="py-5">
        <h2 class="text-center text-dark mb-2 fw-bold">Network Commission Structure</h2>
        <p class="text-center text-secondary mb-5">Activate your package for just <strong class="text-dark">₹1,000</strong> and earn up to 5 levels deep from your team referrals.</p>

        <div class="row g-4 justify-content-center">
            <!-- Level 1 -->
            <div class="col-md-4 col-sm-6">
                <div class="glass-card p-4 text-center border-top border-info border-3">
                    <div class="stat-icon-box icon-box-cyan mx-auto mb-3">1</div>
                    <h4 class="text-dark fw-bold mb-2">Direct Sponsor</h4>
                    <p class="text-secondary mb-3">Level 1 Referral Payout</p>
                    <div class="h2 text-cyan fw-extrabold" style="color: var(--accent-cyan);">10% <span class="fs-6 text-secondary">(₹100)</span></div>
                </div>
            </div>

            <!-- Level 2 -->
            <div class="col-md-4 col-sm-6">
                <div class="glass-card p-4 text-center border-top border-primary border-3">
                    <div class="stat-icon-box icon-box-blue mx-auto mb-3">2</div>
                    <h4 class="text-dark fw-bold mb-2">Level 2 Payout</h4>
                    <p class="text-secondary mb-3">Indirect Referral Upline</p>
                    <div class="h2 text-primary fw-extrabold" style="color: var(--accent-blue);">5% <span class="fs-6 text-secondary">(₹50)</span></div>
                </div>
            </div>

            <!-- Level 3 -->
            <div class="col-md-4 col-sm-6">
                <div class="glass-card p-4 text-center border-top border-success border-3">
                    <div class="stat-icon-box icon-box-green mx-auto mb-3">3</div>
                    <h4 class="text-dark fw-bold mb-2">Level 3 Payout</h4>
                    <p class="text-secondary mb-3">Indirect Referral Upline</p>
                    <div class="h2 text-success fw-extrabold" style="color: var(--accent-green);">3% <span class="fs-6 text-secondary">(₹30)</span></div>
                </div>
            </div>

            <!-- Level 4 -->
            <div class="col-md-4 col-sm-6">
                <div class="glass-card p-4 text-center border-top border-warning border-3">
                    <div class="stat-icon-box icon-box-pink mx-auto mb-3">4</div>
                    <h4 class="text-dark fw-bold mb-2">Level 4 Payout</h4>
                    <p class="text-secondary mb-3">Indirect Referral Upline</p>
                    <div class="h2 text-pink fw-extrabold" style="color: var(--accent-pink);">2% <span class="fs-6 text-secondary">(₹20)</span></div>
                </div>
            </div>

            <!-- Level 5 -->
            <div class="col-md-4 col-sm-6">
                <div class="glass-card p-4 text-center border-top border-danger border-3">
                    <div class="stat-icon-box icon-box-pink mx-auto mb-3" style="background: rgba(220, 38, 38, 0.08); color: var(--accent-red); border-color: rgba(220, 38, 38, 0.2);">5</div>
                    <h4 class="text-dark fw-bold mb-2">Level 5 Payout</h4>
                    <p class="text-secondary mb-3">Indirect Referral Upline</p>
                    <div class="h2 text-danger fw-extrabold" style="color: var(--accent-red);">1% <span class="fs-6 text-secondary">(₹10)</span></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Platform Highlights -->
    <div class="row align-items-center py-5 g-5">
        <div class="col-md-6">
            <h2 class="text-dark fw-bold mb-4">Why Partner With Us?</h2>
            
            <div class="d-flex align-items-start gap-3 mb-4">
                <div class="stat-icon-box icon-box-cyan flex-shrink-0"><i class="bi bi-shield-fill-check"></i></div>
                <div>
                    <h5 class="text-dark fw-bold mb-1">MS SQL Server Security</h5>
                    <p class="text-secondary">All critical network computations and placements run on secure transaction scopes inside database engine procedures.</p>
                </div>
            </div>

            <div class="d-flex align-items-start gap-3 mb-4">
                <div class="stat-icon-box icon-box-blue flex-shrink-0"><i class="bi bi-lightning-charge-fill"></i></div>
                <div>
                    <h5 class="text-dark fw-bold mb-1">Real-time Level Compression</h5>
                    <p class="text-secondary">Commissions are instantly paid and computed in micro-seconds, ensuring no delay in your network rewards distribution.</p>
                </div>
            </div>

            <div class="d-flex align-items-start gap-3">
                <div class="stat-icon-box icon-box-green flex-shrink-0"><i class="bi bi-cash-stack"></i></div>
                <div>
                    <h5 class="text-dark fw-bold mb-1">Direct Withdrawal Approvals</h5>
                    <p class="text-secondary">Request payouts at any time to your active account. Admin processes withdraws transparently.</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="glass-card p-5 border border-opacity-10 border-dark">
                <h3 class="text-dark fw-bold mb-3 text-center">Plan At A Glance</h3>
                <table class="table table-borderless text-secondary align-middle mt-4">
                    <tbody>
                        <tr>
                            <td><i class="bi bi-check-circle-fill text-info me-2"></i> Package Cost:</td>
                            <td class="text-dark fw-bold text-end">₹1,000 INR</td>
                        </tr>
                        <tr>
                            <td><i class="bi bi-check-circle-fill text-info me-2"></i> Payout Depth:</td>
                            <td class="text-dark fw-bold text-end">5 Levels</td>
                        </tr>
                        <tr>
                            <td><i class="bi bi-check-circle-fill text-info me-2"></i> Transaction Speed:</td>
                            <td class="text-dark fw-bold text-end">Instant SP execution</td>
                        </tr>
                        <tr>
                            <td><i class="bi bi-check-circle-fill text-info me-2"></i> Admin Support:</td>
                            <td class="text-dark fw-bold text-end">24/7 Ticketing</td>
                        </tr>
                    </tbody>
                </table>
                <div class="text-center mt-5">
                    <a asp-controller="Account" asp-action="Register" class="btn btn-cyber-pink w-100 py-3">Create Free Account</a>
                </div>
            </div>
        </div>
    </div>
</div>
