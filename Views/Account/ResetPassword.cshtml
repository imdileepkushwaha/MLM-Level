@model MLM_Level.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="auth-page">
    <div class="glass-card auth-card shadow-lg">
        <div class="text-center mb-4">
            <div class="stat-icon-box icon-box-cyan mx-auto mb-3" style="width: 60px; height: 60px; font-size: 1.6rem;">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h2 class="text-white fw-bold">Reset Password</h2>
            <p class="text-secondary small mt-1">Choose a new password for your account</p>
        </div>

        <form asp-controller="Account" asp-action="ResetPassword" method="post">
            <input type="hidden" asp-for="Token" />
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3 form-group">
                <label asp-for="NewPassword"></label>
                <div class="position-relative">
                    <input asp-for="NewPassword" class="form-control auth-glow-input w-100 pe-5" placeholder="Min 6 characters" />
                    <button type="button" class="btn position-absolute top-50 end-0 translate-middle-y me-2 border-0 bg-transparent text-secondary py-0 px-2" onclick="togglePasswordVisibility(this)" style="z-index: 10;">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="mb-4 form-group">
                <label asp-for="ConfirmPassword"></label>
                <div class="position-relative">
                    <input asp-for="ConfirmPassword" class="form-control auth-glow-input w-100 pe-5" placeholder="Re-enter password" />
                    <button type="button" class="btn position-absolute top-50 end-0 translate-middle-y me-2 border-0 bg-transparent text-secondary py-0 px-2" onclick="togglePasswordVisibility(this)" style="z-index: 10;">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
            </div>

            <button type="submit" class="btn btn-cyber-cyan w-100 py-3 mb-3">
                <i class="bi bi-check2-circle me-1"></i>Update Password
            </button>
        </form>

        <div class="text-center mt-3 pt-3 border-top border-opacity-10 border-white">
            <p class="text-secondary small mb-0">
                <a asp-controller="Account" asp-action="Login" class="text-info text-decoration-none fw-bold">
                    <i class="bi bi-arrow-left-short"></i> Back to sign in
                </a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
