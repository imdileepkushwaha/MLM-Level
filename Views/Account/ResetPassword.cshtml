@model MLM_Level.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    ViewData["AuthPage"] = true;
}

<div class="auth-shell">
    <aside class="auth-shell-brand">
        <div class="auth-shell-brand-inner">
            <a asp-controller="Home" asp-action="Index" class="auth-shell-logo">
                <i class="bi bi-diagram-3-fill"></i>
                <span>ELITE MLM</span>
            </a>
            <h1 class="auth-shell-title">Create a new password</h1>
            <p class="auth-shell-lead">Choose a strong password to keep your account and earnings secure.</p>
            <ul class="auth-shell-perks">
                <li><i class="bi bi-check-circle-fill"></i> Minimum 6 characters</li>
                <li><i class="bi bi-check-circle-fill"></i> One-time secure link</li>
                <li><i class="bi bi-check-circle-fill"></i> Instant access after reset</li>
            </ul>
        </div>
    </aside>

    <div class="auth-shell-panel">
        <a asp-controller="Account" asp-action="Login" class="auth-shell-back">
            <span class="auth-shell-back-icon" aria-hidden="true"><i class="bi bi-arrow-left"></i></span>
            Back to sign in
        </a>

        <div class="auth-card">
            <div class="auth-card-head">
                <div class="auth-card-icon auth-card-icon-reset">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>
                <h2>Reset Password</h2>
                <p>Set a new password for your member account</p>
            </div>

            <form asp-controller="Account" asp-action="ResetPassword" method="post" class="auth-form">
                <input type="hidden" asp-for="Token" />
                <div asp-validation-summary="ModelOnly" class="auth-validation-summary"></div>

                <div class="auth-field">
                    <label asp-for="NewPassword">New Password</label>
                    <div class="auth-input-wrap">
                        <i class="bi bi-lock auth-input-icon"></i>
                        <input asp-for="NewPassword" class="auth-input auth-input-password" placeholder="Min 6 characters" autocomplete="new-password" />
                        <button type="button" class="auth-password-toggle" onclick="togglePasswordVisibility(this)" aria-label="Show password">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="NewPassword" class="auth-field-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="ConfirmPassword">Confirm Password</label>
                    <div class="auth-input-wrap">
                        <i class="bi bi-lock-fill auth-input-icon"></i>
                        <input asp-for="ConfirmPassword" class="auth-input auth-input-password" placeholder="Re-enter password" autocomplete="new-password" />
                        <button type="button" class="auth-password-toggle" onclick="togglePasswordVisibility(this)" aria-label="Show password">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="auth-field-error"></span>
                </div>

                <button type="submit" class="btn btn-auth-primary w-100">
                    <i class="bi bi-check2-circle me-2"></i>Update Password
                </button>
            </form>

            <div class="auth-card-foot">
                <a asp-controller="Account" asp-action="Login" class="auth-link auth-link-bold">
                    <i class="bi bi-arrow-left"></i> Return to sign in
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
