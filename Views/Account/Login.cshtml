@model MLM_Level.Models.LoginViewModel
@{
    ViewData["Title"] = "Member Login";
    ViewData["AuthPage"] = true;
    var maintenanceMode = ViewBag.MaintenanceMode == true;
}

<div class="auth-shell@(maintenanceMode ? " auth-shell-maintenance" : "")">
    <aside class="auth-shell-brand">
        <div class="auth-shell-brand-inner">
            <a asp-controller="Home" asp-action="Index" class="auth-shell-logo">
                <i class="bi bi-diagram-3-fill"></i>
                <span>ELITE MLM</span>
            </a>
            <h1 class="auth-shell-title">Welcome back</h1>
            <p class="auth-shell-lead">Sign in to manage your team, track level income, and request withdrawals from your E-Wallet.</p>
            <ul class="auth-shell-perks">
                <li><i class="bi bi-check-circle-fill"></i> Real-time commission ledger</li>
                <li><i class="bi bi-check-circle-fill"></i> Genealogy tree & downline view</li>
                <li><i class="bi bi-check-circle-fill"></i> Secure KYC verified payouts</li>
            </ul>
        </div>
    </aside>

    <div class="auth-shell-panel">
        <a asp-controller="Home" asp-action="Index" class="auth-shell-back">
            <span class="auth-shell-back-icon" aria-hidden="true"><i class="bi bi-arrow-left"></i></span>
            Back to home
        </a>

        <div class="auth-card@(maintenanceMode ? " auth-card-disabled" : "")">
            <div class="auth-card-head">
                <div class="auth-card-icon auth-card-icon-login">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>
                <h2>Member Sign In</h2>
                <p>Enter your credentials to access the portal</p>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="auth-alert auth-alert-success">
                    <i class="bi bi-check-circle-fill"></i>@TempData["SuccessMessage"]
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="auth-alert auth-alert-danger">
                    <i class="bi bi-exclamation-triangle-fill"></i>@TempData["ErrorMessage"]
                </div>
            }

            <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="auth-validation-summary"></div>

                <div class="auth-field">
                    <label asp-for="UsernameOrEmail">Username or Email</label>
                    <div class="auth-input-wrap">
                        <i class="bi bi-person auth-input-icon"></i>
                        <input asp-for="UsernameOrEmail" class="auth-input" placeholder="Enter username or email" autocomplete="username" />
                    </div>
                    <span asp-validation-for="UsernameOrEmail" class="auth-field-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Password">Password</label>
                    <div class="auth-input-wrap">
                        <i class="bi bi-lock auth-input-icon"></i>
                        <input asp-for="Password" class="auth-input auth-input-password" placeholder="Enter password" autocomplete="current-password" />
                        <button type="button" class="auth-password-toggle" onclick="togglePasswordVisibility(this)" aria-label="Show password">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="auth-field-error"></span>
                </div>

                <div class="auth-row">
                    <div class="form-check auth-check">
                        <input asp-for="RememberMe" class="form-check-input" id="rememberMe" />
                        <label asp-for="RememberMe" class="form-check-label" for="rememberMe">Remember me</label>
                    </div>
                    <a asp-controller="Account" asp-action="ForgotPassword" class="auth-link">Forgot password?</a>
                </div>

                <button type="submit" class="btn btn-auth-primary w-100">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>
            </form>

            <div class="auth-card-foot">
                <span>New member?</span>
                <a asp-controller="Account" asp-action="Register" class="auth-link auth-link-bold">Create free account <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
