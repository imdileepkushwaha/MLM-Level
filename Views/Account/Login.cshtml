@model MLM_Level.Models.LoginViewModel
@{
    ViewData["Title"] = "Member Login";
}

<div class="auth-page">
    <div class="glass-card auth-card shadow-lg">
        <div class="text-center mb-4">
            <div class="stat-icon-box icon-box-cyan mx-auto mb-3" style="width: 60px; height: 60px; font-size: 1.6rem;">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h2 class="text-white fw-bold">Sign In</h2>
            <p class="text-secondary small mt-1">Access the Elite MLM Portal</p>
        </div>

        <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3 form-group">
                <label asp-for="UsernameOrEmail"></label>
                <div class="position-relative">
                    <input asp-for="UsernameOrEmail" class="form-control auth-glow-input w-100" placeholder="Enter username or email" />
                    <span asp-validation-for="UsernameOrEmail" class="text-danger small mt-1 d-block"></span>
                </div>
            </div>

            <div class="mb-4 form-group">
                <label asp-for="Password"></label>
                <div class="position-relative">
                    <input asp-for="Password" class="form-control auth-glow-input w-100" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                </div>
            </div>

            <div class="mb-4 d-flex justify-content-between align-items-center">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" style="background-color: rgba(15,23,42,0.6); border-color: var(--glass-border);" />
                    <label asp-for="RememberMe" class="form-check-label text-secondary small">Remember Me</label>
                </div>
            </div>

            <button type="submit" class="btn btn-cyber-cyan w-100 py-3 mb-3">
                <i class="bi bi-box-arrow-in-right me-1"></i>Authenticate
            </button>
        </form>

        <div class="text-center mt-3 pt-3 border-top border-opacity-10 border-white">
            <p class="text-secondary small">Not registered yet? <a asp-controller="Account" asp-action="Register" class="text-info text-decoration-none fw-bold">Create an account <i class="bi bi-arrow-right-short"></i></a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
