@model MLM_Level.Models.RegisterViewModel
@{
    ViewData["Title"] = "Create Free Account";
    ViewData["AuthPage"] = true;
}

<div class="auth-shell">
    <aside class="auth-shell-brand">
        <div class="auth-shell-brand-inner">
            <a asp-controller="Home" asp-action="Index" class="auth-shell-logo">
                <i class="bi bi-diagram-3-fill"></i>
                <span>ELITE MLM</span>
            </a>
            <h1 class="auth-shell-title">Start your network journey</h1>
            <p class="auth-shell-lead">Register free, activate a package, and earn level income up to 5 generations deep.</p>
            <ul class="auth-shell-perks">
                <li><i class="bi bi-check-circle-fill"></i> Free member registration</li>
                <li><i class="bi bi-check-circle-fill"></i> 5-level commission plan</li>
                <li><i class="bi bi-check-circle-fill"></i> ROI membership packages</li>
            </ul>
        </div>
    </aside>

    <div class="auth-shell-panel auth-shell-panel-wide">
        <a asp-controller="Home" asp-action="Index" class="auth-shell-back">
            <span class="auth-shell-back-icon" aria-hidden="true"><i class="bi bi-arrow-left"></i></span>
            Back to home
        </a>

        <div class="auth-card auth-card-wide">
            <div class="auth-card-head">
                <div class="auth-card-icon auth-card-icon-register">
                    <i class="bi bi-person-plus-fill"></i>
                </div>
                <h2>Create Account</h2>
                <p>Your Member ID (e.g. ML000003) is assigned automatically after signup</p>
            </div>

            <form asp-controller="Account" asp-action="Register" method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="auth-validation-summary"></div>

                <div class="row g-3">
                    <div class="col-12">
                        <div class="auth-field">
                            <label asp-for="FullName">Full Name</label>
                            <div class="auth-input-wrap">
                                <i class="bi bi-person-badge auth-input-icon"></i>
                                <input asp-for="FullName" class="auth-input" placeholder="Your full name" />
                            </div>
                            <span asp-validation-for="FullName" class="auth-field-error"></span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="auth-field">
                            <label asp-for="Email">Email</label>
                            <div class="auth-input-wrap">
                                <i class="bi bi-envelope auth-input-icon"></i>
                                <input asp-for="Email" class="auth-input" placeholder="name@example.com" autocomplete="email" />
                            </div>
                            <span asp-validation-for="Email" class="auth-field-error"></span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="auth-field">
                            <label asp-for="Phone">Phone</label>
                            <div class="auth-input-wrap">
                                <i class="bi bi-phone auth-input-icon"></i>
                                <input asp-for="Phone" class="auth-input" placeholder="10-digit mobile" autocomplete="tel" />
                            </div>
                            <span asp-validation-for="Phone" class="auth-field-error"></span>
                        </div>
                    </div>
                </div>

                <div class="auth-field auth-field-highlight">
                    <div class="row g-3 auth-sponsor-row">
                        <div class="col-sm-6">
                            <label asp-for="SponsorCode">Sponsor / Referral Code</label>
                            <div class="auth-input-wrap">
                                <i class="bi bi-link-45deg auth-input-icon"></i>
                                <input asp-for="SponsorCode" class="auth-input" id="SponsorCode" placeholder="e.g. ML000001" autocomplete="off" />
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <label for="sponsorNameDisplay">Sponsor Name</label>
                            <div class="auth-input-wrap">
                                <i class="bi bi-person-check auth-input-icon"></i>
                                <input type="text" id="sponsorNameDisplay" class="auth-input auth-input-readonly" readonly
                                       value="@(ViewBag.SponsorDisplayName as string ?? string.Empty)"
                                       placeholder="Auto-filled from code" tabindex="-1" aria-readonly="true" />
                            </div>
                        </div>
                    </div>
                    <span class="auth-field-hint">Use sponsor Member ID (e.g. ML000001) or leave empty for default placement.</span>
                    <span id="sponsorLookupStatus" class="auth-field-hint" aria-live="polite"></span>
                    <span asp-validation-for="SponsorCode" class="auth-field-error"></span>
                </div>

                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="auth-field">
                            <label asp-for="Password">Password</label>
                            <div class="auth-input-wrap">
                                <i class="bi bi-lock auth-input-icon"></i>
                                <input asp-for="Password" class="auth-input auth-input-password" placeholder="Min 6 characters" autocomplete="new-password" />
                                <button type="button" class="auth-password-toggle" onclick="togglePasswordVisibility(this)" aria-label="Show password">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="auth-field-error"></span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="auth-field">
                            <label asp-for="ConfirmPassword">Confirm Password</label>
                            <div class="auth-input-wrap">
                                <i class="bi bi-lock-fill auth-input-icon"></i>
                                <input asp-for="ConfirmPassword" class="auth-input auth-input-password" placeholder="Repeat password" autocomplete="new-password" />
                                <button type="button" class="auth-password-toggle" onclick="togglePasswordVisibility(this)" aria-label="Show password">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="auth-field-error"></span>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-auth-primary btn-auth-gold w-100">
                    <i class="bi bi-rocket-takeoff me-2"></i>Create Free Account
                </button>
            </form>

            <div class="auth-card-foot">
                <span>Already registered?</span>
                <a asp-controller="Account" asp-action="Login" class="auth-link auth-link-bold">Sign in here <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const codeInput = document.getElementById('SponsorCode');
            const nameInput = document.getElementById('sponsorNameDisplay');
            const statusEl = document.getElementById('sponsorLookupStatus');
            let lookupTimer = null;

            function clearSponsorPreview() {
                setSponsorName('');
                statusEl.textContent = '';
                statusEl.className = 'auth-field-hint';
            }

            function setSponsorName(name) {
                nameInput.value = name || '';
            }

            function getSponsorPayload(data) {
                return {
                    found: data.found === true || data.Found === true,
                    fullName: data.fullName || data.FullName || '',
                    memberId: data.memberId || data.MemberId || '',
                    message: data.message || data.Message || 'Sponsor code not found.'
                };
            }

            async function lookupSponsor(code) {
                const trimmed = (code || '').trim();
                if (!trimmed) {
                    clearSponsorPreview();
                    return;
                }

                statusEl.textContent = 'Verifying sponsor…';
                statusEl.className = 'auth-field-hint';

                try {
                    const response = await fetch('/Account/LookupSponsor?code=' + encodeURIComponent(trimmed));
                    if (!response.ok) {
                        throw new Error('lookup_failed');
                    }
                    const data = getSponsorPayload(await response.json());

                    if (data.found) {
                        setSponsorName(data.fullName);
                        statusEl.textContent = 'Verified: ' + (data.memberId || trimmed);
                        statusEl.className = 'auth-field-hint text-success';
                    } else {
                        setSponsorName('');
                        statusEl.textContent = data.message;
                        statusEl.className = 'auth-field-hint text-danger';
                    }
                } catch {
                    setSponsorName('');
                    statusEl.textContent = 'Could not verify sponsor. Refresh the page and try again.';
                    statusEl.className = 'auth-field-hint text-danger';
                }
            }

            function scheduleLookup() {
                clearTimeout(lookupTimer);
                lookupTimer = setTimeout(function () {
                    lookupSponsor(codeInput.value);
                }, 400);
            }

            codeInput.addEventListener('input', scheduleLookup);
            codeInput.addEventListener('change', scheduleLookup);
            codeInput.addEventListener('blur', function () {
                lookupSponsor(codeInput.value);
            });

            if (codeInput.value.trim()) {
                lookupSponsor(codeInput.value);
            }
        })();
    </script>
}
