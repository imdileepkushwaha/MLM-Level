@{
    ViewData["Title"] = "Access Denied";
}

<div class="container py-5">
    <div class="row justify-content-center py-5">
        <div class="col-md-7 text-center">
            <div class="glass-card p-5 border border-danger border-opacity-25" style="box-shadow: 0 0 30px rgba(239, 68, 68, 0.15);">
                <div class="stat-icon-box mx-auto mb-4" style="width: 72px; height: 72px; font-size: 2.2rem; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #f87171;">
                    <i class="bi bi-shield-slash-fill"></i>
                </div>
                <h1 class="text-white fw-bold display-5 mb-3">Access Denied</h1>
                <p class="text-secondary fs-5 mb-4">
                    You do not have the required permissions to view this resource.
                </p>
                <div class="d-flex justify-content-center gap-3">
                    <a href="javascript:history.back()" class="btn btn-cyber-outline">Go Back</a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-cyber-cyan">Return Home</a>
                </div>
            </div>
        </div>
    </div>
</div>
