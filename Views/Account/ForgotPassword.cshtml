@model MLM_Level.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-page">
    <div class="glass-card auth-card shadow-lg">
        <div class="text-center mb-4">
            <div class="stat-icon-box icon-box-cyan mx-auto mb-3" style="width: 60px; height: 60px; font-size: 1.6rem;">
                <i class="bi bi-key-fill"></i>
            </div>
            <h2 class="text-white fw-bold">Forgot Password</h2>
            <p class="text-secondary small mt-1">Enter your username or email to receive a reset link</p>
        </div>

        <form asp-controller="Account" asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-4 form-group">
                <label asp-for="UsernameOrEmail"></label>
                <input asp-for="UsernameOrEmail" class="form-control auth-glow-input w-100" placeholder="Enter username or email" />
                <span asp-validation-for="UsernameOrEmail" class="text-danger small mt-1 d-block"></span>
            </div>

            <button type="submit" class="btn btn-cyber-cyan w-100 py-3 mb-3">
                <i class="bi bi-envelope me-1"></i>Send Reset Link
            </button>
        </form>

        <div class="text-center mt-3 pt-3 border-top border-opacity-10 border-white">
            <p class="text-secondary small mb-0">
                <a asp-controller="Account" asp-action="Login" class="text-info text-decoration-none fw-bold">
                    <i class="bi bi-arrow-left-short"></i> Back to sign in
                </a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
