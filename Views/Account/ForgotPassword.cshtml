@model MLM_Level.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    ViewData["AuthPage"] = true;
}

<div class="auth-shell">
    <aside class="auth-shell-brand">
        <div class="auth-shell-brand-inner">
            <a asp-controller="Home" asp-action="Index" class="auth-shell-logo">
                <i class="bi bi-diagram-3-fill"></i>
                <span>ELITE MLM</span>
            </a>
            <h1 class="auth-shell-title">Reset your password</h1>
            <p class="auth-shell-lead">No worries — enter your username or email and we'll send you a secure link to create a new password.</p>
            <ul class="auth-shell-perks">
                <li><i class="bi bi-check-circle-fill"></i> Link expires in 1 hour</li>
                <li><i class="bi bi-check-circle-fill"></i> Sent to your registered email</li>
                <li><i class="bi bi-check-circle-fill"></i> Secure one-time reset token</li>
            </ul>
        </div>
    </aside>

    <div class="auth-shell-panel">
        <a asp-controller="Account" asp-action="Login" class="auth-shell-back">
            <span class="auth-shell-back-icon" aria-hidden="true"><i class="bi bi-arrow-left"></i></span>
            Back to sign in
        </a>

        <div class="auth-card">
            <div class="auth-card-head">
                <div class="auth-card-icon auth-card-icon-forgot">
                    <i class="bi bi-key-fill"></i>
                </div>
                <h2>Forgot Password</h2>
                <p>Enter your account details to receive a reset link</p>
            </div>

            <div class="auth-info-box">
                <i class="bi bi-info-circle"></i>
                <span>If an account exists, you'll receive an email with instructions within a few minutes.</span>
            </div>

            <form asp-controller="Account" asp-action="ForgotPassword" method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="auth-validation-summary"></div>

                <div class="auth-field">
                    <label asp-for="UsernameOrEmail">Username or Email</label>
                    <div class="auth-input-wrap">
                        <i class="bi bi-person auth-input-icon"></i>
                        <input asp-for="UsernameOrEmail" class="auth-input" placeholder="Enter username or email" autocomplete="username" />
                    </div>
                    <span asp-validation-for="UsernameOrEmail" class="auth-field-error"></span>
                </div>

                <button type="submit" class="btn btn-auth-primary w-100">
                    <i class="bi bi-envelope me-2"></i>Send Reset Link
                </button>
            </form>

            <div class="auth-card-foot">
                <span>Remember your password?</span>
                <a asp-controller="Account" asp-action="Login" class="auth-link auth-link-bold">Sign in <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
