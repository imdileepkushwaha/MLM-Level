@model IEnumerable<MLM_Level.Models.CommissionTran>
@{
    ViewData["Title"] = "Direct Income";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="glass-card p-4 d-flex justify-content-between align-items-center">
            <div>
                <h4 class="text-white fw-bold mb-1"><i class="bi bi-arrow-right-circle text-info me-2"></i>Direct Income</h4>
                <p class="text-secondary mb-0">Earnings from your direct referrals (Level 1).</p>
            </div>
            <div class="text-end">
                <span class="text-secondary small d-block mb-1">Total Direct Income</span>
                <h3 class="text-info fw-bold mb-0">₹@((ViewBag.TotalIncome ?? 0m).ToString("N2"))</h3>
            </div>
        </div>
    </div>
</div>

<div class="glass-card p-4">
    <div class="glass-table-container">
        @if (Model != null && Model.Any())
        {
            <table class="table glass-table align-middle">
                <thead>
                    <tr>
                        <th>Date & Time</th>
                        <th>Member Details</th>
                        <th>Description</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Timestamp.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</td>
                            <td>
                                @if (item.FromUser != null)
                                {
                                    <span class="text-white fw-bold">@item.FromUser.Username</span><br />
                                    <span class="small text-muted">@item.FromUser.FullName</span>
                                }
                                else
                                {
                                    <span class="text-muted">System</span>
                                }
                            </td>
                            <td><span class="text-secondary">@item.Description</span></td>
                            <td class="text-end text-success fw-bold">+₹@item.Amount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center py-5 text-secondary">
                <i class="bi bi-inbox fs-1 mb-3 d-block opacity-50"></i>
                <p>No direct income records found.</p>
            </div>
        }
    </div>
</div>
