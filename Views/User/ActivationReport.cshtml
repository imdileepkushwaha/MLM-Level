@model IEnumerable<MLM_Level.Models.ActivationRequest>

@{
    ViewData["Title"] = "Activation Report";
}

<div class="container py-2">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold mb-1">Activation Report</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0" style="font-size: 0.85rem;">
                    <li class="breadcrumb-item"><a asp-controller="User" asp-action="Index" class="text-decoration-none">Home</a></li>
                    <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">Reports</a></li>
                    <li class="breadcrumb-item active text-primary" aria-current="page">Activation History</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Activate" class="btn btn-cyber-cyan btn-sm px-3 shadow-sm" style="border-radius: 8px;">
            <i class="bi bi-plus-circle me-1"></i> New Request
        </a>
    </div>

    <div class="glass-card p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="border-0 rounded-start">Date Submitted</th>
                        <th class="border-0">Amount</th>
                        <th class="border-0">UTR / Ref No</th>
                        <th class="border-0">Status</th>
                        <th class="border-0 rounded-end">Remarks/Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var req in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold text-dark" style="font-size: 0.9rem;">
                                        @req.CreatedDate.ToString("dd MMM yyyy")
                                    </div>
                                    <div class="text-muted" style="font-size: 0.75rem;">
                                        @req.CreatedDate.ToString("hh:mm tt")
                                    </div>
                                </td>
                                <td>
                                    <span class="text-primary fw-bold">₹@req.Amount.ToString("N0")</span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <code class="text-secondary bg-light px-2 py-1 rounded">@req.TransactionReference</code>
                                        @if (!string.IsNullOrEmpty(req.PaymentSlipUrl))
                                        {
                                            <a href="@req.PaymentSlipUrl" target="_blank" class="text-info" title="View Payment Slip" style="font-size: 1.1rem;">
                                                <i class="bi bi-file-earmark-image"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @if (req.Status == "Approved")
                                    {
                                        <span class="badge badge-approved">
                                            <i class="bi bi-check-circle me-1"></i>Approved
                                        </span>
                                    }
                                    else if (req.Status == "Pending")
                                    {
                                        <span class="badge badge-pending">
                                            <i class="bi bi-hourglass-split me-1"></i>Pending
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-rejected">
                                            <i class="bi bi-x-circle me-1"></i>Rejected
                                        </span>
                                    }
                                </td>
                                <td>
                                    @if (req.Status == "Approved" && req.ApprovedDate.HasValue)
                                    {
                                        <div class="text-success small" style="font-size: 0.75rem;">
                                            Approved on <br />
                                            <strong>@req.ApprovedDate.Value.ToString("dd MMM, HH:mm")</strong>
                                        </div>
                                    }
                                    else if (req.Status == "Pending")
                                    {
                                        <span class="text-muted small" style="font-size: 0.75rem;">Awaiting Audit</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger small" style="font-size: 0.75rem;">Declined by Admin</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                <i class="bi bi-receipt fs-1 d-block mb-3 text-secondary opacity-50"></i>
                                No activation requests found.
                                <div class="mt-3">
                                    <a asp-action="Activate" class="btn btn-sm btn-outline-primary" style="border-radius: 8px;">Submit a new request</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
