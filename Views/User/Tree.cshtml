@model MLM_Level.Models.UserDownlineViewModel
@{
    ViewData["Title"] = "Network Tree";
    var totalDownline = Model.FullDownlineList?.Count ?? 0;
}

@await Html.PartialAsync("_MemberPageHeader", new MLM_Level.Models.MemberPageHeaderViewModel
{
    Title = "Network Tree",
    Subtitle = "Visual placement tree and level-wise downline breakdown",
    Icon = "bi-diagram-3",
    ThemeClass = "member-theme-cyan",
    Badge = $"{totalDownline} in network"
})

<ul class="nav member-tab-nav mb-4" id="treeTab" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="visual-tab" data-bs-toggle="tab" data-bs-target="#visual" type="button" role="tab">
            <i class="bi bi-diagram-3 me-1"></i>Visual tree
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="list-tab" data-bs-toggle="tab" data-bs-target="#list" type="button" role="tab">
            <i class="bi bi-list-stars me-1"></i>Level breakdown
        </button>
    </li>
</ul>

<!-- Tab Contents -->
<div class="tab-content" id="treeTabContent">
    
    <!-- Tab 1: Visual tree -->
    <div class="tab-pane fade show active" id="visual" role="tabpanel" aria-labelledby="visual-tab">
        <div class="member-tree-panel downline-tree-wrapper">
            <div class="tree-root">
                <!-- Logged in User (Anchor Root node) -->
                <div class="tree-node-box @(Model.UserInfo.IsActive ? "active-node" : "inactive-node")">
                    <div class="node-name">@Model.UserInfo.Username</div>
                    <div class="node-meta">@Model.UserInfo.FullName</div>
                    <div class="node-meta">Sponsor: @(Model.UserInfo.Sponsor?.Username ?? "Root")</div>
                    <span class="badge @(Model.UserInfo.IsActive ? "bg-success" : "bg-warning") mt-1" style="font-size: 0.65rem;">
                        @(Model.UserInfo.IsActive ? "Active" : "Inactive")
                    </span>
                </div>

                @if (Model.Level1.Any())
                {
                    <ul class="tree-ul">
                        @foreach (var lvl1 in Model.Level1.Where(n => n.ParentId == Model.UserInfo.Id))
                        {
                            <li class="tree-li">
                                <div class="tree-node-box @(lvl1.IsActive ? "active-node" : "inactive-node")">
                                    <div class="node-name">@lvl1.Username</div>
                                    <div class="node-meta">@lvl1.FullName</div>
                                    <div class="node-meta text-info">Level 1</div>
                                    <span class="badge @(lvl1.IsActive ? "bg-success" : "bg-warning") mt-1" style="font-size: 0.65rem;">
                                        @(lvl1.IsActive ? "Active" : "Inactive")
                                    </span>
                                </div>

                                <!-- Level 2 nested children -->
                                @{
                                    var lvl2Children = Model.Level2.Where(n => n.ParentId == lvl1.Id).ToList();
                                }
                                @if (lvl2Children.Any())
                                {
                                    <ul class="tree-ul">
                                        @foreach (var lvl2 in lvl2Children)
                                        {
                                            <li class="tree-li">
                                                <div class="tree-node-box @(lvl2.IsActive ? "active-node" : "inactive-node")">
                                                    <div class="node-name">@lvl2.Username</div>
                                                    <div class="node-meta">@lvl2.FullName</div>
                                                    <div class="node-meta text-primary">Level 2</div>
                                                    <span class="badge @(lvl2.IsActive ? "bg-success" : "bg-warning") mt-1" style="font-size: 0.65rem;">
                                                        @(lvl2.IsActive ? "Active" : "Inactive")
                                                    </span>
                                                </div>

                                                <!-- Level 3 nested children -->
                                                @{
                                                    var lvl3Children = Model.Level3.Where(n => n.ParentId == lvl2.Id).ToList();
                                                }
                                                @if (lvl3Children.Any())
                                                {
                                                    <ul class="tree-ul">
                                                        @foreach (var lvl3 in lvl3Children)
                                                        {
                                                            <li class="tree-li">
                                                                <div class="tree-node-box @(lvl3.IsActive ? "active-node" : "inactive-node")">
                                                                    <div class="node-name">@lvl3.Username</div>
                                                                    <div class="node-meta">@lvl3.FullName</div>
                                                                    <div class="node-meta text-success">Level 3</div>
                                                                </div>

                                                                <!-- Level 4 nested children -->
                                                                @{
                                                                    var lvl4Children = Model.Level4.Where(n => n.ParentId == lvl3.Id).ToList();
                                                                }
                                                                @if (lvl4Children.Any())
                                                                {
                                                                    <ul class="tree-ul">
                                                                        @foreach (var lvl4 in lvl4Children)
                                                                        {
                                                                            <li class="tree-li">
                                                                                <div class="tree-node-box @(lvl4.IsActive ? "active-node" : "inactive-node")">
                                                                                    <div class="node-name">@lvl4.Username</div>
                                                                                    <div class="node-meta">@lvl4.FullName</div>
                                                                                    <div class="node-meta text-warning">Level 4</div>
                                                                                </div>
                                                                            </li>
                                                                        }
                                                                    </ul>
                                                                }
                                                                else
                                                                {
                                                                    <ul class="tree-ul">
                                                                        <li class="tree-li">
                                                                            <div class="tree-node-box inactive-node" style="opacity: 0.6; border-style: dashed;">
                                                                                <div class="node-name text-muted">Blank</div>
                                                                                <div class="node-meta text-muted">Level 4</div>
                                                                            </div>
                                                                        </li>
                                                                    </ul>
                                                                }
                                                            </li>
                                                        }
                                                    </ul>
                                                }
                                                else
                                                {
                                                    <ul class="tree-ul">
                                                        <li class="tree-li">
                                                            <div class="tree-node-box inactive-node" style="opacity: 0.6; border-style: dashed;">
                                                                <div class="node-name text-muted">Blank</div>
                                                                <div class="node-meta text-muted">Level 3</div>
                                                            </div>
                                                            <ul class="tree-ul">
                                                                <li class="tree-li">
                                                                    <div class="tree-node-box inactive-node" style="opacity: 0.6; border-style: dashed;">
                                                                        <div class="node-name text-muted">Blank</div>
                                                                        <div class="node-meta text-muted">Level 4</div>
                                                                    </div>
                                                                </li>
                                                            </ul>
                                                        </li>
                                                    </ul>
                                                }
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <ul class="tree-ul">
                                        <li class="tree-li">
                                            <div class="tree-node-box inactive-node" style="opacity: 0.6; border-style: dashed;">
                                                <div class="node-name text-muted">Blank</div>
                                                <div class="node-meta text-muted">Level 2</div>
                                            </div>
                                            <ul class="tree-ul">
                                                <li class="tree-li">
                                                    <div class="tree-node-box inactive-node" style="opacity: 0.6; border-style: dashed;">
                                                        <div class="node-name text-muted">Blank</div>
                                                        <div class="node-meta text-muted">Level 3</div>
                                                    </div>
                                                    <ul class="tree-ul">
                                                        <li class="tree-li">
                                                            <div class="tree-node-box inactive-node" style="opacity: 0.6; border-style: dashed;">
                                                                <div class="node-name text-muted">Blank</div>
                                                                <div class="node-meta text-muted">Level 4</div>
                                                            </div>
                                                        </li>
                                                    </ul>
                                                </li>
                                            </ul>
                                        </li>
                                    </ul>
                                }
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <ul class="tree-ul">
                        <li class="tree-li">
                            <div class="tree-node-box inactive-node" style="opacity: 0.6; border-style: dashed;">
                                <div class="node-name text-muted">Blank</div>
                                <div class="node-meta text-muted">Level 1</div>
                            </div>
                            <ul class="tree-ul">
                                <li class="tree-li">
                                    <div class="tree-node-box inactive-node" style="opacity: 0.6; border-style: dashed;">
                                        <div class="node-name text-muted">Blank</div>
                                        <div class="node-meta text-muted">Level 2</div>
                                    </div>
                                    <ul class="tree-ul">
                                        <li class="tree-li">
                                            <div class="tree-node-box inactive-node" style="opacity: 0.6; border-style: dashed;">
                                                <div class="node-name text-muted">Blank</div>
                                                <div class="node-meta text-muted">Level 3</div>
                                            </div>
                                            <ul class="tree-ul">
                                                <li class="tree-li">
                                                    <div class="tree-node-box inactive-node" style="opacity: 0.6; border-style: dashed;">
                                                        <div class="node-name text-muted">Blank</div>
                                                        <div class="node-meta text-muted">Level 4</div>
                                                    </div>
                                                </li>
                                            </ul>
                                        </li>
                                    </ul>
                                </li>
                            </ul>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </div>

    <!-- Tab 2: Tabular categorizations -->
    <div class="tab-pane fade" id="list" role="tabpanel" aria-labelledby="list-tab">
        <!-- Level Category Tabs -->
        <div class="glass-card member-panel-card p-4">
            <h5 class="member-panel-title mb-4"><i class="bi bi-layers text-primary me-2"></i>Downline by level</h5>
            
            @if (Model.FullDownlineList.Any())
            {
                <div class="accordion member-accordion" id="levelAccordion">
                    
                    <!-- Level 1 -->
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingOne">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne">
                                <i class="bi bi-star-fill text-primary me-2"></i> Level 1 — Direct referrals
                                <span class="admin-record-badge ms-auto me-2">@Model.Level1.Count</span>
                            </button>
                        </h2>
                        <div id="collapseOne" class="accordion-collapse collapse" data-bs-parent="#levelAccordion">
                            <div class="accordion-body p-0">
                                <div class="admin-table-scroll">
                                    <table class="table admin-table align-middle m-0">
                                        <thead>
                                            <tr>
                                                <th>Member Details</th>
                                                <th>Sponsor</th>
                                                <th>Active Status</th>
                                                <th>Joining Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var m in Model.Level1)
                                            {
                                                <tr>
                                                    <td><strong>@m.Username</strong><br/><span class="small text-muted">@m.FullName</span></td>
                                                    <td>@m.SponsorName</td>
                                                    <td>@(m.IsActive ? Html.Raw("<span class=\"admin-badge-success\">Active</span>") : Html.Raw("<span class=\"admin-badge-pending\">Inactive</span>"))</td>
                                                    <td>@m.JoinedDate.ToString("dd MMM yyyy")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Level 2 -->
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingTwo">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo">
                                <i class="bi bi-star text-primary me-2"></i> Level 2
                                <span class="admin-record-badge ms-auto me-2">@Model.Level2.Count</span>
                            </button>
                        </h2>
                        <div id="collapseTwo" class="accordion-collapse collapse" data-bs-parent="#levelAccordion">
                            <div class="accordion-body p-0">
                                <div class="admin-table-scroll">
                                    <table class="table admin-table align-middle m-0">
                                        <thead>
                                            <tr>
                                                <th>Member Details</th>
                                                <th>Sponsor / Parent</th>
                                                <th>Active Status</th>
                                                <th>Joining Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var m in Model.Level2)
                                            {
                                                <tr>
                                                    <td><strong>@m.Username</strong><br/><span class="small text-muted">@m.FullName</span></td>
                                                    <td>
                                                        Sponsor: <strong>@m.SponsorName</strong><br/>
                                                        Parent: <strong>@m.ParentName</strong>
                                                    </td>
                                                    <td>@(m.IsActive ? Html.Raw("<span class=\"admin-badge-success\">Active</span>") : Html.Raw("<span class=\"admin-badge-pending\">Inactive</span>"))</td>
                                                    <td>@m.JoinedDate.ToString("dd MMM yyyy")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Level 3 -->
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingThree">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree">
                                <i class="bi bi-star text-primary me-2"></i> Level 3
                                <span class="admin-record-badge ms-auto me-2">@Model.Level3.Count</span>
                            </button>
                        </h2>
                        <div id="collapseThree" class="accordion-collapse collapse" data-bs-parent="#levelAccordion">
                            <div class="accordion-body p-0">
                                <div class="admin-table-scroll">
                                    <table class="table admin-table align-middle m-0">
                                        <thead>
                                            <tr>
                                                <th>Member Details</th>
                                                <th>Sponsor / Parent</th>
                                                <th>Active Status</th>
                                                <th>Joining Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var m in Model.Level3)
                                            {
                                                <tr>
                                                    <td><strong>@m.Username</strong><br/><span class="small text-muted">@m.FullName</span></td>
                                                    <td>
                                                        Sponsor: <strong>@m.SponsorName</strong><br/>
                                                        Parent: <strong>@m.ParentName</strong>
                                                    </td>
                                                    <td>@(m.IsActive ? Html.Raw("<span class=\"admin-badge-success\">Active</span>") : Html.Raw("<span class=\"admin-badge-pending\">Inactive</span>"))</td>
                                                    <td>@m.JoinedDate.ToString("dd MMM yyyy")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Level 4 -->
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingFour">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFour">
                                <i class="bi bi-star text-primary me-2"></i> Level 4
                                <span class="admin-record-badge ms-auto me-2">@Model.Level4.Count</span>
                            </button>
                        </h2>
                        <div id="collapseFour" class="accordion-collapse collapse" data-bs-parent="#levelAccordion">
                            <div class="accordion-body p-0">
                                <div class="admin-table-scroll">
                                    <table class="table admin-table align-middle m-0">
                                        <thead>
                                            <tr>
                                                <th>Member Details</th>
                                                <th>Sponsor / Parent</th>
                                                <th>Active Status</th>
                                                <th>Joining Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var m in Model.Level4)
                                            {
                                                <tr>
                                                    <td><strong>@m.Username</strong><br/><span class="small text-muted">@m.FullName</span></td>
                                                    <td>
                                                        Sponsor: <strong>@m.SponsorName</strong><br/>
                                                        Parent: <strong>@m.ParentName</strong>
                                                    </td>
                                                    <td>@(m.IsActive ? Html.Raw("<span class=\"admin-badge-success\">Active</span>") : Html.Raw("<span class=\"admin-badge-pending\">Inactive</span>"))</td>
                                                    <td>@m.JoinedDate.ToString("dd MMM yyyy")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Level 5 -->
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingFive">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFive">
                                <i class="bi bi-star text-primary me-2"></i> Level 5
                                <span class="admin-record-badge ms-auto me-2">@Model.Level5.Count</span>
                            </button>
                        </h2>
                        <div id="collapseFive" class="accordion-collapse collapse" data-bs-parent="#levelAccordion">
                            <div class="accordion-body p-0">
                                <div class="admin-table-scroll">
                                    <table class="table admin-table align-middle m-0">
                                        <thead>
                                            <tr>
                                                <th>Member Details</th>
                                                <th>Sponsor / Parent</th>
                                                <th>Active Status</th>
                                                <th>Joining Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var m in Model.Level5)
                                            {
                                                <tr>
                                                    <td><strong>@m.Username</strong><br/><span class="small text-muted">@m.FullName</span></td>
                                                    <td>
                                                        Sponsor: <strong>@m.SponsorName</strong><br/>
                                                        Parent: <strong>@m.ParentName</strong>
                                                    </td>
                                                    <td>@(m.IsActive ? Html.Raw("<span class=\"admin-badge-success\">Active</span>") : Html.Raw("<span class=\"admin-badge-pending\">Inactive</span>"))</td>
                                                    <td>@m.JoinedDate.ToString("dd MMM yyyy")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            }
            else
            {
                @await Html.PartialAsync("_AdminNoResults")
            }
        </div>
    </div>

</div>
