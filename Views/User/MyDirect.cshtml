@model IEnumerable<MLM_Level.Models.User>

@{
    ViewData["Title"] = "My Direct Referrals";
}

<div class="container py-2">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold mb-1">My Direct Referrals</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0" style="font-size: 0.85rem;">
                    <li class="breadcrumb-item"><a asp-controller="User" asp-action="Index" class="text-decoration-none">Home</a></li>
                    <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">My Team</a></li>
                    <li class="breadcrumb-item active text-primary" aria-current="page">My Direct</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="glass-card p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="border-0 rounded-start">Member</th>
                        <th class="border-0">Username</th>
                        <th class="border-0">Status</th>
                        <th class="border-0 rounded-end">Joined Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar-circle avatar-md avatar-color-@(Math.Abs((user.FullName ?? user.Username).GetHashCode()) % 6)">
                                            @(user.FullName?.FirstOrDefault() ?? 'U')
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark" style="font-size: 0.9rem;">@user.FullName</div>
                                            <div class="text-muted" style="font-size: 0.75rem;">@user.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="text-secondary fw-semibold">@@@user.Username</span></td>
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 px-2 py-1">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div class="text-secondary small">
                                        <i class="bi bi-calendar-check me-1"></i> @user.JoinedDate.ToString("MMM dd, yyyy")
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-5">
                                <i class="bi bi-people-fill fs-1 d-block mb-3 text-secondary opacity-50"></i>
                                You don't have any direct referrals yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
