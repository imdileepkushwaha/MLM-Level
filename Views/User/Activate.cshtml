@{
    ViewData["Title"] = "Package Activation";
    var settings = ViewBag.MlmSettings as MLM_Level.Models.MlmSetting ?? new MLM_Level.Models.MlmSetting();
    var packages = ViewBag.Packages as List<MLM_Level.Models.Package> ?? new List<MLM_Level.Models.Package>();
}


<div class="container py-2">
    <!-- Page Header & Breadcrumb -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold mb-1">Package Activation</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0" style="font-size: 0.85rem;">
                    <li class="breadcrumb-item"><a asp-controller="User" asp-action="Index" class="text-decoration-none">Home</a></li>
                    <li class="breadcrumb-item"><a asp-controller="User" asp-action="Index" class="text-decoration-none text-muted">Network Management</a></li>
                    <li class="breadcrumb-item active text-primary" aria-current="page">Package Activation</li>
                </ol>
            </nav>
        </div>
    </div>

    @if (ViewBag.HasPendingRequest == true)
    {
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="glass-card border-warning text-center p-5 shadow-sm">
                    <div class="d-inline-flex align-items-center justify-content-center bg-warning bg-opacity-10 text-warning rounded-circle mb-4" style="width: 80px; height: 80px;">
                        <i class="bi bi-clock-history" style="font-size: 2.5rem;"></i>
                    </div>
                    <h4 class="text-dark fw-bold mb-3">Activation Request Pending</h4>
                    <p class="text-secondary small mb-4 px-md-4">
                        You have already submitted an activation request. Our financial audit team is currently verifying the payment references. This process typically takes less than an hour.
                    </p>
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-controller="User" asp-action="Index" class="btn btn-light px-4 border" style="border-radius: 8px;">Dashboard</a>
                        <a asp-controller="User" asp-action="Profile" class="btn btn-cyber-cyan px-4" style="border-radius: 8px;">My Profile</a>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (!packages.Any())
    {
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="glass-card border-danger text-center p-5 shadow-sm">
                    <div class="d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10 text-danger rounded-circle mb-4" style="width: 80px; height: 80px;">
                        <i class="bi bi-exclamation-triangle" style="font-size: 2.5rem;"></i>
                    </div>
                    <h4 class="text-dark fw-bold mb-3">No Active Packages Available</h4>
                    <p class="text-secondary small mb-0 px-md-4">
                        There are currently no active membership plans configured in the system. Please reach out to the administrator to set up activation packages.
                    </p>
                </div>
            </div>
        </div>
    }
    else
    {
        <form asp-controller="User" asp-action="Activate" method="post" id="activationForm" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
            
            <div class="row g-4">
                <!-- Left Column: Plans + Bank Details -->
                <div class="col-lg-7">
                    <div class="d-flex flex-column gap-4">
                        
                        <!-- Step 1: Select Plan (Column Cards) -->
                        <div class="glass-card p-4">
                            <div class="d-flex align-items-center gap-2 mb-4">
                                <span class="step-badge">1</span>
                                <h5 class="step-title mb-0">Select Membership Plan</h5>
                            </div>
                            
                            <div class="row g-3">
                                @for (int i = 0; i < packages.Count; i++)
                                {
                                    var pkg = packages[i];
                                    var isSelected = i == 0;
                                    
                                    var themeClass = "theme-blue";
                                    var planIcon = "bi-star-fill";
                                    var priorityText = "Basic Support";
                                    
                                    if (i == 1)
                                    {
                                        themeClass = "theme-cyan";
                                        planIcon = "bi-award-fill";
                                        priorityText = "Priority Access";
                                    }
                                    else if (i >= 2)
                                    {
                                        themeClass = "theme-purple";
                                        planIcon = "bi-gem";
                                        priorityText = "VIP Benefits";
                                    }
                                    
                                    <div class="col-md-4 col-sm-6 col-12">
                                        <div class="card custom-plan-card w-100 @themeClass @(isSelected ? "active-selected" : "")" onclick="selectPackage('@pkg.Id', '@pkg.Price', this)" data-pkg-id="@pkg.Id">
                                            
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="plan-icon-box">
                                                    <i class="bi @planIcon"></i>
                                                </div>
                                                <div>
                                                    <h5 class="plan-title text-dark fw-extrabold mb-1" style="font-size: 1.1rem; letter-spacing: -0.01em;">@pkg.Name</h5>
                                                    <span class="plan-subtitle text-muted small" style="font-size: 0.72rem;">@priorityText</span>
                                                </div>
                                            </div>
                                            
                                            <div class="my-3">
                                                <span class="price-val">₹@pkg.Price.ToString("N0")</span>
                                                <span class="price-suffix d-block mt-1">One-time Activation</span>
                                            </div>
                                            
                                            <div class="plan-feature-box">
                                                <div class="d-flex align-items-center justify-content-between mb-2">
                                                    <span class="text-dark small feature-item" style="font-size: 0.72rem; font-weight: 500;">
                                                        <i class="bi bi-check-circle-fill text-success me-1"></i>Referrals
                                                    </span>
                                                    <span class="fw-bold small text-dark feature-item" style="font-size: 0.72rem;">Active</span>
                                                </div>
                                                <div class="d-flex align-items-center justify-content-between">
                                                    <span class="text-dark small feature-item" style="font-size: 0.72rem; font-weight: 500;">
                                                        <i class="bi bi-check-circle-fill text-success me-1"></i>Binary Node
                                                    </span>
                                                    <span class="fw-bold small text-dark feature-item" style="font-size: 0.72rem;">Qualify</span>
                                                </div>
                                            </div>
                                            
                                            <button type="button" class="plan-select-btn">
                                                @(isSelected ? "✓ Selected" : "Choose Plan")
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                            <input type="hidden" id="packageId" name="packageId" value="@(packages.FirstOrDefault()?.Id)" />
                        </div>

                        <!-- Step 2: Complete Payment -->
                        <div class="glass-card p-4">
                            <div class="d-flex align-items-center gap-2 mb-4">
                                <span class="step-badge">2</span>
                                <h5 class="step-title mb-0">Complete Payment Transfer</h5>
                            </div>
                            
                            <p class="text-muted small mb-4">
                                Please transfer the exact package amount of <strong class="text-primary" id="instructionPriceText">₹@(packages.FirstOrDefault()?.Price.ToString("N0"))</strong> to the company accounts detailed below:
                            </p>

                            <div class="row g-3">
                                @if (!string.IsNullOrEmpty(settings.CompanyQrCodeUrl))
                                {
                                    <div class="col-md-6">
                                        <div class="border rounded-3 p-3 bg-white h-100 position-relative" style="border-color: var(--glass-border) !important;">
                                            <div class="d-flex align-items-center gap-2 mb-2">
                                                <div class="d-flex align-items-center justify-content-center bg-info bg-opacity-10 text-info rounded-circle" style="width: 28px; height: 28px;">
                                                    <i class="bi bi-qr-code" style="font-size: 0.85rem;"></i>
                                                </div>
                                                <div class="small text-muted fw-bold" style="font-size: 0.75rem;">UPI Payment Address</div>
                                            </div>
                                            
                                            <div class="bg-light bg-opacity-50 border rounded-3 p-2 d-flex align-items-center justify-content-between mt-3" style="font-size: 0.85rem; letter-spacing: 0.02em;">
                                                <span class="text-dark fw-bold" id="upiAddressVal">@settings.CompanyQrCodeUrl</span>
                                                <button type="button" class="btn btn-link p-0 text-decoration-none" onclick="copyValue('upiAddressVal', 'UPI Address')" title="Copy UPI Address">
                                                    <i class="bi bi-clipboard text-info fs-6"></i>
                                                </button>
                                            </div>
                                            
                                            <div class="small text-muted mt-3" style="font-size: 0.65rem; line-height: 1.3;">
                                                <i class="bi bi-lightning-fill text-warning me-1"></i>Supports all major UPI apps (GPay, PhonePe, Paytm).
                                            </div>
                                        </div>
                                    </div>
                                }

                                <div class="col-md-12">
                                    <div class="border rounded-3 p-3 bg-white h-100" style="border-color: var(--glass-border) !important;">
                                        <div class="d-flex align-items-center justify-content-between mb-3">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="d-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle" style="width: 28px; height: 28px;">
                                                    <i class="bi bi-bank" style="font-size: 0.85rem;"></i>
                                                </div>
                                                <div class="small text-muted fw-bold" style="font-size: 0.75rem;">Bank Account Details</div>
                                            </div>
                                            @if (!string.IsNullOrEmpty(settings.BankDetails))
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary border-0 px-2 py-0" onclick="copyText('@settings.BankDetails.Replace("\r\n", "\\n").Replace("\n", "\\n")', 'All Bank Details')" title="Copy All" style="font-size: 0.65rem; border-radius: 6px;">
                                                    <i class="bi bi-files me-1"></i>Copy All
                                                </button>
                                            }
                                        </div>

                                        @if (!string.IsNullOrEmpty(settings.BankDetails))
                                        {
                                            var bankLines = settings.BankDetails.Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries);
                                            var bankIcons = new Dictionary<string, string> {
                                                { "bank", "bi-building" },
                                                { "a/c name", "bi-person" },
                                                { "a/c no", "bi-credit-card" },
                                                { "ifsc", "bi-upc-scan" },
                                                { "branch", "bi-geo-alt" },
                                                { "upi", "bi-phone" }
                                            };

                                            <div class="bank-box">
                                                @foreach (var line in bankLines)
                                                {
                                                    var parts = line.Split(new[] { ':' }, 2);
                                                    var label = parts.Length > 1 ? parts[0].Trim() : "Info";
                                                    var val = parts.Length > 1 ? parts[1].Trim() : line.Trim();
                                                    var iconClass = "bi-info-circle";
                                                    foreach (var kvp in bankIcons)
                                                    {
                                                        if (label.ToLower().Contains(kvp.Key))
                                                        {
                                                            iconClass = kvp.Value;
                                                            break;
                                                        }
                                                    }
                                                    var fieldId = "bank_" + label.Replace(" ", "_").Replace("/", "_").ToLower();

                                                    <div class="d-flex align-items-center justify-content-between rounded-3 px-3 py-2" style="background: #f8fafc; border: 1px solid #f0f0f5;">
                                                        <div class="d-flex align-items-center gap-2" style="min-width: 0;">
                                                            <i class="bi @iconClass text-primary bank-box-icon" ></i>
                                                            <div style="min-width: 0;">
                                                                <div class="text-muted" style="font-size: 0.6rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">@label</div>
                                                                <div class="text-dark fw-bold text-truncate" id="@fieldId" style="font-size: 0.82rem; letter-spacing: 0.02em;">@val</div>
                                                            </div>
                                                        </div>
                                                        <button type="button" class="btn btn-link p-0 ms-2 text-decoration-none flex-shrink-0" onclick="copyValue('@fieldId', '@label')" title="Copy @label">
                                                            <i class="bi bi-clipboard text-primary" style="font-size: 0.85rem; opacity: 0.6;"></i>
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="text-muted small mt-3" style="font-size: 0.75rem; line-height: 1.4;">
                                                <i class="bi bi-exclamation-circle me-1"></i>Bank transfers currently offline. Please use the UPI option.
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column (Step 3 - Submit Payment Proof) -->
                <div class="col-lg-5">
                    <div class="glass-card p-4 h-100 d-flex flex-column justify-content-between shadow-sm">
                        <div>
                            <div class="d-flex align-items-center gap-2 mb-4">
                                <span class="step-badge">3</span>
                                <h5 class="step-title mb-0">Submit Payment Proof</h5>
                            </div>

                            <!-- Selected Stat Summary Box -->
                            <div class="border rounded-3 p-3 mb-4 bg-light bg-opacity-25" style="border-color: var(--glass-border) !important;">
                                <div class="row align-items-center">
                                    <div class="col-6">
                                        <span class="small text-muted d-block">Selected Plan Price</span>
                                        <span class="fs-3 fw-extrabold text-primary" id="displayTransferAmount" style="letter-spacing: -0.02em;">₹@(packages.FirstOrDefault()?.Price.ToString("N0"))</span>
                                    </div>
                                    <div class="col-6 border-start ps-3" style="border-color: var(--glass-border) !important;">
                                        <span class="small text-muted d-block">Status</span>
                                        <span class="badge bg-warning bg-opacity-10 text-warning px-2.5 py-1 mt-1" style="font-size: 0.72rem; border-radius: 6px;">Awaiting UTR</span>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-4 form-group">
                                <label for="transactionReference" class="text-muted small fw-bold mb-1">Transaction UTR / Reference ID</label>
                                <input type="text" id="transactionReference" name="transactionReference" class="form-control auth-glow-input" placeholder="Enter the 12-digit UTR number" required style="font-size: 0.95rem; border-radius: 10px;" />
                                <small class="text-muted mt-2 d-block" style="font-size: 0.7rem; line-height: 1.3;">
                                    <i class="bi bi-info-circle me-1"></i>Please enter the 12-digit transaction ID or reference number shown in your payment receipt from GPay, PhonePe, Paytm, or your bank.
                                </small>
                            </div>

                            <div class="mb-4 form-group">
                                <label for="paymentSlip" class="text-muted small fw-bold mb-1">Upload Payment Slip <span class="fw-normal text-secondary">(Optional)</span></label>
                                <div class="position-relative">
                                    <input type="file" id="paymentSlip" name="paymentSlip" class="form-control auth-glow-input" accept="image/*,.pdf" style="font-size: 0.85rem; border-radius: 10px; padding: 10px;" />
                                </div>
                                <small class="text-muted mt-2 d-block" style="font-size: 0.7rem; line-height: 1.3;">
                                    <i class="bi bi-image me-1"></i>You can optionally upload a screenshot of your payment receipt to speed up verification. (Image/PDF)
                                </small>
                            </div>

                            <div class="border border-info border-opacity-10 bg-info bg-opacity-5 rounded-3 p-3 mb-4">
                                <div class="d-flex gap-2">
                                    <i class="bi bi-info-circle-fill text-info fs-5 mt-0.5"></i>
                                    <div>
                                        <h6 class="text-dark fw-bold mb-1" style="font-size: 0.82rem;">Audit Verification</h6>
                                        <p class="text-muted small mb-0" style="font-size: 0.72rem; line-height: 1.4;">
                                            Commissions are instantly computed and distributed across 5 sponsor levels the moment your transaction reference is verified by our admins.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-cyber-pink w-100 py-3 mt-auto shadow-sm" style="border-radius: 12px; font-weight: 600; font-size: 1rem;">
                            <i class="bi bi-shield-check me-1.5 fs-5 align-middle"></i>Submit Proof for Verification
                        </button>
                    </div>
                </div>
            </div>
        </form>
    }
</div>

@section Scripts {
    <script>
        function selectPackage(id, price, element) {
            // Update hidden input
            document.getElementById('packageId').value = id;
            
            // Toggle active classes on cards
            document.querySelectorAll('.custom-plan-card').forEach(card => {
                card.classList.remove('active-selected');
                const btn = card.querySelector('.plan-select-btn');
                if (btn) btn.innerText = "Choose Plan";
            });
            element.classList.add('active-selected');
            const selectedBtn = element.querySelector('.plan-select-btn');
            if (selectedBtn) selectedBtn.innerText = "✓ Selected";
            
            // Format and update the prices in Steps 2 & 3
            const priceText = parseFloat(price).toLocaleString('en-IN');
            document.getElementById('displayTransferAmount').innerText = '₹' + priceText;
            document.getElementById('instructionPriceText').innerText = '₹' + priceText;
        }

        function copyValue(elementId, label) {
            const val = document.getElementById(elementId).innerText;
            navigator.clipboard.writeText(val).then(() => {
                showCopyToast(label + ' copied!');
            }).catch(err => {
                console.error("Failed to copy: ", err);
            });
        }

        function copyText(text, label) {
            const decoded = text.replace(/\\n/g, '\n');
            navigator.clipboard.writeText(decoded).then(() => {
                showCopyToast(label + ' copied!');
            }).catch(err => {
                console.error("Failed to copy: ", err);
            });
        }

        function showCopyToast(msg) {
            let toast = document.getElementById('copyToast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'copyToast';
                toast.style.cssText = 'position:fixed;bottom:24px;right:24px;background:#10b981;color:#fff;padding:10px 20px;border-radius:10px;font-size:0.85rem;font-weight:600;box-shadow:0 8px 24px rgba(0,0,0,0.15);z-index:9999;opacity:0;transition:opacity 0.3s;display:flex;align-items:center;gap:8px;';
                document.body.appendChild(toast);
            }
            toast.innerHTML = '<i class="bi bi-check-circle-fill"></i>' + msg;
            toast.style.opacity = '1';
            clearTimeout(toast._timer);
            toast._timer = setTimeout(() => { toast.style.opacity = '0'; }, 2000);
        }
    </script>
}
