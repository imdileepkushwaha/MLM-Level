@model MLM_Level.Models.UserDashboardViewModel
@{
    ViewData["Title"] = "Member Dashboard";
    var announcements = ViewBag.Announcements as List<MLM_Level.Models.Announcement>;
    var leaderboard = ViewBag.Leaderboard as List<MLM_Level.Models.LeaderboardItemViewModel>;
}

@await Html.PartialAsync("_MemberPageHeader", new MLM_Level.Models.MemberPageHeaderViewModel
{
    Title = $"Welcome, {Model.UserInfo.FullName?.Split(' ').FirstOrDefault() ?? Model.UserInfo.Username}",
    Subtitle = "Track earnings, team growth and account activity in one place",
    Icon = "bi-grid-fill",
    ThemeClass = "member-theme-violet",
    Badge = Model.UserInfo.IsActive ? "Active Member" : "Activation Required",
    ActionText = Model.UserInfo.IsActive ? "Withdraw" : "Activate Now",
    ActionUrl = Model.UserInfo.IsActive ? "Wallet" : "Activate",
    ActionIcon = Model.UserInfo.IsActive ? "bi-wallet2" : "bi-shield-check"
})

<div class="member-quick-actions mb-4">
    <a asp-action="Wallet" class="member-quick-btn"><i class="bi bi-wallet2 text-success"></i> E-Wallet</a>
    <a asp-action="Tree" class="member-quick-btn"><i class="bi bi-diagram-3 text-primary"></i> My Team</a>
    <a asp-action="Kyc" class="member-quick-btn"><i class="bi bi-shield-check text-info"></i> KYC</a>
    <a asp-action="Support" class="member-quick-btn"><i class="bi bi-headset text-warning"></i> Support</a>
    @if (!Model.UserInfo.IsActive)
    {
        <a asp-action="Activate" class="member-quick-btn" style="border-color:rgba(236,72,153,0.35);color:#db2777!important;"><i class="bi bi-lightning-charge"></i> Activate</a>
    }
</div>

<div class="member-status-strip @(Model.UserInfo.IsActive ? "is-active" : "is-inactive") mb-4 d-flex align-items-center justify-content-between flex-wrap gap-3">
    <div class="d-flex align-items-center gap-3">
        <div class="member-stat-icon @(Model.UserInfo.IsActive ? "member-stat-icon-green" : "member-stat-icon-amber")">
            <i class="bi @(Model.UserInfo.IsActive ? "bi-shield-fill-check" : "bi-shield-fill-exclamation")"></i>
        </div>
        <div>
            <div class="fw-bold text-dark">Account @(Model.UserInfo.IsActive ? "Active" : "Inactive")</div>
            <div class="text-muted small mb-0">
                @(Model.UserInfo.IsActive
                    ? $"Activated {Model.UserInfo.ActivationDate?.ToString("dd MMM yyyy")}"
                    : "Complete activation to unlock commissions and withdrawals")
            </div>
        </div>
    </div>
    <span class="badge rounded-pill px-3 py-2 @(Model.UserInfo.IsActive ? "bg-success bg-opacity-10 text-success" : "bg-warning bg-opacity-10 text-warning")">
        @(Model.UserInfo.IsActive ? "Earning enabled" : "Pending activation")
    </span>
</div>

@if (announcements != null && announcements.Any())
{
    <div class="glass-card member-panel-card p-4 mb-4">
        <h5 class="member-panel-title mb-3"><i class="bi bi-megaphone text-primary me-2"></i>Latest Notices</h5>
        @foreach (var ann in announcements.Take(3))
        {
            <div class="member-announcement-item">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-1">
                    <span class="fw-bold text-dark small">@ann.Title</span>
                    <span class="text-muted flex-shrink-0" style="font-size:0.7rem;">@ann.CreatedDate.ToString("dd MMM yyyy")</span>
                </div>
                <p class="text-secondary small mb-0" style="white-space:pre-line;">@ann.Content</p>
            </div>
        }
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="glass-card member-stat-card h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="member-stat-label">Available wallet</p>
                    <p class="member-stat-value text-success">₹@Model.UserInfo.WalletBalance.ToString("N2")</p>
                    <a asp-action="Wallet" class="member-stat-link text-success">Withdraw <i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="member-stat-icon member-stat-icon-green"><i class="bi bi-wallet2"></i></div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="glass-card member-stat-card h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="member-stat-label">Uncleared income</p>
                    <p class="member-stat-value text-warning">₹@Model.UserInfo.IncomeWallet.ToString("N2")</p>
                    <span class="text-muted small">Clears at midnight</span>
                </div>
                <div class="member-stat-icon member-stat-icon-amber"><i class="bi bi-hourglass-split"></i></div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="glass-card member-stat-card h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="member-stat-label">Total earnings</p>
                    <p class="member-stat-value">₹@Model.TotalEarnings.ToString("N2")</p>
                    <span class="text-muted small">All levels combined</span>
                </div>
                <div class="member-stat-icon member-stat-icon-blue"><i class="bi bi-graph-up-arrow"></i></div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="glass-card member-stat-card h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="member-stat-label">Direct referrals</p>
                    <p class="member-stat-value">@Model.DirectReferralCount</p>
                    <a asp-action="MyDirect" class="member-stat-link text-primary">View team <i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="member-stat-icon member-stat-icon-violet"><i class="bi bi-person-check-fill"></i></div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="glass-card member-stat-card h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="member-stat-label">Network size</p>
                    <p class="member-stat-value">@Model.TotalTeamCount</p>
                    <span class="text-muted small">Active: <strong>@Model.ActiveTeamCount</strong></span>
                </div>
                <div class="member-stat-icon member-stat-icon-rose"><i class="bi bi-people-fill"></i></div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="glass-card member-panel-card p-4 h-100">
            <h5 class="member-panel-title mb-1"><i class="bi bi-bar-chart-line text-primary me-2"></i>30-Day Earnings</h5>
            <p class="text-muted small mb-3">Daily commissions and transfers</p>
            <div style="position:relative;height:260px;">
                <canvas id="earningsChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="glass-card member-panel-card p-4 h-100">
            <h5 class="member-panel-title mb-2"><i class="bi bi-trophy text-warning me-2"></i>Top Earners</h5>
            @if (leaderboard != null && leaderboard.Any())
            {
                int rank = 1;
                foreach (var item in leaderboard)
                {
                    <div class="d-flex align-items-center justify-content-between py-2 border-bottom border-light">
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-light text-dark">#@rank</span>
                            <div>
                                <div class="fw-semibold text-dark small">@item.FullName</div>
                                <div class="text-muted" style="font-size:0.72rem;">@@@item.Username</div>
                            </div>
                        </div>
                        <span class="text-success fw-bold small">₹@item.TotalEarned.ToString("N0")</span>
                    </div>
                    rank++;
                }
            }
            else
            {
                <div class="text-center py-4 text-muted small">No leaderboard data yet.</div>
            }
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="glass-card member-panel-card p-4 mb-4">
            <h5 class="member-panel-title mb-2"><i class="bi bi-share text-primary me-2"></i>Referral link</h5>
            <p class="text-muted small mb-3">Share this link to invite new members to your network.</p>
            <div class="copy-link-container mb-3">
                <input id="referralLink" class="copy-link-input" value="@Model.ReferralLink" readonly />
                <button id="copyBtn" type="button" onclick="copyReferralLink()" class="btn btn-cyber-cyan btn-sm px-4">
                    <i class="bi bi-copy me-1"></i>Copy
                </button>
            </div>
            <div class="border-top pt-3 d-flex flex-wrap justify-content-between align-items-center gap-2">
                <div class="small text-muted">
                    Placement node:
                    <strong class="text-dark">
                        @(Model.UserInfo.DefaultPlacement != null ? $"{Model.UserInfo.DefaultPlacement.FullName} (@{Model.UserInfo.DefaultPlacement.Username})" : "Direct under you")
                    </strong>
                </div>
                <button type="button" class="btn btn-sm btn-light border rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#placementPlacerModal">
                    <i class="bi bi-gear me-1"></i>Set placement
                </button>
            </div>
        </div>

        <div class="glass-card admin-table-card member-table-card" data-admin-table data-page-size="5" data-search-placeholder="Search commissions..." data-count-label="records">
            <div class="admin-table-header flex-wrap gap-2">
                <h5 class="member-panel-title mb-0"><i class="bi bi-receipt text-primary me-2"></i>Recent commissions</h5>
                <a asp-controller="User" asp-action="IncomeTransactions" class="member-stat-link text-primary ms-lg-auto">All transactions <i class="bi bi-arrow-right"></i></a>
            </div>
            @if (Model.RecentTransactions.Any())
            {
                <div class="admin-table-scroll">
                    <table class="table admin-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>From</th>
                                <th>Level</th>
                                <th>Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tx in Model.RecentTransactions)
                            {
                                var searchText = $"{tx.FromUser.Username} {tx.FromUser.FullName} {tx.Level} {tx.Amount}".ToLowerInvariant();
                                <tr data-search="@searchText">
                                    <td class="admin-subtext">@tx.Timestamp.ToString("dd MMM")</td>
                                    <td>
                                        <div class="fw-semibold text-dark small">@tx.FromUser.Username</div>
                                        <div class="admin-subtext">@tx.FromUser.FullName</div>
                                    </td>
                                    <td>
                                        @if (tx.Level > 0)
                                        {
                                            <span class="admin-badge-type admin-type-commission">L@tx.Level</span>
                                        }
                                        else
                                        {
                                            <span class="admin-badge-type">P2P</span>
                                        }
                                    </td>
                                    <td class="fw-bold @(tx.Amount > 0 ? "text-success" : "text-danger")">
                                        @(tx.Amount > 0 ? "+" : "")₹@tx.Amount.ToString("N2")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-4 text-center text-muted small">No commissions received yet.</div>
            }
        </div>
    </div>

    <div class="col-lg-5">
        <div class="glass-card member-panel-card p-4 mb-4">
            <h5 class="member-panel-title mb-3"><i class="bi bi-shield-check text-info me-2"></i>Activations</h5>
            @if (Model.ActivationRequests.Any())
            {
                @foreach (var req in Model.ActivationRequests.Take(5))
                {
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-light">
                        <div>
                            <div class="fw-semibold text-dark small">@req.TransactionReference</div>
                            <div class="admin-subtext">@req.CreatedDate.ToString("dd MMM yyyy")</div>
                        </div>
                        <span class="badge rounded-pill @(req.Status == "Approved" ? "bg-success" : req.Status == "Pending" ? "bg-warning" : "bg-danger") bg-opacity-10 text-dark">@req.Status</span>
                    </div>
                }
            }
            else
            {
                <p class="text-muted small mb-0">No activation requests yet.</p>
            }
        </div>
        <div class="glass-card member-panel-card p-4">
            <h5 class="member-panel-title mb-3"><i class="bi bi-cash-stack text-warning me-2"></i>Withdrawals</h5>
            @if (Model.WithdrawalRequests.Any())
            {
                @foreach (var w in Model.WithdrawalRequests.Take(5))
                {
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-light">
                        <div>
                            <div class="fw-semibold text-dark small">₹@w.Amount.ToString("N2")</div>
                            <div class="admin-subtext">@w.CreatedDate.ToString("dd MMM yyyy")</div>
                        </div>
                        <span class="badge rounded-pill @(w.Status == "Approved" ? "bg-success" : w.Status == "Pending" ? "bg-warning" : "bg-danger") bg-opacity-10 text-dark">@w.Status</span>
                    </div>
                }
            }
            else
            {
                <p class="text-muted small mb-0">No withdrawal requests yet.</p>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="placementPlacerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius:20px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-diagram-3 text-info me-2"></i>Set downline placement</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="SetPlacementNode" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body py-4">
                    <p class="text-muted small">Enter a username from your downline to place new recruits under them.</p>
                    <label class="form-label small fw-semibold">Upline username</label>
                    <input type="text" name="placementUsername" class="form-control rounded-3" placeholder="e.g. member01" required />
                </div>
                <div class="modal-footer border-0 pt-0">
                    @if (Model.UserInfo.DefaultPlacementId != null)
                    {
                        <button type="submit" name="placementUsername" value="" class="btn btn-outline-danger rounded-pill me-auto">Reset to direct</button>
                    }
                    <button type="button" class="btn btn-light rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function copyReferralLink() {
            var el = document.getElementById("referralLink");
            navigator.clipboard.writeText(el.value);
            var btn = document.getElementById("copyBtn");
            btn.innerHTML = '<i class="bi bi-check2 me-1"></i>Copied!';
            setTimeout(function () {
                btn.innerHTML = '<i class="bi bi-copy me-1"></i>Copy';
            }, 2000);
        }
        document.addEventListener("DOMContentLoaded", function () {
            fetch('/User/GetEarningsChartData')
                .then(r => r.json())
                .then(data => {
                    var ctx = document.getElementById('earningsChart').getContext('2d');
                    var gradient = ctx.createLinearGradient(0, 0, 0, 260);
                    gradient.addColorStop(0, 'rgba(124, 58, 237, 0.35)');
                    gradient.addColorStop(1, 'rgba(124, 58, 237, 0)');
                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: data.map(d => d.date),
                            datasets: [{
                                label: 'Earnings',
                                data: data.map(d => d.amount),
                                borderColor: '#7c3aed',
                                backgroundColor: gradient,
                                fill: true,
                                tension: 0.35,
                                borderWidth: 2.5
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { legend: { display: false } },
                            scales: {
                                x: { grid: { display: false }, ticks: { color: '#64748b', font: { size: 10 } } },
                                y: {
                                    grid: { color: 'rgba(100,116,139,0.08)' },
                                    ticks: { color: '#64748b', callback: v => '₹' + v }
                                }
                            }
                        }
                    });
                });
        });
    </script>
}
