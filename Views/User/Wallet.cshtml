@model MLM_Level.Models.UserWalletViewModel
@{
    ViewData["Title"] = "E-Wallet";
    var settings = ViewBag.MlmSettings as MLM_Level.Models.MlmSetting ?? new MLM_Level.Models.MlmSetting();
    var withdrawals = Model.Withdrawals.ToList();
    var canWithdraw = Model.WalletBalance > 0;
}

@await Html.PartialAsync("_MemberPageHeader", new MLM_Level.Models.MemberPageHeaderViewModel
{
    Title = "E-Wallet",
    Subtitle = "Withdraw to bank, transfer to members, and track withdrawal requests",
    Icon = "bi-wallet2",
    ThemeClass = "member-theme-emerald",
    Badge = $"₹{Model.WalletBalance:N0} available"
})

<div class="row g-3 mb-4">
    <div class="col-lg-4 col-md-6">
        <div class="glass-card member-stat-card h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="member-stat-label">Available balance</p>
                    <p class="member-stat-value text-success">₹@Model.WalletBalance.ToString("N2")</p>
                    <span class="wallet-chip wallet-chip-success">Ready to withdraw</span>
                </div>
                <div class="member-stat-icon member-stat-icon-green"><i class="bi bi-wallet2"></i></div>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6">
        <div class="glass-card member-stat-card h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="member-stat-label">Uncleared income</p>
                    <p class="member-stat-value text-warning">₹@Model.IncomeWallet.ToString("N2")</p>
                    <span class="text-muted small">Clears at midnight</span>
                </div>
                <div class="member-stat-icon member-stat-icon-amber"><i class="bi bi-hourglass-split"></i></div>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-12">
        <div class="glass-card member-stat-card h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="member-stat-label">Lifetime earned</p>
                    <p class="member-stat-value">₹@Model.TotalIncome.ToString("N2")</p>
                    <a asp-controller="User" asp-action="IncomeTransactions" class="member-stat-link text-primary small">View all transactions <i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="member-stat-icon member-stat-icon-blue"><i class="bi bi-graph-up-arrow"></i></div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5 col-12">
        <div class="glass-card wallet-withdraw-card member-panel-card h-100">
            <div class="wallet-withdraw-header">
                <div class="wallet-withdraw-header-icon"><i class="bi bi-bank2"></i></div>
                <div>
                    <h5 class="wallet-withdraw-title mb-1">Request wallet withdrawal</h5>
                    <p class="wallet-withdraw-subtitle mb-0">Transfer spendable balance to your bank account</p>
                </div>
            </div>

            <div class="wallet-info-pills">
                <div class="wallet-info-pill">
                    <span class="wallet-info-pill-label">Available</span>
                    <span class="wallet-info-pill-value text-success">₹@Model.WalletBalance.ToString("N0")</span>
                </div>
                <div class="wallet-info-pill">
                    <span class="wallet-info-pill-label">Min withdraw</span>
                    <span class="wallet-info-pill-value">₹@settings.MinWithdrawalLimit.ToString("N0")</span>
                </div>
                <div class="wallet-info-pill">
                    <span class="wallet-info-pill-label">Processing fee</span>
                    <span class="wallet-info-pill-value text-warning">@settings.WithdrawalFeePercent%</span>
                </div>
            </div>

            <form asp-action="RequestWithdrawal" method="post" class="wallet-withdraw-form">
                @Html.AntiForgeryToken()
                <label class="wallet-field-label" for="withdrawAmount">Withdrawal amount</label>
                <div class="wallet-amount-input-wrap">
                    <span class="wallet-amount-prefix">₹</span>
                    <input type="number" id="withdrawAmount" name="amount" class="wallet-amount-input"
                           placeholder="@settings.MinWithdrawalLimit.ToString("N0")"
                           step="1" min="@settings.MinWithdrawalLimit" max="@Model.WalletBalance"
                           required @(canWithdraw ? "" : "disabled") />
                </div>
                <p class="wallet-field-hint" id="withdrawHint">
                    Enter between ₹@settings.MinWithdrawalLimit.ToString("N0") and ₹@Model.WalletBalance.ToString("N2")
                </p>

                <button type="submit" class="btn wallet-btn-withdraw w-100" @(canWithdraw ? "" : "disabled")>
                    <i class="bi bi-send-fill me-2"></i>Submit withdrawal request
                </button>
            </form>

            <div class="wallet-p2p-divider">
                <span>or send to a member</span>
            </div>

            <button type="button" class="btn wallet-btn-p2p" data-bs-toggle="modal" data-bs-target="#p2pTransferModal" @(canWithdraw ? "" : "disabled")>
                <i class="bi bi-arrow-left-right me-2"></i>Peer-to-peer transfer
            </button>
        </div>
    </div>

    <div class="col-lg-7 col-12">
        <div class="glass-card admin-table-card member-panel-card h-100" data-admin-table data-page-size="10" data-search-placeholder="Search withdrawals..." data-count-label="requests">
            <div class="admin-table-header flex-wrap gap-2">
                <h5 class="member-panel-title mb-0"><i class="bi bi-clock-history text-info me-2"></i>Withdrawal requests</h5>
                <span class="admin-record-badge" data-admin-table-count>@withdrawals.Count requests</span>
                <div class="admin-search-wrap admin-table-search-wrap ms-lg-auto" style="min-width:200px;max-width:280px;">
                    <i class="bi bi-search admin-search-icon"></i>
                    <input type="search" data-admin-table-search class="form-control admin-search-input" placeholder="Search..." autocomplete="off" />
                </div>
            </div>
            @if (withdrawals.Any())
            {
                <div class="admin-table-scroll">
                    <table class="table admin-table">
                        <thead>
                            <tr>
                                <th>Request</th>
                                <th>Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var w in withdrawals)
                            {
                                var searchText = $"{w.Amount} {w.Status} {w.CreatedDate}".ToLowerInvariant();
                                <tr data-search="@searchText">
                                    <td>
                                        <div class="fw-semibold text-dark small">@w.CreatedDate.ToString("dd MMM yyyy")</div>
                                        <div class="admin-subtext">@w.CreatedDate.ToString("hh:mm tt")</div>
                                    </td>
                                    <td class="fw-bold text-dark">₹@w.Amount.ToString("N2")</td>
                                    <td>
                                        @if (w.Status == "Approved")
                                        {
                                            <span class="admin-badge-success"><i class="bi bi-check-circle me-1"></i>Approved</span>
                                        }
                                        else if (w.Status == "Pending")
                                        {
                                            <span class="admin-badge-pending"><i class="bi bi-hourglass-split me-1"></i>Pending</span>
                                        }
                                        else
                                        {
                                            <span class="admin-badge-danger"><i class="bi bi-x-circle me-1"></i>Rejected</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="wallet-empty-inline p-4 text-center">
                    <i class="bi bi-inbox text-muted d-block mb-2" style="font-size:1.75rem;"></i>
                    <p class="text-muted small mb-0">No withdrawal requests yet.</p>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="p2pTransferModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg wallet-modal">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-arrow-left-right text-primary me-2"></i>P2P transfer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="P2PTransfer" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body py-4">
                    <p class="text-muted small mb-3">Send funds instantly to another member inside the network. Transfers are permanent and audited.</p>
                    <div class="mb-3">
                        <label class="wallet-field-label">Receiver username</label>
                        <input type="text" name="receiverUsername" class="form-control rounded-3" placeholder="e.g. member01" required />
                    </div>
                    <div class="mb-0">
                        <label class="wallet-field-label">Amount (₹)</label>
                        <div class="wallet-amount-input-wrap">
                            <span class="wallet-amount-prefix">₹</span>
                            <input type="number" name="amount" class="wallet-amount-input" placeholder="250" min="1" max="@Model.WalletBalance" required />
                        </div>
                        <p class="wallet-field-hint mb-0">Available: ₹@Model.WalletBalance.ToString("N2")</p>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 gap-2">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn wallet-btn-withdraw rounded-pill px-4">Transfer now</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var input = document.getElementById('withdrawAmount');
            var hint = document.getElementById('withdrawHint');
            var feePct = @settings.WithdrawalFeePercent.ToString(System.Globalization.CultureInfo.InvariantCulture);
            if (!input || !hint) return;
            input.addEventListener('input', function () {
                var amt = parseFloat(this.value);
                if (!amt || amt <= 0) {
                    hint.textContent = 'Enter between ₹@settings.MinWithdrawalLimit.ToString("N0") and ₹@Model.WalletBalance.ToString("N2")';
                    return;
                }
                var net = amt - (amt * feePct / 100);
                hint.innerHTML = 'Estimated bank credit: <strong class="text-success">₹' + net.toFixed(2) + '</strong> after ' + feePct + '% fee';
            });
        })();
    </script>
}
