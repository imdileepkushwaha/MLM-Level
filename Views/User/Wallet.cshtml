@model MLM_Level.Models.UserWalletViewModel
@{
    ViewData["Title"] = "E-Wallet Transactions & Withdrawals";
}

<!-- Alert Notifications -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 12px;">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 12px;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4 mb-4">
    <!-- Wallet stats -->
    <div class="col-md-6">
        <div class="glass-card p-4 h-100 d-flex justify-content-between align-items-center">
            <div>
                <p class="text-secondary small fw-medium mb-1">Available E-Wallet Balance</p>
                <h2 class="text-slate-800 fw-extrabold mb-2" style="font-size: 2.5rem;">₹@Model.WalletBalance.ToString("N2")</h2>
                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill fw-bold small">
                    <i class="bi bi-wallet2 me-1"></i> Funds Unlocked & Spendable
                </span>
            </div>
            <div class="stat-icon-box icon-box-cyan" style="width: 64px; height: 64px; font-size: 1.8rem;">
                <i class="bi bi-cash-stack"></i>
            </div>
        </div>
    </div>

    <!-- Total Income -->
    <div class="col-md-6">
        <div class="glass-card p-4 h-100 d-flex justify-content-between align-items-center">
            <div>
                <p class="text-secondary small fw-medium mb-1">Cumulative Level Income</p>
                <h2 class="text-slate-800 fw-extrabold mb-2" style="font-size: 2.5rem;">₹@Model.TotalIncome.ToString("N2")</h2>
                <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-3 py-2 rounded-pill fw-bold small">
                    <i class="bi bi-graph-up-arrow me-1"></i> Total Commissions Distributed
                </span>
            </div>
            <div class="stat-icon-box icon-box-blue" style="width: 64px; height: 64px; font-size: 1.8rem;">
                <i class="bi bi-trophy"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Left Column: Payout Ledger -->
    <div class="col-lg-7 col-12">
        <div class="glass-card p-4 h-100" id="printArea">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="text-slate-800 fw-bold mb-0"><i class="bi bi-receipt text-primary me-2 text-print-dark"></i>Income Transaction Ledger</h5>
                <button onclick="window.print()" class="btn btn-sm btn-light border rounded-pill px-3 shadow-sm d-print-none fw-semibold">
                    <i class="bi bi-printer me-1"></i>Print Statement
                </button>
            </div>
            
            <!-- Company Letterhead for Printing -->
            <div class="d-none d-print-block mb-4 border-bottom pb-3">
                <h3 class="fw-bold text-dark mb-1">ELITE MLM PLATFORM</h3>
                <p class="text-muted small mb-0">Official E-Wallet Income Statement & Transaction Ledger</p>
                <p class="text-muted small mb-0">Generated on: @DateTime.UtcNow.ToString("dd MMM yyyy, hh:mm tt") UTC</p>
            </div>

            <div class="glass-table-container">
                @if (Model.IncomeLedger.Any())
                {
                    <table class="table glass-table align-middle">
                        <thead>
                            <tr class="text-secondary small border-bottom border-light">
                                <th>Date</th>
                                <th>Description / Source</th>
                                <th>Level</th>
                                <th>Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tx in Model.IncomeLedger)
                            {
                                <tr class="border-bottom border-light">
                                    <td class="small text-secondary">@tx.Timestamp.ToString("dd MMM yyyy hh:mm tt")</td>
                                    <td>
                                        <div class="fw-bold text-slate-800 text-print-dark">@tx.Description</div>
                                        <div class="small text-muted">Source: @tx.FromUser.FullName (@@@tx.FromUser.Username)</div>
                                    </td>
                                    <td>
                                        @if (tx.Level > 0)
                                        {
                                            <span class="badge bg-opacity-10 bg-info text-info border border-info border-opacity-25 px-2 py-1">Level @tx.Level</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-opacity-10 bg-secondary text-secondary border border-secondary border-opacity-25 px-2 py-1">P2P</span>
                                        }
                                    </td>
                                    <td>
                                        @if (tx.Amount > 0)
                                        {
                                            <strong class="text-success">+₹@tx.Amount.ToString("N2")</strong>
                                        }
                                        else
                                        {
                                            <strong class="text-danger">-₹@Math.Abs(tx.Amount).ToString("N2")</strong>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center py-5 text-secondary">
                        <i class="bi bi-file-earmark-text display-6 mb-2 d-block text-muted"></i>
                        No transactions recorded in your wallet ledger yet.
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Right Column: Withdraw Request Form & History -->
    <div class="col-lg-5 col-12 d-print-none">
        <!-- Request Form -->
        <div class="glass-card p-4 mb-4">
            <h5 class="text-slate-800 fw-bold mb-3"><i class="bi bi-cash-coin text-pink me-2"></i>Request Wallet Withdrawal</h5>
            <p class="text-secondary small mb-4">Transfer unlocked funds from your e-wallet balance to your registered bank account.</p>

            <form asp-action="RequestWithdrawal" method="post" class="mb-3">
                <div class="mb-3 form-group">
                    <label class="form-label text-secondary small fw-semibold">Withdrawal Amount (₹)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light text-secondary border-end-0" style="border-radius: 10px 0 0 10px;">₹</span>
                        <input type="number" name="amount" class="form-control" placeholder="e.g. 500" step="1" min="1" max="@Model.WalletBalance" required style="border-radius: 0 10px 10px 0; border-left: none;" />
                    </div>
                    <small class="text-muted mt-2 d-block" style="font-size: 0.75rem;">Available limit: ₹@Model.WalletBalance.ToString("N2")</small>
                </div>

                <button type="submit" class="btn btn-cyber-pink w-100 py-2 rounded-pill fw-semibold @(Model.WalletBalance <= 0 ? "disabled" : "")" @(Model.WalletBalance <= 0 ? "disabled" : "")>
                    <i class="bi bi-box-arrow-right me-1"></i>Request Cashout
                </button>
            </form>

            <div class="border-top border-light pt-3 text-center">
                <span class="text-secondary small me-2">Or, transfer to another member:</span>
                <button class="btn btn-sm btn-primary rounded-pill px-4 shadow-sm fw-semibold" data-bs-toggle="modal" data-bs-target="#p2pTransferModal" @(Model.WalletBalance <= 0 ? "disabled" : "")>
                    <i class="bi bi-arrow-left-right me-1"></i>P2P Transfer
                </button>
            </div>
        </div>

        <!-- Withdrawal Logs -->
        <div class="glass-card p-4">
            <h5 class="text-slate-800 fw-bold mb-3"><i class="bi bi-clock-history text-info me-2"></i>Withdrawal Requests Log</h5>
            <div class="glass-table-container">
                @if (Model.Withdrawals.Any())
                {
                    <table class="table glass-table align-middle">
                        <thead>
                            <tr class="text-secondary small border-bottom border-light">
                                <th>Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var w in Model.Withdrawals)
                            {
                                <tr class="border-bottom border-light">
                                    <td>
                                        <strong class="text-slate-800">₹@w.Amount.ToString("N2")</strong><br/>
                                        <span class="small text-muted" style="font-size: 0.75rem;">@w.CreatedDate.ToString("dd MMM yyyy")</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-opacity-10 @(w.Status == "Approved" ? "bg-success text-success" : w.Status == "Pending" ? "bg-warning text-warning" : "bg-danger text-danger") px-3 py-1 rounded-pill small">@w.Status</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center py-4 text-secondary small">
                        No withdrawal requests recorded.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- P2P Transfer Modal -->
<div class="modal fade" id="p2pTransferModal" tabindex="-1" aria-labelledby="p2pTransferModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-slate-800" id="p2pTransferModalLabel"><i class="bi bi-arrow-left-right text-primary me-2"></i>Peer-to-Peer Fund Transfer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="P2PTransfer" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body py-4">
                    <p class="text-secondary small mb-3">
                        Transfer funds instantly from your e-wallet to another member's wallet inside the network. This transaction is audited and permanent.
                    </p>
                    <div class="mb-3">
                        <label class="form-label text-secondary small fw-semibold">Receiver Username</label>
                        <input type="text" name="receiverUsername" class="form-control rounded-3" placeholder="e.g. rahul_active" required />
                    </div>
                    <div class="mb-0">
                        <label class="form-label text-secondary small fw-semibold">Transfer Amount (₹)</label>
                        <input type="number" name="amount" class="form-control rounded-3" placeholder="e.g. 250" min="1" max="@Model.WalletBalance" required />
                        <div class="form-text text-muted small mt-1">Available for transfer: ₹@Model.WalletBalance.ToString("N2")</div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 justify-content-end">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Transfer Instantly</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    @@media print {
        body * {
            visibility: hidden;
        }
        #printArea, #printArea * {
            visibility: visible;
        }
        #printArea {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            padding: 20px;
            background: white !important;
            color: #000 !important;
            box-shadow: none !important;
            border: none !important;
        }
        .text-print-dark {
            color: #000 !important;
        }
        .table {
            border-collapse: collapse !important;
            width: 100% !important;
        }
        .table th, .table td {
            background-color: #fff !important;
            border: 1px solid #ddd !important;
            padding: 8px !important;
            color: #000 !important;
        }
    }
</style>
