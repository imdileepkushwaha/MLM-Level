@model IEnumerable<MLM_Level.Models.CommissionTran>
@{
    ViewData["Title"] = "Daily Income";
    var list = Model?.ToList() ?? new List<MLM_Level.Models.CommissionTran>();
    var total = (decimal)(ViewBag.TotalIncome ?? 0m);
}

@await Html.PartialAsync("_MemberPageHeader", new MLM_Level.Models.MemberPageHeaderViewModel
{
    Title = "Daily ROI Income",
    Subtitle = "Daily returns from your active packages",
    Icon = "bi-calendar-check",
    ThemeClass = "member-theme-emerald",
    Badge = $"₹{total:N0} total"
})

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="glass-card member-stat-card h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="member-stat-label">Total daily income</p>
                    <p class="member-stat-value text-success">₹@total.ToString("N2")</p>
                    <span class="text-muted small">@list.Count transactions</span>
                </div>
                <div class="member-stat-icon member-stat-icon-green"><i class="bi bi-calendar-check"></i></div>
            </div>
        </div>
    </div>
</div>

<div class="glass-card admin-table-card" data-admin-table data-page-size="15" data-search-placeholder="Search transactions..." data-count-label="records">
    <div class="admin-table-header flex-wrap gap-2">
        <h5 class="member-panel-title mb-0"><i class="bi bi-cash-stack text-success me-2"></i>Income ledger</h5>
        <span class="admin-record-badge" data-admin-table-count>@list.Count records</span>
        <div class="admin-search-wrap admin-table-search-wrap ms-lg-auto" style="min-width:220px;max-width:320px;">
            <i class="bi bi-search admin-search-icon"></i>
            <input type="search" data-admin-table-search class="form-control admin-search-input" placeholder="Search..." autocomplete="off" />
        </div>
    </div>
    @if (list.Any())
    {
        <div class="admin-table-scroll">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Description</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in list)
                    {
                        var searchText = $"{item.Description} {item.Amount} {item.Timestamp}".ToLowerInvariant();
                        <tr data-search="@searchText">
                            <td class="admin-subtext">@item.Timestamp.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</td>
                            <td><span class="text-dark small">@item.Description</span></td>
                            <td class="text-end fw-bold text-success">+₹@item.Amount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        @await Html.PartialAsync("_AdminNoResults")
    }
</div>
