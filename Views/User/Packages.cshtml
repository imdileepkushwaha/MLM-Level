@model MLM_Level.Models.UserPackagesViewModel
@{
    ViewData["Title"] = "Packages";
    var user = Model.UserInfo;
    var settings = Model.Settings;
    var packages = Model.AvailablePackages;
    var activePackages = Model.ActivePackages;
    var recentRequests = Model.RecentRequests;
    var pending = Model.PendingRequest;
    var totalInvested = activePackages.Sum(p => p.Amount);
    var showPurchase = !Model.HasPendingRequest && packages.Any();
    var isInactive = !user.IsActive;
    var purchaseTitle = isInactive ? "Activate your account" : "Buy another package";
    var purchaseSubtitle = isInactive
        ? "Complete all 3 steps to submit your first activation request"
        : "Purchase an additional plan to increase ROI and network benefits";
}

@await Html.PartialAsync("_MemberPageHeader", new MemberPageHeaderViewModel
{
    Title = "Membership Packages",
    Subtitle = user.IsActive
        ? "Browse plans, purchase new packages, and track ROI progress"
        : "Select a plan and submit payment proof to activate your account",
    Icon = "bi-box-seam",
    ThemeClass = "member-theme-violet",
    Badge = user.IsActive ? $"{activePackages.Count} active" : "Activation required",
    ActionText = Model.HasPendingRequest ? null : (user.IsActive ? "View history" : null),
    ActionUrl = "ActivationReport",
    ActionIcon = "bi-clock-history"
})

<div class="row g-3 mb-4">
    <div class="col-lg-4 col-md-6">
        <div class="glass-card member-stat-card h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="member-stat-label">Available plans</p>
                    <p class="member-stat-value">@packages.Count</p>
                    <span class="text-muted small">Ready to purchase</span>
                </div>
                <div class="member-stat-icon member-stat-icon-blue"><i class="bi bi-layers"></i></div>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6">
        <div class="glass-card member-stat-card h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="member-stat-label">Active packages</p>
                    <p class="member-stat-value text-success">@activePackages.Count</p>
                    <span class="text-muted small">₹@totalInvested.ToString("N0") invested</span>
                </div>
                <div class="member-stat-icon member-stat-icon-green"><i class="bi bi-check-circle"></i></div>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-12">
        <div class="glass-card member-stat-card h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="member-stat-label">@(user.IsActive ? "Member since" : "Account status")</p>
                    @if (user.IsActive && user.ActivationDate.HasValue)
                    {
                        <p class="member-stat-value text-success">@user.ActivationDate.Value.ToLocalTime().ToString("dd MMM yyyy")</p>
                        <span class="wallet-chip wallet-chip-success">Active member</span>
                    }
                    else
                    {
                        <p class="member-stat-value text-warning">Inactive</p>
                        @if (Model.HasPendingRequest)
                        {
                            <span class="wallet-chip wallet-chip-warning">Request pending</span>
                        }
                        else
                        {
                            <span class="text-muted small">Choose a plan below</span>
                        }
                    }
                </div>
                <div class="member-stat-icon member-stat-icon-amber"><i class="bi bi-shield-check"></i></div>
            </div>
        </div>
    </div>
</div>

@if (Model.HasPendingRequest && pending != null)
{
    <div class="glass-card member-panel-card mb-4 border-warning border-opacity-25">
        <div class="d-flex flex-wrap align-items-center gap-3 p-1">
            <div class="member-package-pending-icon"><i class="bi bi-hourglass-split"></i></div>
            <div class="flex-grow-1">
                <h5 class="text-dark fw-bold mb-1">Payment verification in progress</h5>
                <p class="text-muted small mb-0">
                    <strong>@(pending.Package?.Name ?? "Package")</strong> · ₹@pending.Amount.ToString("N0") · UTR <code>@pending.TransactionReference</code>
                    · submitted @pending.CreatedDate.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")
                </p>
            </div>
            <a asp-action="ActivationReport" class="btn btn-sm btn-light border rounded-pill px-3">View all requests</a>
        </div>
    </div>
}
else if (!packages.Any())
{
    <div class="glass-card member-panel-card text-center p-5 mb-4">
        <i class="bi bi-exclamation-triangle text-warning d-block mb-3" style="font-size:2.5rem;"></i>
        <h5 class="text-dark fw-bold">No packages available</h5>
        <p class="text-muted small mb-0">Admin has not published any active plans yet. Please contact support.</p>
    </div>
}

@if (isInactive && showPurchase)
{
    <div class="glass-card member-panel-card p-4 mb-4">
        <h5 class="text-dark fw-bold mb-1"><i class="bi bi-lightning-charge text-warning me-2"></i>@purchaseTitle</h5>
        <p class="text-muted small mb-4">@purchaseSubtitle</p>
        @await Html.PartialAsync("_PackagePurchaseForm", Model)
    </div>
}

@if (activePackages.Any())
{
    <div class="glass-card admin-table-card member-panel-card mb-4" data-admin-table data-page-size="5" data-search-placeholder="Search packages..." data-count-label="packages">
        <div class="admin-table-header flex-wrap gap-2">
            <h5 class="member-panel-title mb-0"><i class="bi bi-check2-square text-success me-2"></i>My active packages</h5>
            <span class="admin-record-badge" data-admin-table-count>@activePackages.Count packages</span>
        </div>
        <div class="admin-table-scroll">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>Package</th>
                        <th>Invested</th>
                        <th>ROI progress</th>
                        <th>Activated</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var up in activePackages)
                    {
                        var progress = up.RoiDurationDays > 0 ? Math.Min(100, (int)Math.Round(up.DaysPaid * 100.0 / up.RoiDurationDays)) : 100;
                        var searchText = $"{up.Package?.Name} {up.Amount} {up.ActivationDate}".ToLowerInvariant();
                        <tr data-search="@searchText">
                            <td>
                                <div class="fw-semibold text-dark small">@(up.Package?.Name ?? "Package")</div>
                                @if (up.RoiDurationDays > 0)
                                {
                                    <div class="admin-subtext">@up.RoiPercentage% daily · @up.RoiDurationDays days</div>
                                }
                            </td>
                            <td class="fw-bold text-dark">₹@up.Amount.ToString("N0")</td>
                            <td style="min-width:140px;">
                                @if (up.RoiDurationDays > 0)
                                {
                                    <div class="progress" style="height:6px;">
                                        <div class="progress-bar bg-success" style="width:@progress%"></div>
                                    </div>
                                    <div class="admin-subtext">@up.DaysPaid / @up.RoiDurationDays days paid</div>
                                }
                                else
                                {
                                    <span class="admin-subtext">—</span>
                                }
                            </td>
                            <td class="admin-subtext">@up.ActivationDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td>
                                @if (up.IsActive)
                                {
                                    <span class="admin-badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="admin-badge-pending">Completed</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (recentRequests.Any())
{
    <div class="glass-card admin-table-card member-panel-card" data-admin-table data-page-size="5" data-search-placeholder="Search requests..." data-count-label="requests">
        <div class="admin-table-header flex-wrap gap-2">
            <h5 class="member-panel-title mb-0"><i class="bi bi-clock-history text-info me-2"></i>Recent requests</h5>
            <span class="admin-record-badge" data-admin-table-count>@recentRequests.Count requests</span>
            <a asp-action="ActivationReport" class="member-stat-link text-primary ms-lg-auto">Full history <i class="bi bi-arrow-right"></i></a>
        </div>
        <div class="admin-table-scroll">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Package</th>
                        <th>Amount</th>
                        <th>UTR</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in recentRequests)
                    {
                        var searchText = $"{req.Package?.Name} {req.TransactionReference} {req.Amount} {req.Status} {req.RejectionReason}".ToLowerInvariant();
                        <tr data-search="@searchText">
                            <td class="admin-subtext">@req.CreatedDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td class="text-dark small">@(req.Package?.Name ?? "—")</td>
                            <td class="fw-bold text-dark">₹@req.Amount.ToString("N0")</td>
                            <td><code class="text-primary small">@req.TransactionReference</code></td>
                            <td>
                                @if (req.Status == "Approved")
                                {
                                    <span class="admin-badge-success">Approved</span>
                                }
                                else if (req.Status == "Pending")
                                {
                                    <span class="admin-badge-pending">Pending</span>
                                }
                                else
                                {
                                    <span class="admin-badge-danger">Rejected</span>
                                    @if (!string.IsNullOrWhiteSpace(req.RejectionReason))
                                    {
                                        <div class="admin-subtext text-danger mt-1">@req.RejectionReason</div>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (!isInactive && showPurchase)
{
    <div class="glass-card member-panel-card mb-4 mt-4">
        <button class="btn btn-light border w-100 d-flex align-items-center justify-content-between p-3 rounded-3"
                type="button" data-bs-toggle="collapse" data-bs-target="#buyPackageCollapse" aria-expanded="false">
            <span class="fw-bold text-dark"><i class="bi bi-plus-circle text-primary me-2"></i>@purchaseTitle</span>
            <i class="bi bi-chevron-down text-muted"></i>
        </button>
        <div class="collapse" id="buyPackageCollapse">
            <div class="p-4 pt-3 border-top">
                <p class="text-muted small mb-4">@purchaseSubtitle</p>
                @await Html.PartialAsync("_PackagePurchaseForm", Model)
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        function selectPackage(id, price, element) {
            document.getElementById('packageId').value = id;
            document.querySelectorAll('.custom-plan-card').forEach(function (card) {
                card.classList.remove('active-selected');
                var btn = card.querySelector('.plan-select-btn');
                if (btn) btn.innerText = 'Choose plan';
            });
            element.classList.add('active-selected');
            var selectedBtn = element.querySelector('.plan-select-btn');
            if (selectedBtn) selectedBtn.innerText = 'Selected';
            var priceText = parseFloat(price).toLocaleString('en-IN');
            document.getElementById('displayTransferAmount').innerText = '₹' + priceText;
            document.getElementById('instructionPriceText').innerText = '₹' + priceText;
        }
        function copyValue(elementId) {
            var val = document.getElementById(elementId).innerText;
            navigator.clipboard.writeText(val).then(function () { alert('Copied to clipboard'); });
        }
    </script>
}
